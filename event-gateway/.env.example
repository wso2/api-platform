# Copy this file to .env before starting the stack:
#   cp .env.example .env

# Required: registration token used by gateway-controller when connecting
# to the platform-api control plane.
GATEWAY_REGISTRATION_TOKEN=replace-with-real-gateway-registration-token

# Optional: override the control plane host if needed locally.
GATEWAY_CONTROLPLANE_HOST=connect.preview-dv.bijira.dev
