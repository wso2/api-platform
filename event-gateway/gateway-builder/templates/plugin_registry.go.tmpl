package main

import (
	"context"
	"log/slog"

	"github.com/wso2/api-platform/gateway/gateway-runtime/policy-engine/pkg/engine"
	policy "github.com/wso2/api-platform/sdk/core/policy/v1alpha2"
{{- range .GoPolicies }}
	{{ .ImportAlias }} "{{ .ImportPath }}"
{{- end }}
)

// Code generated by Event Gateway Builder. DO NOT EDIT.
// init registers compiled-in policies into the global registry singleton via engine.RegisterPolicy.
// engine.New() seeds its private registry from this global registry on startup.
func init() {
	ctx := context.Background()
	slog.InfoContext(ctx, "Registering policies from Event Gateway Builder compilation")

	{{- range .GoPolicies }}
	// Register {{ .Name }} {{ .Version }}
	if err := engine.RegisterPolicy(&policy.PolicyDefinition{
		Name:    "{{ .Name }}",
		Version: "{{ .Version }}",
		SystemParameters: {{ if .SystemParameters }}map[string]interface{}{
			{{- range $key, $value := .SystemParameters }}
			"{{ $key }}": {{ printf "%#v" $value }},
			{{- end }}
		}{{ else }}nil{{ end }},
	}, {{ .ImportAlias }}.GetPolicy); err != nil {
		slog.ErrorContext(ctx, "Failed to register policy {{ .Name }} version {{ .Version }}", "error", err)
	} else {
		slog.InfoContext(ctx, "Registered policy {{ .Name }} version {{ .Version }}")
	}
	{{- end }}
}
