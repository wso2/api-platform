{
  "request": {
    "method": "POST",
    "url": "/mcp",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.method",
          "equalTo": "tools/call"
        }
      },
      {
        "matchesJsonPath": {
          "expression": "$.params.name",
          "equalTo": "addBook"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": "{\"jsonrpc\":\"2.0\",\"id\":{{jsonPath request.body '$.id'}},\"result\":{\"content\":[{\"type\":\"text\",\"text\":\"{\\\"id\\\":\\\"4\\\",\\\"title\\\":\\\"The Phoenix Project\\\",\\\"author\\\":\\\"Gene Kim\\\",\\\"status\\\":\\\"to_read\\\"}\"}]}}",
    "transformers": ["response-template"]
  }
}
