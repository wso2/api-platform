{
  "request": {
    "method": "POST",
    "url": "/mcp",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.method",
          "equalTo": "initialize"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": "{\"jsonrpc\":\"2.0\",\"id\":{{jsonPath request.body '$.id'}},\"result\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{\"tools\":{\"listChanged\":true}},\"serverInfo\":{\"name\":\"reading-list-mcp\",\"version\":\"1.0.0\"}}}",
    "transformers": ["response-template"]
  }
}
