{
  "name": "kb-search-shipping",
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/mcp",
    "bodyPatterns": [
      { "matchesJsonPath": "$[?(@.method == 'tools/call')]" },
      { "matchesJsonPath": "$[?(@.params.name == 'search_kb')]" },
      { "matchesJsonPath": "$[?(@.params.arguments.query =~ /.*ship.*/i)]" }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "kb-search-shipping.json"
  }
}
