    "jose": "5.10.0",
    "js-yaml": "4.3.0",
    "jsonwebtoken": "9.0.3",
    "marked": "13.0.3",
    "minimatch": "10.2.5",
    "multer": "1.4.5-lts.1",
    "passport": "0.7.0",
    "passport-oauth2": "1.8.0",
    "pg": "8.22.0",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.8",
