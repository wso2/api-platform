{
  "name": "devportal-webapp",
  "version": "1.0.0-beta-SNAPSHOT",
  "description": "WSO2 API Platform Developer Portal",
  "main": "src/server.js",
  "scripts": {
    "start": "npm rebuild better-sqlite3 --ignore-scripts=false && NODE_ENV=development nodemon src/server.js",
    "start:local": "APIP_DP_TLS_ENABLED=false APIP_DP_SERVER_BASEURL=http://localhost:3000 APIP_DP_PLATFORMAPI_BASEURL=https://localhost:9243 APIP_DP_PLATFORMAPI_INSECURE=true APIP_DP_DATABASE_FILE=./devportal.db npm run start",
    "debug": "nodemon --inspect src/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wso2/api-platform.git",
    "directory": "portals/developer-portal"
  },
  "keywords": [
    "WSO2",
    "API Platform",
    "Developer Portal",
    "Node.js"
  ],
  "author": "WSO2 LLC",
  "license": "Apache-2.0",
  "engines": {
    "node": "24.x"
  },
  "bugs": {
    "url": "https://github.com/wso2/api-platform/issues"
  },
  "homepage": "https://github.com/wso2/api-platform/tree/main/portals/developer-portal#readme",
  "dependencies": {
    "axios": "1.18.1",
    "better-sqlite3": "12.11.1",
    "bootstrap-icons": "1.13.1",
    "connect-pg-simple": "10.0.0",
    "connect-session-sequelize": "7.1.7",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "express-handlebars": "7.1.3",
    "express-openapi-validator": "4.13.9",
    "express-session": "1.19.0",
    "express-validator": "7.3.2",
    "graphql": "16.14.2",
