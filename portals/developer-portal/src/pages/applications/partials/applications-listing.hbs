{{#pageHead}}
  <link rel='stylesheet' href='/technical-styles/applications.css' />
{{/pageHead}}

<div class="page-container">

  <!-- Page header -->
  <div class="page-header">
    <div>
      <h1 class="page-title">Applications</h1>
      <p class="page-desc">Applications hold the API keys and subscriptions you use to call APIs.</p>
    </div>
    {{#if applicationsMetadata.length}}
    <button class="apps-create-btn" id="apps-create-btn" type="button"
      >
      <i class="bi bi-plus"></i> Create application
    </button>
    {{/if}}
  </div>

  <!-- Empty state -->
  {{#unless applicationsMetadata.length}}
  <div class="dp-empty">
    <span class="dp-empty-icon"><i class="bi bi-grid-3x3-gap-fill"></i></span>
    <h2 class="dp-empty-title">No applications yet</h2>
    <p class="dp-empty-desc">Create an application to generate API keys and subscribe to APIs. You can manage all your credentials in one place.</p>
    <button class="dp-btn dp-btn--primary dp-btn--lg" id="apps-create-btn-empty" type="button"
      >
      <i class="bi bi-plus"></i> Create application
    </button>
  </div>
  {{/unless}}

  <!-- Card grid -->
  {{#if applicationsMetadata.length}}
  <div class="apps-grid" id="applicationsContainer">
    {{#applicationsMetadata}}
    <div class="app-card" id="app-card-{{id}}" data-id="{{id}}" data-display-name="{{displayName}}"
      style="cursor:pointer;" onclick="window.location.href='{{../baseUrl}}/applications/{{id}}'">

      <div class="app-card-top">
        <span class="app-avatar" data-display-name="{{displayName}}"></span>
        <div class="app-card-meta">
          <h3 class="app-card-name">{{displayName}}</h3>
        </div>
      </div>

      <p class="app-card-desc">{{description}}</p>

      <div class="app-card-footer">
        <button type="button" class="app-delete-btn" id="trash-btn-{{id}}"
          title="Delete application" data-app-id="{{id}}" data-app-name="{{displayName}}">
          <i class="bi bi-trash"></i>
        </button>
      </div>

    </div>
    {{/applicationsMetadata}}
  </div>
  {{/if}}

</div>

<!-- ── Create application modal ── -->
<div class="app-modal-overlay" id="app-create-modal" style="display:none;">
  <div class="app-modal">
    <div class="app-modal-head">
      <div class="app-modal-head-left">
        <span class="app-modal-icon"><i class="bi bi-grid-3x3-gap-fill"></i></span>
        <h2 class="app-modal-title">Create application</h2>
      </div>
      <button type="button" class="app-modal-close" id="app-create-close" aria-label="Close">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
    <div class="app-modal-body">
      <div class="app-form-group">
        <label for="app-name-input">Application name <span class="app-required">*</span></label>
        <input type="text" id="app-name-input" class="app-form-input" placeholder="e.g. My Mobile App" maxlength="100" autocomplete="off" />
      </div>
      <div class="app-form-group">
        <label for="app-desc-input">Description</label>
        <textarea id="app-desc-input" class="app-form-input" rows="3"
          placeholder="What is this application for? (optional)"
          maxlength="256" style="resize:vertical;"></textarea>
      </div>
    </div>
    <div class="app-modal-footer">
      <button type="button" class="app-btn-secondary" id="app-create-cancel">Cancel</button>
      <button type="button" class="app-btn-primary" id="app-create-confirm" disabled>Create</button>
    </div>
  </div>
</div>

<!-- ── Delete confirmation modal ── -->
<div class="app-modal-overlay" id="app-delete-modal" style="display:none;">
  <div class="app-modal app-modal--sm">
    <div class="app-modal-head">
      <div class="app-modal-head-left">
        <span class="app-modal-icon app-modal-icon--danger"><i class="bi bi-trash"></i></span>
        <h2 class="app-modal-title">Delete application</h2>
      </div>
    </div>
    <p class="app-modal-body-text">
      Are you sure you want to delete <strong id="app-delete-name"></strong>?
      Its API keys and subscriptions will be revoked. This action can't be undone.
    </p>
    <div class="app-modal-footer">
      <button type="button" class="app-btn-secondary" id="app-delete-cancel">Cancel</button>
      <button type="button" class="app-btn-danger" id="app-delete-confirm">Delete</button>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';

  /* ── Avatar palette ──────────────────────────────── */
  var palette = [
    { bg: '#e6f2fb', fg: '#0277bd' },
    { bg: '#ece9fb', fg: '#6741d9' },
    { bg: '#fff1e6', fg: '#e65100' },
    { bg: '#e6f4ea', fg: '#2e7d32' },
    { bg: '#fce4ef', fg: '#d6336c' },
  ];

  function initials(name) {
    var x = (name || '').replace(/[^A-Za-z0-9 ]/g, '').trim()
      .split(/\s+/).map(function (w) { return w[0] || ''; }).join('');
    return (x || 'AP').slice(0, 2).toUpperCase();
  }

  /* Slugifies a display name into a handle, matching platform-api's handle convention:
     lowercase, alphanumeric + hyphens only, no leading/trailing/consecutive hyphens,
     max 40 chars. Actual uniqueness (per org) is enforced server-side. */
  function generateHandle(name) {
    var handle = (name || '')
      .toLowerCase()
      .replace(/[\s_]+/g, '-')
      .replace(/[^a-z0-9-]/g, '')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
    handle = handle.substring(0, 40).replace(/-$/, '');
    if (handle.length < 3) {
      var suffix = Math.random().toString(36).slice(2, 6);
      handle = handle ? handle + '-' + suffix : suffix;
    }
    return handle;
  }

  document.querySelectorAll('.app-avatar[data-display-name]').forEach(function (el, i) {
    var c = palette[i % palette.length];
    el.style.background = c.bg;
    el.style.color = c.fg;
    el.textContent = initials(el.getAttribute('data-display-name'));
  });

  /* ── Create modal ────────────────────────────────── */
  function openCreateModal() {
    document.getElementById('app-name-input').value = '';
    document.getElementById('app-desc-input').value = '';
    document.getElementById('app-create-confirm').disabled = true;
    document.getElementById('app-create-modal').style.display = 'flex';
    setTimeout(function () { document.getElementById('app-name-input').focus(); }, 60);
  }

  function closeCreateModal() {
    document.getElementById('app-create-modal').style.display = 'none';
  }

  var createBtn = document.getElementById('apps-create-btn');
  if (createBtn) createBtn.addEventListener('click', openCreateModal);
  var createBtnEmpty = document.getElementById('apps-create-btn-empty');
  if (createBtnEmpty) createBtnEmpty.addEventListener('click', openCreateModal);

  document.getElementById('app-create-close').addEventListener('click', closeCreateModal);
  document.getElementById('app-create-cancel').addEventListener('click', closeCreateModal);
  document.getElementById('app-create-modal').addEventListener('click', function (e) {
    if (e.target === this) closeCreateModal();
  });

  document.getElementById('app-name-input').addEventListener('input', function () {
    document.getElementById('app-create-confirm').disabled = !this.value.trim();
  });

  document.getElementById('app-create-confirm').addEventListener('click', function () {
    var name = document.getElementById('app-name-input').value.trim();
    var desc = document.getElementById('app-desc-input').value.trim();
    if (!name) return;
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Creating…';
    fetch(devportalApi.root('/applications'), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ displayName: name, description: desc, id: generateHandle(name) }),
    })
      .then(function (r) {
        if (!r.ok) return r.json().catch(function () { return {}; }).then(function (data) {
          throw new Error(data.description || data.message || ('HTTP ' + r.status));
        });
        return r.json();
      })
      .then(function () { window.location.reload(); })
      .catch(function (err) {
        btn.disabled = false;
        btn.textContent = 'Create';
        console.error('Create application failed:', err);
        if (typeof showAlert === 'function') {
          showAlert('Failed to create application: ' + (err.message || 'an application with this name may already exist'), 'error');
        }
      });
  });

  /* ── Delete modal ────────────────────────────────── */
  var pendingDeleteId = null;

  window.appShowDeleteModal = function (id, name) {
    pendingDeleteId = id;
    document.getElementById('app-delete-name').textContent = name;
    document.getElementById('app-delete-confirm').disabled = false;
    document.getElementById('app-delete-confirm').textContent = 'Delete';
    document.getElementById('app-delete-modal').style.display = 'flex';
  };

  // Wire delete buttons from data-* attributes rather than an inline onclick, so
  // a display name is never interpolated into a JS-string context (HTML-escaping
  // alone does not make it safe there — see js-output-encoding-xss.md).
  document.querySelectorAll('.app-delete-btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      window.appShowDeleteModal(btn.dataset.appId, btn.dataset.appName);
    });
  });

  document.getElementById('app-delete-cancel').addEventListener('click', function () {
    document.getElementById('app-delete-modal').style.display = 'none';
  });
  document.getElementById('app-delete-modal').addEventListener('click', function (e) {
    if (e.target === this) this.style.display = 'none';
  });

  document.getElementById('app-delete-confirm').addEventListener('click', function () {
    if (!pendingDeleteId) return;
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Deleting…';
    fetch(devportalApi.root('/applications/' + pendingDeleteId), {
      method: 'DELETE',
      credentials: 'include',
    })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        document.getElementById('app-delete-modal').style.display = 'none';
        var card = document.getElementById('app-card-' + pendingDeleteId);
        if (card) card.remove();
        if (!document.querySelector('.app-card')) {
          window.location.reload();
        }
      })
      .catch(function (err) {
        btn.disabled = false;
        btn.textContent = 'Delete';
        console.error('Delete application failed:', err);
      });
  });
}());
</script>
