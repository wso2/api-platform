<h2 class="auth-form-title">Sign in to continue</h2>
<p class="auth-form-sub">Enter your credentials to access the developer portal.</p>

{{#if loginError}}
<div class="ln-error-banner" role="alert">
  <i class="bi bi-exclamation-circle-fill"></i>
  {{loginError}}
</div>
{{/if}}

<form id="local-login-form" method="POST" data-base-url="{{baseUrl}}">
  <div class="ln-fields">

    <div class="auth-field">
      <label class="auth-field-label" for="username">Username</label>
      <div class="auth-input-wrap">
        <i class="bi bi-person auth-input-icon" aria-hidden="true"></i>
        <input
          type="text"
          id="username"
          name="username"
          class="auth-input"
          placeholder="Enter username"
          required
          autocomplete="username"
        >
      </div>
    </div>

    <div class="auth-field">
      <label class="auth-field-label" for="password">Password</label>
      <div class="auth-input-wrap">
        <i class="bi bi-lock auth-input-icon" aria-hidden="true"></i>
        <input
          type="password"
          id="password"
          name="password"
          class="auth-input ln-pw-input"
          placeholder="Enter password"
          required
          autocomplete="current-password"
        >
        <button type="button" class="ln-pw-toggle" id="ln-pw-toggle" aria-label="Toggle password visibility" tabindex="-1">
          <i class="bi bi-eye" id="ln-pw-icon"></i>
        </button>
      </div>
    </div>

    <button type="submit" class="ln-signin-btn auth-continue-btn auth-continue-btn--active">Sign in</button>

  </div>
</form>

<script>
  (function () {
    var toggle = document.getElementById('ln-pw-toggle');
    var input  = document.getElementById('password');
    var icon   = document.getElementById('ln-pw-icon');
    if (!toggle) return;
    toggle.addEventListener('click', function () {
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
    });
  })();
</script>
