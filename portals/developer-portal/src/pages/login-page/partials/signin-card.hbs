{{#if localAuthEnabled}}

<h2 class="os-form-title">Sign in to continue</h2>
<p class="os-form-sub">Enter your credentials to access the developer portal.</p>

{{#if loginError}}
<div class="ln-error-banner" role="alert">
  <i class="bi bi-exclamation-circle-fill"></i>
  {{loginError}}
</div>
{{/if}}

<form id="local-login-form" method="POST" data-base-url="{{baseUrl}}">
  <div class="ln-fields">

    <div class="os-field">
      <label class="os-field-label" for="username">Username</label>
      <div class="os-input-wrap">
        <i class="bi bi-person os-input-icon" aria-hidden="true"></i>
        <input
          type="text"
          id="username"
          name="username"
          class="os-input"
          placeholder="Enter username"
          required
          autocomplete="username"
        >
      </div>
    </div>

    <div class="os-field">
      <div class="ln-pw-label-row">
        <label class="os-field-label" for="password">Password</label>
        <a href="#" class="ln-forgot-link">Forgot password?</a>
      </div>
      <div class="os-input-wrap">
        <i class="bi bi-lock os-input-icon" aria-hidden="true"></i>
        <input
          type="password"
          id="password"
          name="password"
          class="os-input ln-pw-input"
          placeholder="Enter password"
          required
          autocomplete="current-password"
        >
        <button type="button" class="ln-pw-toggle" id="ln-pw-toggle" aria-label="Toggle password visibility" tabindex="-1">
          <i class="bi bi-eye" id="ln-pw-icon"></i>
        </button>
      </div>
    </div>

    <label class="ln-remember">
      <input type="checkbox" name="rememberMe" class="ln-remember-check">
      Keep me signed in
    </label>

    <button type="submit" class="ln-signin-btn os-continue-btn os-continue-btn--active">Sign in</button>

  </div>
</form>

<script>
  (function () {
    var toggle = document.getElementById('ln-pw-toggle');
    var input  = document.getElementById('password');
    var icon   = document.getElementById('ln-pw-icon');
    if (!toggle) return;
    toggle.addEventListener('click', function () {
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
    });
  })();
</script>

{{else}}

<h2 class="os-form-title">Sign in to continue</h2>
<p class="os-form-sub">Choose how you'd like to sign in.</p>

<div class="ln-social-list">
  <button class="ln-social-btn" id="login-google">
    <img src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/Google.svg" alt="" width="18" aria-hidden="true">
    Continue with Google
  </button>
  <button class="ln-social-btn" id="login-github">
    <img src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/Github.svg" alt="" width="18" aria-hidden="true">
    Continue with GitHub
  </button>
  <button class="ln-social-btn" id="login-microsoft">
    <img src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/Microsoft.svg" alt="" width="18" aria-hidden="true">
    Continue with Microsoft
  </button>

  <div class="ln-divider"><span>or</span></div>

  <button class="ln-social-btn" id="login-email">
    <img src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/Email.svg" alt="" width="18" aria-hidden="true">
    Sign in with Email
  </button>
  <a class="ln-social-btn ln-social-btn--outline" id="show-enterprise">
    <img src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/Enterprise.svg" alt="" width="18" aria-hidden="true">
    Sign in with Enterprise ID
  </a>
</div>

{{/if}}
