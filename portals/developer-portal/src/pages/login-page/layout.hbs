    <div class="auth-brand-body">
      <span class="auth-tenant-pill">Unified portal for APIs &amp; MCP</span>
      <h1 class="auth-headline">Discover, integrate, and ship faster.</h1>
      <p class="auth-desc">One place to explore published APIs and MCP servers, try them live, and manage your subscriptions and keys.</p>

      <div class="ln-features">
        <div class="ln-feature-item">
          <span class="ln-feature-icon"><i class="bi bi-compass"></i></span>
          <span class="ln-feature-text">Discover and explore published APIs and MCP servers</span>
        </div>
        <div class="ln-feature-item">
          <span class="ln-feature-icon"><i class="bi bi-terminal"></i></span>
          <span class="ln-feature-text">Try out APIs live with interactive consoles</span>
        </div>
        <div class="ln-feature-item">
          <span class="ln-feature-icon"><i class="bi bi-key"></i></span>
          <span class="ln-feature-text">Subscribe, then manage your access keys and tokens</span>
        </div>
      </div>
    </div>

