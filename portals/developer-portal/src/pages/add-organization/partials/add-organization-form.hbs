<section>
    <div class="container my-5">
        <div class="card-body">
            <form id="createOrg">
                <div class="form-group mb-2">
                    <label for="name" class="form-label">Name</label>
                    <input type="text" class="form-control" id="name" name="name"
                        placeholder="Enter organization name">
                </div>
                <div class="form-group mb-2">
                    <label for="business-owner" class="form-label">Business Owner</label>
                    <input type="text" class="form-control" id="businessOwner" name="businessOwner"
                        placeholder="Enter Business Owner">
                </div>
                <div class="form-group mb-2">
                    <label for="business-owner-contact" class="form-label">Business Owner Contact</label>
                    <input type="text" class="form-control" id="businessOwnerContact" name="businessOwnerContact"
                        placeholder="Enter Business Owner Contact" pattern="[0-9]{10}"
                        title="Please enter a valid 10-digit contact number">
                </div>
                <div class="form-group mb-2">
                    <label for="business-owner-email" class="form-label">Business Owner Email</label>
                    <input type="email" class="form-control" id="businessOwnerEmail" name="businessOwnerEmail"
                        placeholder="Enter Business Owner Email" title="Please enter a valid email address">
                </div>
                <div class="form-group mb-2">
                    <label for="id" class="form-label">Organization handle</label>
                    <input type="text" class="form-control" id="id" name="id"
                        placeholder="Enter Dev Portal URL Identifier" required>
                </div>
                <div class="form-group mb-2">
                    <label for="idpRefId" class="form-label">IDP Reference ID</label>
                    <input type="text" class="form-control" id="idpRefId" name="idpRefId"
                        placeholder="Enter the org claim value asserted by your Identity Provider" required>
                </div>
                <div class="form-group mb-4">
                    <label for="cpRefId" class="form-label">Control Plane Reference ID</label>
                    <input type="text" class="form-control" id="cpRefId" name="cpRefId"
                        placeholder="Optional — included in outbound webhook event payloads">
                </div>
                <div class="form-group">
                    <button type="button" class="btn btn-secondary" id="cancelAddBtn">Cancel</button>
                    <button type="button" class="common-btn-outlined" onclick="createOrg()">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</section>