                  <button type="button" class="cfg-webhook-edit-btn" data-id="{{id}}"
                    style="border:none;background:none;padding:0;cursor:pointer;font-size:.875rem;font-weight:600;color:#1a2433;text-decoration:none;">{{name}}</button>
                </td>
                <td>
                  <span class="cfg-name-chip" title="{{url}}"
                    style="display:inline-block;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{url}}</span>
                </td>
                <td>
                  {{#if events.length}}
                  {{#each events}}<span class="cfg-name-chip" style="margin-right:4px;">{{this}}</span>{{/each}}
                  {{else}}
                  <span style="font-size:.813rem;color:#637282;">All events</span>
                  {{/if}}
                </td>
                <td>{{#if hasSecret}}••••••••{{else}}—{{/if}}</td>
                <td>{{#if hasPublicKey}}Configured{{else}}—{{/if}}</td>
                <td>{{#if enabled}}Yes{{else}}No{{/if}}</td>
