{{#pageHead}}
    <link rel="stylesheet" href="/technical-styles/api-flows.css">
    <link rel="stylesheet" href="/technical-styles/settings-layout.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css" integrity="sha512-uf06llspW44/LZpHzHT6qBOIVODjWtv4MxCricRxkzvopAlSWnTf6hpZTFxuuZcuNE9CBQhqE0Seu1CoRk84nQ==" crossorigin="anonymous">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js" integrity="sha512-OeZ4Yrb/W7d2W4rAMOO0HQ9Ro/aWLtpW9BUSR2UOWnSV2hprXLkkYnnCGc9NeLUxxE4ZG7zN16UuT1Elqq8Opg==" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/yaml/yaml.min.js" integrity="sha512-Prlj899DsOyGWU8noS4ZqQ8Z4jy+215JiZPxt/cT3ds3VqbwwsjSYZ64zCWQ/Z7AUZvymKGRllUSLPW5RKylNQ==" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js" integrity="sha512-CSBhVREyzHAjAFfBlIBakjoRUKp5h7VSweP0InR/pAJyptH7peuhCsqAI/snV+TwZmXZqoUklpXp6R6wMnYf5Q==" crossorigin="anonymous"></script>
{{/pageHead}}
{{#pageScripts}}
    <script src='/technical-scripts/api-flows.js' defer></script>
{{/pageScripts}}

<!-- Hidden tab buttons kept for api-flows.js compatibility -->
<div style="display:none;" aria-hidden="true">
  <button id="llms-tab-btn"      aria-controls="llmsTabContent"     type="button"></button>
  <button id="workflows-tab-btn" aria-controls="workflowsTabContent" type="button"></button>
</div>

<!-- Server-side data for JS -->
<script type="application/json" id="cfg-org-apis-data">{{{ json orgAPIs }}}</script>
<script type="application/json" id="cfg-policies-data">{{{ json orgPolicies }}}</script>

<div class="cfg-page">

  <a href="{{baseUrl}}/" class="cfg-back-link">
    <i class="bi bi-arrow-left"></i> Home
  </a>
  <h1 class="cfg-heading">Settings</h1>

  <div class="cfg-layout">

    <!-- ── Left sub-nav ── -->
    <nav class="cfg-nav" aria-label="Settings navigation">

      <div class="cfg-nav-section">AI &amp; DISCOVERY</div>
      <div class="cfg-nav-items">
        <a href="#cfg-llm" class="cfg-nav-item" data-panel="cfg-llm">
          <i class="bi bi-stars"></i><span>LLM Instructions</span>
        </a>
        <a href="#cfg-workflows" class="cfg-nav-item" data-panel="cfg-workflows">
          <i class="bi bi-diagram-3"></i><span>API Workflows</span>
        </a>
      </div>

      <div class="cfg-nav-section">MANAGEMENT</div>
      <div class="cfg-nav-items">
        <a href="#cfg-apis" class="cfg-nav-item" data-panel="cfg-apis">
          <i class="bi bi-boxes"></i><span>APIs</span>
        </a>
        <a href="#cfg-labels" class="cfg-nav-item" data-panel="cfg-labels">
          <i class="bi bi-tags"></i><span>Labels</span>
        </a>
        <a href="#cfg-policies" class="cfg-nav-item" data-panel="cfg-policies">
          <i class="bi bi-speedometer2"></i><span>Subscription Policies</span>
        </a>
        <a href="#cfg-orgs" class="cfg-nav-item" data-panel="cfg-orgs">
          <i class="bi bi-building"></i><span>Organizations</span>
        </a>
      </div>

    </nav>

    <!-- ── Content panes ── -->
    <div class="cfg-content">

      <!-- ══ LLM Instructions ══ -->
      <div class="cfg-panel" id="cfg-llm">
        <div id="llmsTabContent">
          {{> llms-config}}
        </div>
      </div>

      <!-- ══ API Workflows ══ -->
      <div class="cfg-panel" id="cfg-workflows">
        <div id="workflowsTabContent">
          {{> api-flows}}
        </div>
      </div>

      <!-- ══ Manage APIs ══ -->
      <div class="cfg-panel" id="cfg-apis">

        <!-- API list view -->
        <div id="cfg-apis-list">
          <div class="cfg-panel-header">
            <div>
              <h2 class="cfg-panel-title">Manage APIs</h2>
              <p class="cfg-panel-desc">Add, edit, and remove the APIs visible in this developer portal.</p>
            </div>
            <button class="cfg-btn-primary" id="cfg-add-api-btn" type="button">
              <i class="bi bi-plus"></i> Add API
            </button>
          </div>

          <div class="cfg-bulk-bar" id="cfg-bulk-bar" style="display:none;" role="region" aria-label="Bulk actions">
            <span class="cfg-bulk-bar-count" id="cfg-bulk-bar-count"></span>
            <button type="button" class="cfg-btn-danger cfg-btn-sm" id="cfg-bulk-delete-btn">
              <i class="bi bi-trash"></i> Delete selected
            </button>
          </div>

          <div class="cfg-table-wrap">
            <table class="cfg-table">
              <thead>
                <tr>
                  <th class="cfg-th-check"><input type="checkbox" id="cfg-select-all" aria-label="Select all APIs"></th>
                  <th>API</th>
                  <th>Type</th>
                  <th>Version</th>
                  <th>Status</th>
                  <th style="width:52px;"></th>
                </tr>
              </thead>
              <tbody id="cfg-apis-tbody">
                {{#orgAPIs}}
                <tr id="cfg-api-row-{{apiId}}">
                  <td class="cfg-td-check">
                    <input type="checkbox" class="cfg-row-check"
                      data-id="{{apiId}}" data-name="{{apiName}}"
                      aria-label="Select {{apiName}}">
                  </td>
                  <td>
                    <div class="cfg-api-cell">
                      <span class="cfg-api-avatar
                        {{#if (eq apiType "GRAPHQL")}}cfg-api-avatar--graphql
                        {{else if (eq apiType "WS")}}cfg-api-avatar--ws
                        {{else if (eq apiType "SOAP")}}cfg-api-avatar--soap
                        {{else if (eq apiType "MCP")}}cfg-api-avatar--mcp
                        {{else if (eq apiType "WEBSUB")}}cfg-api-avatar--websub
                        {{else}}cfg-api-avatar--rest{{/if}}">{{firstTwoLetters apiName}}</span>
                      <div>
                        <div class="cfg-cell-name">{{apiName}}</div>
                        <div class="cfg-cell-context">/{{apiHandle}}</div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="cfg-type-badge
                      {{#if (eq apiType "GRAPHQL")}}cfg-type-badge--graphql
                      {{else if (eq apiType "WS")}}cfg-type-badge--ws
                      {{else if (eq apiType "SOAP")}}cfg-type-badge--soap
                      {{else if (eq apiType "MCP")}}cfg-type-badge--mcp
                      {{else if (eq apiType "WEBSUB")}}cfg-type-badge--websub
                      {{else}}cfg-type-badge--rest{{/if}}">
                      {{#if (eq apiType "WS")}}WebSocket
                      {{else if (eq apiType "GRAPHQL")}}GraphQL
                      {{else if (eq apiType "SOAP")}}SOAP
                      {{else if (eq apiType "WEBSUB")}}WebSub
                      {{else if (eq apiType "MCP")}}MCP
                      {{else}}REST{{/if}}
                    </span>
                  </td>
                  <td class="cfg-cell-version">{{apiVersion}}</td>
                  <td>
                    {{#if (eq apiStatus "PUBLISHED")}}
                    <span class="cfg-status-badge cfg-status-published">
                      <span class="cfg-status-dot"></span>Published
                    </span>
                    {{else if (eq apiStatus "DEPRECATED")}}
                    <span class="cfg-status-badge cfg-status-deprecated">
                      <span class="cfg-status-dot"></span>Deprecated
                    </span>
                    {{else}}
                    <span class="cfg-status-badge cfg-status-draft">
                      <span class="cfg-status-dot"></span>Draft
                    </span>
                    {{/if}}
                  </td>
                  <td class="cfg-cell-actions">
                    <button class="cfg-action-btn cfg-menu-trigger" type="button" aria-label="API actions">
                      <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <div class="cfg-dropdown">
                      <button class="cfg-dropdown-item cfg-edit-trigger" type="button" data-id="{{apiId}}">
                        <i class="bi bi-pencil"></i> Edit
                      </button>
                      {{#if (eq apiStatus "PUBLISHED")}}
                      <button class="cfg-dropdown-item cfg-unpublish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                        <i class="bi bi-archive"></i> Deprecate
                      </button>
                      {{else}}
                      <button class="cfg-dropdown-item cfg-publish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                        <i class="bi bi-cloud-upload"></i> Publish
                      </button>
                      {{/if}}
                      <div class="cfg-dropdown-divider"></div>
                      <button class="cfg-dropdown-item cfg-dropdown-item--danger cfg-delete-trigger" type="button"
                        data-id="{{apiId}}" data-name="{{apiName}}">
                        <i class="bi bi-trash"></i> Delete
                      </button>
                    </div>
                  </td>
                </tr>
                {{/orgAPIs}}
                {{#unless orgAPIs.length}}
                <tr><td colspan="6" class="cfg-empty-row">No APIs found. Click <strong>Add API</strong> to get started.</td></tr>
                {{/unless}}
              </tbody>
            </table>
          </div>
        </div>

        <!-- API wizard -->
        <div id="cfg-apis-wizard" style="display:none;">
          <a href="#" class="cfg-wizard-back" id="cfg-wizard-back-link">
            <i class="bi bi-arrow-left"></i> Back to Manage APIs
          </a>
          <h2 class="cfg-panel-title" id="cfg-wizard-title" style="margin:14px 0 0;">Add API</h2>

          <!-- Stepper -->
          <div class="cfg-stepper">
            <div class="cfg-step cfg-step--active" data-step="0">
              <span class="cfg-step-circle">1</span><span class="cfg-step-label">Details</span>
            </div>
            <div class="cfg-step-connector"></div>
            <div class="cfg-step" data-step="1">
              <span class="cfg-step-circle">2</span><span class="cfg-step-label">Spec</span>
            </div>
            <div class="cfg-step-connector"></div>
            <div class="cfg-step" data-step="2">
              <span class="cfg-step-circle">3</span><span class="cfg-step-label">Documentation</span>
            </div>
            <div class="cfg-step-connector"></div>
            <div class="cfg-step" data-step="3">
              <span class="cfg-step-circle">4</span><span class="cfg-step-label">Review</span>
            </div>
          </div>

          <!-- Step 0: Details -->
          <div class="cfg-wizard-step" id="cfg-wstep-0" style="max-width:720px;">
            <!-- GENERAL -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">General</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group">
                  <label for="wz-name">API name <span class="required">*</span></label>
                  <input type="text" id="wz-name" class="cfg-form-input" placeholder="e.g. Booking API" />
                  <p id="wz-name-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-version">Version <span class="required">*</span></label>
                  <input type="text" id="wz-version" class="cfg-form-input" placeholder="e.g. v1.0" />
                  <p id="wz-version-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-handle">Handle (URL slug) <span class="required">*</span></label>
                  <input type="text" id="wz-handle" class="cfg-form-input cfg-form-input--mono" placeholder="booking-api-v1.0" />
                  <p class="cfg-field-hint">Auto-generated from name &amp; version. Edit to override.</p>
                  <p id="wz-handle-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-type">API type</label>
                  <select id="wz-type" class="cfg-form-input">
                    <option value="REST">REST</option>
                    <option value="WS">WebSocket</option>
                    <option value="GRAPHQL">GraphQL</option>
                    <option value="SOAP">SOAP</option>
                    <option value="WEBSUB">WebSub</option>
                    <option value="MCP">MCP</option>
                  </select>
                </div>
                <div class="cfg-form-group cfg-form-group-full">
                  <label for="wz-desc">Description <span class="required">*</span></label>
                  <textarea id="wz-desc" class="cfg-form-input" rows="3" placeholder="Describe what this API does in 1–2 sentences…"></textarea>
                  <p id="wz-desc-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
              </div>
            </div>

            <!-- ENDPOINTS -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Endpoints</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group">
                  <label for="wz-prod">Production URL</label>
                  <input type="text" id="wz-prod" class="cfg-form-input cfg-form-input--mono" placeholder="https://api.example.com/booking" />
                </div>
                <div class="cfg-form-group">
                  <label for="wz-sandbox">Sandbox URL</label>
                  <input type="text" id="wz-sandbox" class="cfg-form-input cfg-form-input--mono" placeholder="https://sandbox.example.com/booking" />
                </div>
              </div>
            </div>

            <!-- LABELS & VISIBILITY -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Labels &amp; Visibility</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group cfg-form-group-full">
                  <label for="wz-tags">Labels</label>
                  <input type="text" id="wz-tags" class="cfg-form-input" placeholder="booking, travel  (comma separated)" />
                </div>
                <div class="cfg-form-group">
                  <label for="wz-status">Status</label>
                  <select id="wz-status" class="cfg-form-input">
                    <option value="PUBLISHED">Published</option>
                    <option value="DEPRECATED">Deprecated</option>
                  </select>
                </div>
                <div class="cfg-form-group">
                  <label>Agent visibility</label>
                  <div class="cfg-vis-toggle">
                    <button type="button" class="cfg-vis-btn active" id="wz-vis-visible" data-val="Visible">
                      <i class="bi bi-eye"></i> Visible
                    </button>
                    <button type="button" class="cfg-vis-btn" id="wz-vis-hidden" data-val="Hidden">
                      <i class="bi bi-eye-slash"></i> Hidden
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- OWNERSHIP -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Ownership</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group">
                  <label for="wz-tech-owner">Technical owner</label>
                  <input type="text" id="wz-tech-owner" class="cfg-form-input" placeholder="e.g. John Doe" />
                </div>
                <div class="cfg-form-group">
                  <label for="wz-tech-email">Technical owner email</label>
                  <input type="text" id="wz-tech-email" class="cfg-form-input cfg-form-input--mono" placeholder="john.doe@example.com" />
                  <p id="wz-tech-email-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-biz-owner">Business owner</label>
                  <input type="text" id="wz-biz-owner" class="cfg-form-input" placeholder="e.g. Jane Doe" />
                </div>
                <div class="cfg-form-group">
                  <label for="wz-biz-email">Business owner email</label>
                  <input type="text" id="wz-biz-email" class="cfg-form-input cfg-form-input--mono" placeholder="jane.doe@example.com" />
                  <p id="wz-biz-email-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
              </div>
            </div>

            <!-- SUBSCRIPTION POLICIES -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Applicable Subscription Policies</p>
              <div class="cfg-form-group cfg-form-group-full" style="position:relative;">
                <label>Subscription plans</label>
                <div class="cfg-chip-input-wrap" id="wz-policy-chip-wrap">
                  <div id="wz-policy-chips" style="display:contents;"></div>
                  <input type="text" class="cfg-chip-text-input" id="wz-policy-search"
                    placeholder="{{#if orgPolicies.length}}Type to search plans…{{else}}No plans available{{/if}}"
                    autocomplete="off" {{#unless orgPolicies.length}}disabled{{/unless}} />
                </div>
                <div class="cfg-chip-dropdown" id="wz-policy-dropdown"></div>
                {{#unless orgPolicies.length}}
                <p style="font-size:.844rem;color:#9aa3af;margin:6px 0 0;">No subscription policies yet. Create them under <strong>Subscription Policies</strong>.</p>
                {{/unless}}
              </div>
            </div>
          </div>

          <!-- Step 1: Spec -->
          <div class="cfg-wizard-step" id="cfg-wstep-1" style="display:none;">
            <p class="cfg-wstep-desc">Upload the contract that defines this API. <span class="required">*</span> Required. Accepted: OpenAPI (.json / .yaml), AsyncAPI, GraphQL SDL (.graphql), or WSDL (.wsdl / .xml).</p>
            <label class="cfg-upload-zone" id="wz-spec-zone">
              <span class="cfg-upload-icon"><i class="bi bi-file-earmark-arrow-up"></i></span>
              <span class="cfg-upload-label">Drag &amp; drop or <span>browse</span> to upload</span>
              <span class="cfg-upload-hint">Single spec file · up to 10 MB</span>
              <input type="file" id="wz-spec-input" accept=".json,.yaml,.yml,.graphql,.gql,.wsdl,.xml" />
            </label>
            <p id="wz-spec-error" style="display:none;color:#c62828;font-size:.813rem;margin:8px 0 0;">A spec file is required to continue.</p>
            <div id="wz-spec-onfile" style="display:none;" class="cfg-spec-onfile">
              <i class="bi bi-check-circle-fill"></i>
              <span>Existing spec on file — attach a new file above to replace it</span>
            </div>
            <div class="cfg-spec-chip" id="wz-spec-chip">
              <span class="cfg-spec-icon"><i class="bi bi-file-check"></i></span>
              <div>
                <div class="cfg-spec-name" id="wz-spec-name"></div>
                <div class="cfg-spec-sub">Spec uploaded</div>
              </div>
              <button type="button" class="cfg-action-btn" id="wz-spec-remove" style="margin-left:auto;">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
          </div>

          <!-- Step 2: Documentation -->
          <div class="cfg-wizard-step" id="cfg-wstep-2" style="display:none;">
            <p class="cfg-wstep-desc">Add guides or references to help developers use this API. You can upload multiple Markdown files (.md).</p>
            <label class="cfg-upload-compact" id="wz-docs-zone">
              <i class="bi bi-upload" style="color:#0277bd;font-size:1rem;flex:none;"></i>
              <span style="font-size:.844rem;font-weight:600;color:#1a2433;">Drag &amp; drop or <span style="color:#1f6feb;">browse</span> to upload <span style="color:#9aa3af;font-weight:400;">— .md · multiple</span></span>
              <input type="file" id="wz-docs-input" multiple accept=".md,.markdown" />
            </label>
            <div id="wz-existing-docs-list" class="cfg-docs-list"></div>
            <div id="wz-docs-empty" class="cfg-docs-empty">No documents added yet.</div>
            <div id="wz-docs-list" class="cfg-docs-list"></div>
          </div>

          <!-- Step 3: Review -->
          <div class="cfg-wizard-step" id="cfg-wstep-3" style="display:none; max-width:720px;">
            <p class="cfg-wstep-desc">Confirm the details below, then save this API to your developer portal.</p>
            <div class="cfg-review-section">
              <div class="cfg-review-header">
                <span class="cfg-review-header-title">API Details</span>
                <button type="button" class="cfg-review-edit" data-goto="0">Edit</button>
              </div>
              <div class="cfg-review-body">
                <div class="cfg-review-grid">
                  <span class="cfg-review-label">Name</span>         <span class="cfg-review-value" id="rv-name">—</span>
                  <span class="cfg-review-label">Handle</span>        <span class="cfg-review-value cfg-review-value--mono" id="rv-handle">—</span>
                  <span class="cfg-review-label">Version</span>       <span class="cfg-review-value" id="rv-version">—</span>
                  <span class="cfg-review-label">Type</span>          <span class="cfg-review-value" id="rv-type">—</span>
                  <span class="cfg-review-label">Status</span>        <span class="cfg-review-value" id="rv-status">—</span>
                  <span class="cfg-review-label">Agent visibility</span><span class="cfg-review-value" id="rv-agentvis">—</span>
                  <span class="cfg-review-label">Production URL</span><span class="cfg-review-value cfg-review-value--mono" id="rv-prod">—</span>
                  <span class="cfg-review-label">Sandbox URL</span>   <span class="cfg-review-value cfg-review-value--mono" id="rv-sandbox">—</span>
                  <span class="cfg-review-label">Tech owner</span>    <span class="cfg-review-value" id="rv-tech-owner">—</span>
                  <span class="cfg-review-label">Biz owner</span>     <span class="cfg-review-value" id="rv-biz-owner">—</span>
                  <span class="cfg-review-label">Policies</span>      <span class="cfg-review-value" id="rv-policies">—</span>
                  <span class="cfg-review-label">Description</span>   <span class="cfg-review-value" id="rv-desc">—</span>
                </div>
              </div>
              <div class="cfg-review-header" style="border-top:1px solid #eef1f5;">
                <span class="cfg-review-header-title">Spec</span>
                <button type="button" class="cfg-review-edit" data-goto="1">Edit</button>
              </div>
              <div class="cfg-review-body" style="padding:14px 18px;">
                <span style="font-size:.844rem;color:#1a2433;" id="rv-spec">No spec uploaded</span>
              </div>
              <div class="cfg-review-header" style="border-top:1px solid #eef1f5;">
                <span class="cfg-review-header-title">Documentation</span>
                <button type="button" class="cfg-review-edit" data-goto="2">Edit</button>
              </div>
              <div class="cfg-review-body" style="padding:14px 18px;">
                <span style="font-size:.844rem;color:#1a2433;" id="rv-docs">No documents added</span>
              </div>
            </div>
          </div>

          <!-- Wizard actions -->
          <div class="cfg-wizard-actions">
            <button type="button" class="cfg-btn-ghost" id="cfg-wizard-cancel">Cancel</button>
            <div class="cfg-wizard-actions-right">
              <button type="button" class="cfg-btn-secondary" id="cfg-wizard-back-step" style="display:none;">
                <i class="bi bi-arrow-left"></i> Back
              </button>
              <button type="button" class="cfg-btn-primary" id="cfg-wizard-next">Continue</button>
            </div>
          </div>
        </div>

      </div><!-- /#cfg-apis -->

      <!-- ══ Manage Labels ══ -->
      <div class="cfg-panel" id="cfg-labels">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Manage Labels</h2>
            <p class="cfg-panel-desc">Labels help categorize and group APIs across the developer portal.</p>
          </div>
          <button class="cfg-btn-primary" id="cfg-add-label-btn" type="button">
            <i class="bi bi-plus"></i> Add label
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th>Display name</th>
                <th>Name</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-labels-tbody">
              {{#orgLabels}}
              <tr id="cfg-label-row-{{labelId}}" data-id="{{labelId}}" data-name="{{name}}" data-display="{{displayName}}">
                <td>
                  <div style="display:flex;align-items:center;gap:10px;">
                    <span class="cfg-label-icon"><i class="bi bi-tag"></i></span>
                    <span style="font-size:.875rem;font-weight:600;color:#1a2433;">{{displayName}}</span>
                  </div>
                </td>
                <td><span class="cfg-name-chip">{{name}}</span></td>
                <td>
                  <div class="cfg-row-actions">
                    <button class="cfg-icon-btn cfg-label-edit-btn" type="button" data-id="{{labelId}}" data-name="{{name}}" data-display="{{displayName}}" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="cfg-icon-btn cfg-icon-btn--danger cfg-label-delete-btn" type="button" data-id="{{labelId}}" data-name="{{name}}" data-display="{{displayName}}" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              {{/orgLabels}}
              {{#unless orgLabels.length}}
              <tr><td colspan="3" class="cfg-tbl-empty">No labels yet. Add one to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-labels -->

      <!-- ══ Subscription Policies ══ -->
      <div class="cfg-panel" id="cfg-policies">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Subscription Policies</h2>
            <p class="cfg-panel-desc">Define the rate and quota tiers applications can subscribe to.</p>
          </div>
          <button class="cfg-btn-primary" id="cfg-add-policy-btn" type="button">
            <i class="bi bi-plus"></i> Add policy
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th>Policy</th>
                <th>Name</th>
                <th>Type</th>
                <th>Limit</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-policies-tbody">
              {{#orgPolicies}}
              <tr id="cfg-policy-row-{{policyId}}"
                data-id="{{policyId}}"
                data-name="{{policyName}}"
                data-display="{{displayName}}"
                data-desc="{{description}}"
                data-count="{{requestCount}}"
                data-refid="{{refId}}">
                <td>
                  <div style="font-size:.875rem;font-weight:600;color:#1a2433;">{{displayName}}</div>
                  {{#if description}}<div style="font-size:.75rem;color:#637282;margin-top:2px;">{{description}}</div>{{/if}}
                </td>
                <td><span class="cfg-name-chip">{{policyName}}</span></td>
                <td>
                  {{#if refId}}
                  <span class="cfg-policy-type-badge cfg-policy-type--event">Event count</span>
                  {{else}}
                  <span class="cfg-policy-type-badge cfg-policy-type--request">Request count</span>
                  {{/if}}
                </td>
                <td><span class="cfg-count-chip">{{requestCount}}</span></td>
                <td>
                  <div class="cfg-row-actions">
                    <button class="cfg-icon-btn cfg-policy-edit-btn" type="button"
                      data-id="{{policyId}}" data-name="{{policyName}}" data-display="{{displayName}}"
                      data-desc="{{description}}" data-count="{{requestCount}}" data-refid="{{refId}}" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="cfg-icon-btn cfg-icon-btn--danger cfg-policy-delete-btn" type="button"
                      data-id="{{policyId}}" data-name="{{policyName}}" data-display="{{displayName}}" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              {{/orgPolicies}}
              {{#unless orgPolicies.length}}
              <tr><td colspan="5" class="cfg-tbl-empty">No subscription policies yet. Add one to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-policies -->

      <!-- ══ Manage Organizations ══ -->
      <div class="cfg-panel" id="cfg-orgs">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Manage Organizations</h2>
            <p class="cfg-panel-desc">Organizations group members and their access to this developer portal.</p>
