        <div class="cfg-orgs-link-panel">
          <div class="cfg-orgs-link-icon"><i class="bi bi-building"></i></div>
          <div class="cfg-orgs-link-body">
            <div class="cfg-orgs-link-title">Organization settings</div>
            <p class="cfg-orgs-link-desc">Manage organizations, views, labels, and API providers from the organization settings page.</p>
            <a href="/{{loggedOrg}}/configure" class="cfg-btn-primary cfg-orgs-link-btn">
              <i class="bi bi-box-arrow-up-right"></i> Open Organization Settings
            </a>
          </div>
        </div>
      </div>

    </div><!-- /.cfg-content -->
  </div><!-- /.cfg-layout -->
</div><!-- /.cfg-page -->

