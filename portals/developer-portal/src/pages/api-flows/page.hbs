          <table class="cfg-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Target URL</th>
                <th>Events</th>
                <th>Secret</th>
                <th>Public key</th>
                <th>Enabled</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-webhooks-tbody">
              {{#webhookSubscribers}}
              <tr id="cfg-webhook-row-{{id}}" data-id="{{id}}">
