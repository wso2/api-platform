{{#pageHead}}
<link rel="stylesheet" href="/technical-styles/settings.css">
{{/pageHead}}
{{#pageScripts}}
<script src='/technical-scripts/delete-confirmation-modal.js' defer></script>
<script src='/technical-scripts/warning.js' defer></script>
<script src='/technical-scripts/create-org.js' defer></script>
<script src='/technical-scripts/configure-org.js' defer></script>
{{/pageScripts}}

<div class="container mt-5 mb-4">
    <!-- Nav tabs -->
    <ul class="nav nav-underline" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <a class="nav-link active" data-bs-toggle="tab" href="#organizations" role="tab">Organizations</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" data-bs-toggle="tab" href="#views" role="tab">Views</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" data-bs-toggle="tab" href="#labels" role="tab">Labels</a>
        </li>
    </ul>
    <!-- Tab content -->
    <div class="tab-content mt-4" id="myTabContent">
        <div class="tab-pane fade show active" id="organizations" role="tabpanel" aria-labelledby="org-tab">
            {{> organization}}
        </div>
        <div class="tab-pane fade" id="views" role="tabpanel" aria-labelledby="view-tab">
            {{> view-details }}
        </div>
        <div class="tab-pane fade" id="labels" role="tabpanel" aria-labelledby="label-tab">
            {{> labels}}
        </div>
    </div>
</div>
{{> warning modalTitle="Confirm" modalMessage="" modalFunction="" }}
{{> alert}}
