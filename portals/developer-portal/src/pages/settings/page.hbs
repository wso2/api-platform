{{#pageHead}}
    <link rel="stylesheet" href="/technical-styles/manage-api-workflows.css">
    <link rel="stylesheet" href="/technical-styles/settings-layout.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css" integrity="sha512-uf06llspW44/LZpHzHT6qBOIVODjWtv4MxCricRxkzvopAlSWnTf6hpZTFxuuZcuNE9CBQhqE0Seu1CoRk84nQ==" crossorigin="anonymous">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js" integrity="sha512-OeZ4Yrb/W7d2W4rAMOO0HQ9Ro/aWLtpW9BUSR2UOWnSV2hprXLkkYnnCGc9NeLUxxE4ZG7zN16UuT1Elqq8Opg==" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/yaml/yaml.min.js" integrity="sha512-Prlj899DsOyGWU8noS4ZqQ8Z4jy+215JiZPxt/cT3ds3VqbwwsjSYZ64zCWQ/Z7AUZvymKGRllUSLPW5RKylNQ==" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js" integrity="sha512-CSBhVREyzHAjAFfBlIBakjoRUKp5h7VSweP0InR/pAJyptH7peuhCsqAI/snV+TwZmXZqoUklpXp6R6wMnYf5Q==" crossorigin="anonymous"></script>
{{/pageHead}}
{{#pageScripts}}
    <script src='/technical-scripts/manage-api-workflows.js' defer></script>
{{/pageScripts}}

<!-- Server-side data for JS -->
<script type="application/json" id="cfg-org-apis-data">{{{ json orgAllAPIs }}}</script>
<script type="application/json" id="cfg-plans-data">{{{ json orgPlans }}}</script>
<script type="application/json" id="cfg-webhooks-data">{{{ json webhookSubscribers }}}</script>
<script type="application/json" id="cfg-keymanagers-data">{{{ json keyManagers }}}</script>
<script type="application/json" id="cfg-views-data">{{{ json views }}}</script>
<script type="application/json" id="cfg-orglabels-data">{{{ json orgLabels }}}</script>

<div class="cfg-page">

  <a href="{{baseUrl}}/" class="cfg-back-link">
    <i class="bi bi-arrow-left"></i> Home
  </a>
  <h1 class="cfg-heading">Settings</h1>

  <div class="cfg-layout">

    <!-- ── Left sub-nav ── -->
    <nav class="cfg-nav" aria-label="Settings navigation">

      <div class="cfg-nav-section">ORGANIZATION</div>
      <div class="cfg-nav-items">
        <a href="#cfg-organizations" class="cfg-nav-item" data-panel="cfg-organizations">
          <i class="bi bi-building"></i><span>Organization</span>
        </a>
        <a href="#cfg-views" class="cfg-nav-item" data-panel="cfg-views">
          <i class="bi bi-layout-text-window"></i><span>Views</span>
        </a>
        <a href="#cfg-labels" class="cfg-nav-item" data-panel="cfg-labels">
          <i class="bi bi-tags"></i><span>Labels</span>
        </a>
        <a href="#cfg-plans" class="cfg-nav-item" data-panel="cfg-plans">
          <i class="bi bi-speedometer2"></i><span>Subscription Plans</span>
        </a>
        <a href="#cfg-keymanagers" class="cfg-nav-item" data-panel="cfg-keymanagers">
          <i class="bi bi-key"></i><span>Key Managers</span>
        </a>
      </div>

      <div class="cfg-nav-section">CONTENT</div>
      <div class="cfg-nav-items">
        <a href="#cfg-apis" class="cfg-nav-item" data-panel="cfg-apis">
          <i class="bi bi-boxes"></i><span>APIs</span>
        </a>
        <a href="#cfg-mcps" class="cfg-nav-item" data-panel="cfg-mcps">
          <i class="bi bi-hdd-network"></i><span>MCP Servers</span>
        </a>
      </div>

      <div class="cfg-nav-section">INTEGRATIONS</div>
      <div class="cfg-nav-items">
        <a href="#cfg-webhooks" class="cfg-nav-item" data-panel="cfg-webhooks">
          <i class="bi bi-broadcast"></i><span>Webhooks</span>
        </a>
      </div>

      <div class="cfg-nav-section">AI &amp; DISCOVERY</div>
      <div class="cfg-nav-items">
        <a href="#cfg-llm" class="cfg-nav-item" data-panel="cfg-llm">
          <i class="bi bi-stars"></i><span>LLM Instructions</span>
        </a>
        <a href="#cfg-workflows" class="cfg-nav-item" data-panel="cfg-workflows">
          <i class="bi bi-diagram-3"></i><span>API Workflows</span>
        </a>
      </div>

      <div class="cfg-nav-section">APPEARANCE</div>
      <div class="cfg-nav-items">
        <a href="#cfg-theming" class="cfg-nav-item" data-panel="cfg-theming">
          <i class="bi bi-palette"></i><span>Theming</span>
        </a>
      </div>

    </nav>

    <!-- ── Content panes ── -->
    <div class="cfg-content">

      <!-- ══ LLM Instructions ══ -->
      <div class="cfg-panel" id="cfg-llm">
        <div id="llmsTabContent">
          {{> llms-config}}
        </div>
      </div>

      <!-- ══ API Workflows ══ -->
      <div class="cfg-panel" id="cfg-workflows">
        <div id="workflowsTabContent">
          {{> api-workflows}}
        </div>
      </div>

      <!-- ══ Theming ══ -->
      <div class="cfg-panel" id="cfg-theming">
        <div id="themingTabContent">
          {{> theming}}
        </div>
      </div>

      <!-- ══ Manage APIs ══ -->
      <div class="cfg-panel" id="cfg-apis">

        <!-- API list view -->
        <div id="cfg-apis-list">
          <div class="cfg-panel-header">
            <div>
              <h2 class="cfg-panel-title">Manage APIs</h2>
              <p class="cfg-panel-desc">Add, edit, and remove the APIs visible in this developer portal.</p>
            </div>
            <div style="display:flex; gap:10px;">
              {{#if demoMode}}
              <button class="cfg-btn-secondary" id="cfg-seed-samples-btn" type="button">
                <i class="bi bi-box-seam"></i> Import Sample APIs
              </button>
              {{/if}}
              <button class="cfg-btn-primary" id="cfg-add-api-btn" type="button">
                <i class="bi bi-plus"></i> Add API
              </button>
            </div>
          </div>

          <div class="cfg-bulk-bar" id="cfg-bulk-bar" style="display:none;" role="region" aria-label="Bulk actions">
            <span class="cfg-bulk-bar-count" id="cfg-bulk-bar-count"></span>
            <button type="button" class="cfg-btn-danger cfg-btn-sm" id="cfg-bulk-delete-btn">
              <i class="bi bi-trash"></i> Delete selected
            </button>
          </div>

          <div class="cfg-table-wrap">
            <table class="cfg-table">
              <thead>
                <tr>
                  <th class="cfg-th-check"><input type="checkbox" id="cfg-select-all" aria-label="Select all APIs"></th>
                  <th>API</th>
                  <th>Type</th>
                  <th>Version</th>
                  <th>Status</th>
                  <th style="width:52px;"></th>
                </tr>
              </thead>
              <tbody id="cfg-apis-tbody">
                {{#orgAPIs}}
                <tr id="cfg-api-row-{{apiId}}">
                  <td class="cfg-td-check">
                    <input type="checkbox" class="cfg-row-check"
                      data-id="{{apiId}}" data-name="{{apiName}}"
                      aria-label="Select {{apiName}}">
                  </td>
                  <td>
                    <div class="cfg-api-cell">
                      <span class="cfg-api-avatar
                        {{#if (eq apiType "GRAPHQL")}}cfg-api-avatar--graphql
                        {{else if (eq apiType "WS")}}cfg-api-avatar--ws
                        {{else if (eq apiType "SOAP")}}cfg-api-avatar--soap
                        {{else if (eq apiType "Mcp")}}cfg-api-avatar--mcp
                        {{else if (eq apiType "WebSubApi")}}cfg-api-avatar--websub
                        {{else}}cfg-api-avatar--rest{{/if}}">{{firstTwoLetters apiName}}</span>
                      <div>
                        <div class="cfg-cell-name">{{apiName}}</div>
                        <div class="cfg-cell-context">/{{apiHandle}}</div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="cfg-type-badge
                      {{#if (eq apiType "GRAPHQL")}}cfg-type-badge--graphql
                      {{else if (eq apiType "WS")}}cfg-type-badge--ws
                      {{else if (eq apiType "SOAP")}}cfg-type-badge--soap
                      {{else if (eq apiType "Mcp")}}cfg-type-badge--mcp
                      {{else if (eq apiType "WebSubApi")}}cfg-type-badge--websub
                      {{else}}cfg-type-badge--rest{{/if}}">
                      {{#if (eq apiType "WS")}}WebSocket
                      {{else if (eq apiType "GRAPHQL")}}GraphQL
                      {{else if (eq apiType "SOAP")}}SOAP
                      {{else if (eq apiType "WebSubApi")}}WebSub
                      {{else if (eq apiType "Mcp")}}MCP
                      {{else}}REST{{/if}}
                    </span>
                  </td>
                  <td class="cfg-cell-version">{{apiVersion}}</td>
                  <td>
                    {{#if (eq apiStatus "PUBLISHED")}}
                    <span class="cfg-status-badge cfg-status-published">
                      <span class="cfg-status-dot"></span>Published
                    </span>
                    {{else if (eq apiStatus "DEPRECATED")}}
                    <span class="cfg-status-badge cfg-status-deprecated">
                      <span class="cfg-status-dot"></span>Deprecated
                    </span>
                    {{else}}
                    <span class="cfg-status-badge cfg-status-draft">
                      <span class="cfg-status-dot"></span>Draft
                    </span>
                    {{/if}}
                  </td>
                  <td class="cfg-cell-actions">
                    <button class="cfg-action-btn cfg-menu-trigger" type="button" aria-label="API actions">
                      <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <div class="cfg-dropdown">
                      <button class="cfg-dropdown-item cfg-edit-trigger" type="button" data-id="{{apiId}}">
                        <i class="bi bi-pencil"></i> Edit
                      </button>
                      {{#if (eq apiStatus "PUBLISHED")}}
                      <button class="cfg-dropdown-item cfg-unpublish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                        <i class="bi bi-archive"></i> Deprecate
                      </button>
                      {{else}}
                      <button class="cfg-dropdown-item cfg-publish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                        <i class="bi bi-cloud-upload"></i> Publish
                      </button>
                      {{/if}}
                      <div class="cfg-dropdown-divider"></div>
                      <button class="cfg-dropdown-item cfg-dropdown-item--danger cfg-delete-trigger" type="button"
                        data-id="{{apiId}}" data-name="{{apiName}}">
                        <i class="bi bi-trash"></i> Delete
                      </button>
                    </div>
                  </td>
                </tr>
                {{/orgAPIs}}
                {{#unless orgAPIs.length}}
                <tr><td colspan="6" class="cfg-empty-row">No APIs found. Click <strong>Add API</strong> to get started.</td></tr>
                {{/unless}}
              </tbody>
            </table>
          </div>
        </div>

        <!-- API wizard -->
        <div id="cfg-apis-wizard" style="display:none;">
          <a href="#" class="cfg-wizard-back" id="cfg-wizard-back-link">
            <i class="bi bi-arrow-left"></i> Back to Manage APIs
          </a>
          <h2 class="cfg-panel-title" id="cfg-wizard-title" style="margin:14px 0 0;">Add API</h2>

          <!-- Stepper -->
          <div class="cfg-stepper">
            <div class="cfg-step cfg-step--active" data-step="0">
              <span class="cfg-step-circle">1</span><span class="cfg-step-label">Details</span>
            </div>
            <div class="cfg-step-connector"></div>
            <div class="cfg-step" data-step="1">
              <span class="cfg-step-circle">2</span><span class="cfg-step-label">Spec</span>
            </div>
            <div class="cfg-step-connector"></div>
            <div class="cfg-step" data-step="2">
              <span class="cfg-step-circle">3</span><span class="cfg-step-label">Documentation</span>
            </div>
            <div class="cfg-step-connector" id="cfg-step-connector-content" style="display:none;"></div>
            <div class="cfg-step" data-step="3" id="cfg-step-content" style="display:none;">
              <span class="cfg-step-circle">4</span><span class="cfg-step-label">Content</span>
            </div>
          </div>

          <!-- Step 0: Details -->
          <div class="cfg-wizard-step" id="cfg-wstep-0" style="max-width:720px;">
            <!-- GENERAL -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">General</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group">
                  <label for="wz-name">API name <span class="required">*</span></label>
                  <input type="text" id="wz-name" class="cfg-form-input" placeholder="e.g. Booking API" />
                  <p id="wz-name-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-version">Version <span class="required">*</span></label>
                  <input type="text" id="wz-version" class="cfg-form-input" placeholder="e.g. v1.0" />
                  <p id="wz-version-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-handle">Handle (URL slug) <span class="required">*</span></label>
                  <input type="text" id="wz-handle" class="cfg-form-input cfg-form-input--mono" placeholder="booking-api-v1.0" />
                  <p class="cfg-field-hint">Auto-generated from name &amp; version. Edit to override.</p>
                  <p id="wz-handle-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-type">API type</label>
                  <select id="wz-type" class="cfg-form-input">
                    <option value="RestApi">REST</option>
                    <option value="WS">WebSocket</option>
                    <option value="GRAPHQL">GraphQL</option>
                    <option value="WebSubApi">WebSub</option>
                    <option value="Mcp">MCP</option>
                  </select>
                </div>
                <div class="cfg-form-group">
                  <label>Agent visibility</label>
                  <div class="cfg-vis-toggle">
                    <button type="button" class="cfg-vis-btn active" id="wz-vis-visible" data-val="Visible">
                      <i class="bi bi-eye"></i> Visible
                    </button>
                    <button type="button" class="cfg-vis-btn" id="wz-vis-hidden" data-val="Hidden">
                      <i class="bi bi-eye-slash"></i> Hidden
                    </button>
                  </div>
                </div>
                <div class="cfg-form-group cfg-form-group-full">
                  <label for="wz-desc">Description <span class="required">*</span></label>
                  <textarea id="wz-desc" class="cfg-form-input" rows="3" placeholder="Describe what this API does in 1–2 sentences…"></textarea>
                  <p id="wz-desc-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
              </div>
            </div>

            <!-- ENDPOINTS -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Endpoints</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group">
                  <label for="wz-prod">Production URL <span class="required" id="wz-prod-required" style="display:none;">*</span></label>
                  <input type="text" id="wz-prod" class="cfg-form-input cfg-form-input--mono" placeholder="https://api.example.com/booking" />
                  <p id="wz-prod-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-sandbox">Sandbox URL</label>
                  <input type="text" id="wz-sandbox" class="cfg-form-input cfg-form-input--mono" placeholder="https://sandbox.example.com/booking" />
                </div>
              </div>
            </div>

            <!-- LABELS & VISIBILITY -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Labels &amp; Visibility</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group cfg-form-group-full">
                  <label for="wz-tags">Labels</label>
                  <input type="text" id="wz-tags" class="cfg-form-input" placeholder="booking, travel  (comma separated)" />
                </div>
                <div class="cfg-form-group">
                  <label for="wz-status">Status</label>
                  <select id="wz-status" class="cfg-form-input">
                    <option value="PUBLISHED">Published</option>
                    <option value="DEPRECATED">Deprecated</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- OWNERSHIP -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Ownership</p>
              <div class="cfg-form-grid">
                <div class="cfg-form-group">
                  <label for="wz-tech-owner">Technical owner</label>
                  <input type="text" id="wz-tech-owner" class="cfg-form-input" placeholder="e.g. John Doe" />
                </div>
                <div class="cfg-form-group">
                  <label for="wz-tech-email">Technical owner email</label>
                  <input type="text" id="wz-tech-email" class="cfg-form-input cfg-form-input--mono" placeholder="john.doe@example.com" />
                  <p id="wz-tech-email-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
                <div class="cfg-form-group">
                  <label for="wz-biz-owner">Business owner</label>
                  <input type="text" id="wz-biz-owner" class="cfg-form-input" placeholder="e.g. Jane Doe" />
                </div>
                <div class="cfg-form-group">
                  <label for="wz-biz-email">Business owner email</label>
                  <input type="text" id="wz-biz-email" class="cfg-form-input cfg-form-input--mono" placeholder="jane.doe@example.com" />
                  <p id="wz-biz-email-error" style="display:none;color:#c62828;font-size:.75rem;margin:3px 0 0;"></p>
                </div>
              </div>
            </div>

            <!-- SUBSCRIPTION PLANS -->
            <div class="cfg-form-section">
              <p class="cfg-form-section-title">Applicable Subscription Plans</p>
              <div class="cfg-form-group cfg-form-group-full" style="position:relative;">
                <label>Subscription plans</label>
                <div class="cfg-chip-input-wrap" id="wz-policy-chip-wrap">
                  <div id="wz-policy-chips" style="display:contents;"></div>
                  <input type="text" class="cfg-chip-text-input" id="wz-policy-search"
                    placeholder="{{#if orgPlans.length}}Type to search plans…{{else}}No plans available{{/if}}"
                    autocomplete="off" {{#unless orgPlans.length}}disabled{{/unless}} />
                </div>
                <div class="cfg-chip-dropdown" id="wz-policy-dropdown"></div>
                {{#unless orgPlans.length}}
                <p style="font-size:.844rem;color:#9aa3af;margin:6px 0 0;">No subscription plans yet. Create them under <strong>Subscription Plans</strong>.</p>
                {{/unless}}
              </div>
            </div>
          </div>

          <!-- Step 1: Spec -->
          <div class="cfg-wizard-step" id="cfg-wstep-1" style="display:none;">
            <p class="cfg-wstep-desc">Upload the contract that defines this API. <span class="required">*</span> Required. Accepted: OpenAPI (.json / .yaml), AsyncAPI, GraphQL SDL (.graphql), or WSDL (.wsdl / .xml).</p>
            <label class="cfg-upload-zone" id="wz-spec-zone">
              <span class="cfg-upload-icon"><i class="bi bi-file-earmark-arrow-up"></i></span>
              <span class="cfg-upload-label">Drag &amp; drop or <span>browse</span> to upload</span>
              <span class="cfg-upload-hint">Single spec file · up to 10 MB</span>
              <input type="file" id="wz-spec-input" accept=".json,.yaml,.yml,.graphql,.gql,.wsdl,.xml" />
            </label>
            <p id="wz-spec-error" style="display:none;color:#c62828;font-size:.813rem;margin:8px 0 0;">A spec file is required to continue.</p>
            <div id="wz-spec-onfile" style="display:none;" class="cfg-spec-onfile">
              <i class="bi bi-check-circle-fill"></i>
              <span>Existing spec on file — attach a new file above to replace it</span>
            </div>
            <div class="cfg-spec-chip" id="wz-spec-chip">
              <span class="cfg-spec-icon"><i class="bi bi-file-check"></i></span>
              <div>
                <div class="cfg-spec-name" id="wz-spec-name"></div>
                <div class="cfg-spec-sub">Spec uploaded</div>
              </div>
              <button type="button" class="cfg-action-btn" id="wz-spec-remove" style="margin-left:auto;">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
          </div>

          <!-- Step 2: Documentation -->
          <div class="cfg-wizard-step" id="cfg-wstep-2" style="display:none;">
            <p class="cfg-wstep-desc">Add guides or references to help developers use this API. You can upload multiple Markdown files (.md).</p>
            <label class="cfg-upload-compact" id="wz-docs-zone">
              <i class="bi bi-upload" style="color:#0277bd;font-size:1rem;flex:none;"></i>
              <span style="font-size:.844rem;font-weight:600;color:#1a2433;">Drag &amp; drop or <span style="color:#1f6feb;">browse</span> to upload <span style="color:#9aa3af;font-weight:400;">— .md · multiple</span></span>
              <input type="file" id="wz-docs-input" multiple accept=".md,.markdown" />
            </label>
            <div id="wz-existing-docs-list" class="cfg-docs-list"></div>
            <div id="wz-docs-empty" class="cfg-docs-empty">No documents added yet.</div>
            <div id="wz-docs-list" class="cfg-docs-list"></div>
          </div>

          <!-- Step 3: Content (landing page & assets) — edit mode only -->
          <div class="cfg-wizard-step" id="cfg-wstep-3" style="display:none;">
            <p class="cfg-wstep-desc">Upload a ZIP to set this API's developer-portal content. Include a <code>web/</code> folder for landing-page assets (Markdown, HTML, CSS, JS, images) and/or a <code>docs/</code> folder for downloadable documents. Files with a matching name are replaced; others are added. This uploads immediately when you click <strong>Upload content</strong> — it is independent of the <strong>Save changes</strong> button.</p>
            <label class="cfg-upload-zone" id="wz-content-zone">
              <span class="cfg-upload-icon"><i class="bi bi-file-earmark-zip"></i></span>
              <span class="cfg-upload-label">Drag &amp; drop or <span>browse</span> to upload</span>
              <span class="cfg-upload-hint">Single ZIP file · up to 10 MB</span>
              <input type="file" id="wz-content-input" accept=".zip" />
            </label>
            <p id="wz-content-error" style="display:none;color:#c62828;font-size:.813rem;margin:8px 0 0;"></p>
            <div class="cfg-spec-chip" id="wz-content-chip">
              <span class="cfg-spec-icon"><i class="bi bi-file-earmark-zip-fill"></i></span>
              <div>
                <div class="cfg-spec-name" id="wz-content-name"></div>
                <div class="cfg-spec-sub">Ready to upload</div>
              </div>
              <button type="button" class="cfg-action-btn" id="wz-content-remove" style="margin-left:auto;">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
            <div class="d-flex align-items-center gap-3 mt-3">
              <button type="button" class="cfg-btn-primary" id="wz-content-upload-btn" disabled>
                <i class="bi bi-cloud-upload"></i> Upload content
              </button>
            </div>
          </div>

          <!-- Wizard actions -->
          <div class="cfg-wizard-actions">
            <div class="cfg-wizard-actions-right">
              <button type="button" class="cfg-btn-ghost" id="cfg-wizard-cancel">Cancel</button>
              <button type="button" class="cfg-btn-ghost" id="cfg-wizard-back-step" style="display:none;">Back</button>
              <button type="button" class="cfg-btn-primary" id="cfg-wizard-next">Next</button>
            </div>
          </div>
        </div>

      </div><!-- /#cfg-apis -->

      <!-- ══ MCP Servers ══ -->
      <div class="cfg-panel" id="cfg-mcps">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">MCP Servers</h2>
            <p class="cfg-panel-desc">Add, edit, and remove the MCP servers exposed in this developer portal.</p>
          </div>
          <div style="display:flex; gap:10px;">
            <button class="cfg-btn-primary" id="cfg-add-mcp-btn" type="button">
              <i class="bi bi-plus"></i> Add MCP Server
            </button>
          </div>
        </div>

        <div class="cfg-bulk-bar" id="cfg-mcps-bulk-bar" style="display:none;" role="region" aria-label="Bulk actions">
          <span class="cfg-bulk-bar-count" id="cfg-mcps-bulk-bar-count"></span>
          <button type="button" class="cfg-btn-danger cfg-btn-sm" id="cfg-mcps-bulk-delete-btn">
            <i class="bi bi-trash"></i> Delete selected
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th class="cfg-th-check"><input type="checkbox" id="cfg-mcps-select-all" aria-label="Select all MCP servers"></th>
                <th>MCP Server</th>
                <th>Version</th>
                <th>Status</th>
                <th style="width:52px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-mcps-tbody">
              {{#orgMCPs}}
              <tr id="cfg-api-row-{{apiId}}">
                <td class="cfg-td-check">
                  <input type="checkbox" class="cfg-row-check"
                    data-id="{{apiId}}" data-name="{{apiName}}"
                    aria-label="Select {{apiName}}">
                </td>
                <td>
                  <div class="cfg-api-cell">
                    <span class="cfg-api-avatar cfg-api-avatar--mcp">{{firstTwoLetters apiName}}</span>
                    <div>
                      <div class="cfg-cell-name">{{apiName}}</div>
                      <div class="cfg-cell-context">/{{apiHandle}}</div>
                    </div>
                  </div>
                </td>
                <td class="cfg-cell-version">{{apiVersion}}</td>
                <td>
                  {{#if (eq apiStatus "PUBLISHED")}}
                  <span class="cfg-status-badge cfg-status-published">
                    <span class="cfg-status-dot"></span>Published
                  </span>
                  {{else if (eq apiStatus "DEPRECATED")}}
                  <span class="cfg-status-badge cfg-status-deprecated">
                    <span class="cfg-status-dot"></span>Deprecated
                  </span>
                  {{else}}
                  <span class="cfg-status-badge cfg-status-draft">
                    <span class="cfg-status-dot"></span>Draft
                  </span>
                  {{/if}}
                </td>
                <td class="cfg-cell-actions">
                  <button class="cfg-action-btn cfg-menu-trigger" type="button" aria-label="MCP server actions">
                    <i class="bi bi-three-dots-vertical"></i>
                  </button>
                  <div class="cfg-dropdown">
                    <button class="cfg-dropdown-item cfg-edit-trigger" type="button" data-id="{{apiId}}">
                      <i class="bi bi-pencil"></i> Edit
                    </button>
                    {{#if (eq apiStatus "PUBLISHED")}}
                    <button class="cfg-dropdown-item cfg-unpublish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                      <i class="bi bi-archive"></i> Deprecate
                    </button>
                    {{else}}
                    <button class="cfg-dropdown-item cfg-publish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                      <i class="bi bi-cloud-upload"></i> Publish
                    </button>
                    {{/if}}
                    <div class="cfg-dropdown-divider"></div>
                    <button class="cfg-dropdown-item cfg-dropdown-item--danger cfg-delete-trigger" type="button"
                      data-id="{{apiId}}" data-name="{{apiName}}">
                      <i class="bi bi-trash"></i> Delete
                    </button>
                  </div>
                </td>
              </tr>
              {{/orgMCPs}}
              {{#unless orgMCPs.length}}
              <tr><td colspan="5" class="cfg-empty-row">No MCP servers found. Click <strong>Add MCP Server</strong> to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-mcps -->

      <!-- ══ Subscription Plans ══ -->
      <div class="cfg-panel" id="cfg-plans">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Subscription Plans</h2>
            <p class="cfg-panel-desc">Define the rate and quota tiers applications can subscribe to.</p>
          </div>
          <button class="cfg-btn-primary" id="cfg-add-plan-btn" type="button">
            <i class="bi bi-plus"></i> Add plan
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th>Plan</th>
                <th>Name</th>
                <th>Limits</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-plans-tbody">
              {{#orgPlans}}
              <tr id="cfg-plan-row-{{planId}}"
                data-id="{{planId}}"
                data-name="{{planName}}"
                data-display="{{displayName}}"
                data-desc="{{description}}"
                data-limits="{{{jsonAttr limits}}}"
                data-refid="{{refId}}">
                <td>
                  <div style="font-size:.875rem;font-weight:600;color:#1a2433;">{{displayName}}</div>
                  {{#if description}}<div style="font-size:.75rem;color:#637282;margin-top:2px;">{{description}}</div>{{/if}}
                </td>
                <td><span class="cfg-name-chip">{{planName}}</span></td>
                <td>
                  {{#if limits.length}}
                    {{#limits}}
                    <span class="cfg-limit-badge">{{limitTypeLabel limitType}} · {{#if (eq limitCount -1)}}∞{{else}}{{limitCount}}{{/if}}{{#if timeUnit}} / {{#unless (eq timeAmount 1)}}{{timeAmount}} {{/unless}}{{timeUnitLabel timeUnit}}{{/if}}</span>
                    {{/limits}}
                  {{else}}
                    <span style="color:#9aa3af;font-size:.8rem;">—</span>
                  {{/if}}
                </td>
                <td>
                  <div class="cfg-row-actions">
                    <button class="cfg-icon-btn cfg-plan-edit-btn" type="button"
                      data-id="{{planId}}" data-name="{{planName}}" data-display="{{displayName}}"
                      data-desc="{{description}}" data-limits="{{{jsonAttr limits}}}" data-refid="{{refId}}" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="cfg-icon-btn cfg-icon-btn--danger cfg-plan-delete-btn" type="button"
                      data-id="{{planId}}" data-name="{{planName}}" data-display="{{displayName}}" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              {{/orgPlans}}
              {{#unless orgPlans.length}}
              <tr><td colspan="4" class="cfg-tbl-empty">No subscription plans yet. Add one to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-plans -->

      <!-- ══ Webhooks ══ -->
      <div class="cfg-panel" id="cfg-webhooks">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Webhooks</h2>
            <p class="cfg-panel-desc">Send a notification to your own endpoint when API keys or subscriptions change in this organization.</p>
          </div>
          <button class="cfg-btn-primary" id="cfg-add-webhook-btn" type="button">
            <i class="bi bi-plus"></i> Add webhook
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th>Display name</th>
                <th>Target URL</th>
                <th>Events</th>
                <th>Secret</th>
                <th>Public key</th>
                <th>Enabled</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-webhooks-tbody">
              {{#webhookSubscribers}}
              <tr id="cfg-webhook-row-{{id}}" data-id="{{id}}">
                <td>
                  <button type="button" class="cfg-webhook-edit-btn" data-id="{{id}}"
                    style="border:none;background:none;padding:0;cursor:pointer;font-size:.875rem;font-weight:600;color:#1a2433;text-decoration:none;">{{displayName}}</button>
                </td>
                <td>
                  <span class="cfg-name-chip" title="{{targetUrl}}"
                    style="display:inline-block;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{targetUrl}}</span>
                </td>
                <td>
                  {{#if events.length}}
                  {{#each events}}<span class="cfg-name-chip" style="margin-right:4px;">{{this}}</span>{{/each}}
                  {{else}}
                  <span style="font-size:.813rem;color:#637282;">All events</span>
                  {{/if}}
                </td>
                <td>{{#if hasSecret}}••••••••{{else}}—{{/if}}</td>
                <td>{{#if hasPublicKey}}Configured{{else}}—{{/if}}</td>
                <td>{{#if enabled}}Yes{{else}}No{{/if}}</td>
                <td>
                  <div class="cfg-row-actions">
                    <button class="cfg-icon-btn cfg-webhook-edit-btn" type="button" data-id="{{id}}" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="cfg-icon-btn cfg-icon-btn--danger cfg-webhook-delete-btn" type="button"
                      data-id="{{id}}" data-name="{{displayName}}" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              {{/webhookSubscribers}}
              {{#unless webhookSubscribers.length}}
              <tr><td colspan="7" class="cfg-tbl-empty">No webhooks yet. Add one to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-webhooks -->

      <!-- ══ Key Managers ══ -->
      <div class="cfg-panel" id="cfg-keymanagers">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Key Managers</h2>
            <p class="cfg-panel-desc">Register the OAuth2 key managers applications can obtain tokens from. OAuth applications are created directly in the key manager itself — the portal only proxies token requests to it.</p>
          </div>
          <button class="cfg-btn-primary" id="cfg-add-km-btn" type="button">
            <i class="bi bi-plus"></i> Add key manager
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th>Display name</th>
                <th>Token endpoint</th>
                <th>Status</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-keymanagers-tbody">
              {{#keyManagers}}
              <tr id="cfg-km-row-{{id}}" data-id="{{id}}">
                <td>
                  <button type="button" class="cfg-km-edit-btn" data-id="{{id}}"
                    style="border:none;background:none;padding:0;cursor:pointer;font-size:.875rem;font-weight:600;color:#1a2433;text-decoration:none;">{{displayName}}</button>
                </td>
                <td>
                  <span class="cfg-name-chip" title="{{tokenEndpoint}}"
                    style="display:inline-block;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{tokenEndpoint}}</span>
                </td>
                <td>
                  {{#if enabled}}
                  <span class="cfg-status-badge cfg-status-published">
                    <span class="cfg-status-dot"></span>Enabled
                  </span>
                  {{else}}
                  <span class="cfg-status-badge cfg-status-draft">
                    <span class="cfg-status-dot"></span>Disabled
                  </span>
                  {{/if}}
                </td>
                <td>
                  <div class="cfg-row-actions">
                    <button class="cfg-icon-btn cfg-km-edit-btn" type="button" data-id="{{id}}" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="cfg-icon-btn cfg-icon-btn--danger cfg-km-delete-btn" type="button"
                      data-id="{{id}}" data-name="{{displayName}}" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              {{/keyManagers}}
              {{#unless keyManagers.length}}
              <tr><td colspan="4" class="cfg-tbl-empty">No key managers yet. Add one to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-keymanagers -->

      <!-- ══ Organization (current org only) ══ -->
      <div class="cfg-panel" id="cfg-organizations">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Organization</h2>
            <p class="cfg-panel-desc">Manage the details of this organization.</p>
          </div>
        </div>

        {{#if currentOrg}}
        <div class="cfg-form-grid" style="max-width:760px;">
          <div class="cfg-form-group">
            <label for="org-display">Name <span class="required">*</span></label>
            <input type="text" id="org-display" class="cfg-form-input" value="{{currentOrg.displayName}}" />
          </div>
          <div class="cfg-form-group">
            <label for="org-handle">Handle</label>
            <input type="text" id="org-handle" class="cfg-form-input cfg-form-input--mono" value="{{currentOrg.id}}" readonly />
            <p class="cfg-field-hint">Identifier used in URLs. Cannot be changed.</p>
          </div>
          <div class="cfg-form-group">
            <label for="org-owner">Business owner</label>
            <input type="text" id="org-owner" class="cfg-form-input" value="{{currentOrg.businessOwner}}" />
          </div>
          <div class="cfg-form-group">
            <label for="org-owner-contact">Business owner contact</label>
            <input type="text" id="org-owner-contact" class="cfg-form-input" value="{{currentOrg.businessOwnerContact}}" />
          </div>
          <div class="cfg-form-group">
            <label for="org-owner-email">Business owner email</label>
            <input type="email" id="org-owner-email" class="cfg-form-input" value="{{currentOrg.businessOwnerEmail}}" />
          </div>
          <div class="cfg-form-group">
            <label for="org-idp-ref">IDP reference ID</label>
            <input type="text" id="org-idp-ref" class="cfg-form-input" value="{{currentOrg.idpRefId}}" />
          </div>
          <div class="cfg-form-group">
            <label for="org-cp-ref">Control plane reference ID</label>
            <input type="text" id="org-cp-ref" class="cfg-form-input" value="{{currentOrg.cpRefId}}" />
          </div>
        </div>
        <div style="margin-top:20px;">
          <button class="cfg-btn-primary" id="cfg-save-org-btn" type="button" data-handle="{{currentOrg.id}}">
            <i class="bi bi-floppy me-1"></i> Save changes
          </button>
        </div>
        {{else}}
        <p class="cfg-tbl-empty">Organization details are unavailable.</p>
        {{/if}}
      </div><!-- /#cfg-organizations -->

      <!-- ══ Manage Views ══ -->
      <div class="cfg-panel" id="cfg-views">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Views</h2>
            <p class="cfg-panel-desc">Views scope which labelled APIs are visible. LLM Instructions and API Workflows are configured per view.</p>
          </div>
          <button class="cfg-btn-primary" id="cfg-add-view-btn" type="button">
            <i class="bi bi-plus"></i> Add view
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th>Handle</th>
                <th>Name</th>
                <th>Labels</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-views-tbody">
              {{#views}}
              <tr id="cfg-view-row-{{id}}" data-id="{{id}}">
                <td><span class="cfg-name-chip">{{id}}</span></td>
                <td>
                  <button type="button" class="cfg-view-edit-btn" data-id="{{id}}"
                    style="border:none;background:none;padding:0;cursor:pointer;font-size:.875rem;font-weight:600;color:#1a2433;text-decoration:none;">{{displayName}}</button>
                </td>
                <td>
                  <div class="d-flex flex-wrap gap-1">
                    {{#each labels}}<span class="cfg-name-chip">{{this}}</span>{{/each}}
                  </div>
                </td>
                <td>
                  <div class="cfg-row-actions">
                    <button class="cfg-icon-btn cfg-view-edit-btn" type="button" data-id="{{id}}" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    {{#unless (eq id "default")}}
                    <button class="cfg-icon-btn cfg-icon-btn--danger cfg-view-delete-btn" type="button"
                      data-id="{{id}}" data-name="{{displayName}}" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                    {{/unless}}
                  </div>
                </td>
              </tr>
              {{/views}}
              {{#unless views.length}}
              <tr><td colspan="4" class="cfg-tbl-empty">No views yet. Add one to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-views -->

      <!-- ══ Manage Labels ══ -->
      <div class="cfg-panel" id="cfg-labels">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">Labels</h2>
            <p class="cfg-panel-desc">Labels group APIs; views make labelled APIs visible to consumers.</p>
          </div>
          <button class="cfg-btn-primary" id="cfg-add-label-btn" type="button">
            <i class="bi bi-plus"></i> Add label
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th>Display name</th>
                <th>Name</th>
                <th style="width:90px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-labels-tbody">
              {{#orgLabels}}
              <tr id="cfg-label-row-{{id}}" data-id="{{id}}">
                <td>
                  <button type="button" class="cfg-label-edit-btn" data-name="{{id}}" data-display="{{displayName}}"
                    style="border:none;background:none;padding:0;cursor:pointer;font-size:.875rem;font-weight:600;color:#1a2433;text-decoration:none;">{{displayName}}</button>
                </td>
                <td><span class="cfg-name-chip">{{id}}</span></td>
                <td>
                  <div class="cfg-row-actions">
                    <button class="cfg-icon-btn cfg-label-edit-btn" type="button" data-name="{{id}}" data-display="{{displayName}}" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="cfg-icon-btn cfg-icon-btn--danger cfg-label-delete-btn" type="button"
                      data-name="{{id}}" data-display="{{displayName}}" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              {{/orgLabels}}
              {{#unless orgLabels.length}}
              <tr><td colspan="3" class="cfg-tbl-empty">No labels yet. Add one to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-labels -->

    </div><!-- /.cfg-content -->
  </div><!-- /.cfg-layout -->
</div><!-- /.cfg-page -->

<!-- ══ Modals (position:fixed) ══ -->

<!-- Delete API modal -->
<div class="cfg-modal-overlay" id="cfg-delete-api-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-trash"></i></span>
      <h2 class="cfg-modal-title">Delete API</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to delete <strong id="cfg-del-api-name-txt"></strong>? It will be removed from the developer portal along with its spec and documentation. This action can't be undone.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-del-api-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-del-api-confirm">Delete API</button>
    </div>
  </div>
</div>

<!-- Deprecate API modal -->
<div class="cfg-modal-overlay" id="cfg-deprecate-api-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-archive"></i></span>
      <h2 class="cfg-modal-title">Deprecate API</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to deprecate <strong id="cfg-dep-api-name-txt"></strong>? It will remain visible but marked as deprecated. You can publish it again at any time.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-dep-api-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-dep-api-confirm">Deprecate</button>
    </div>
  </div>
</div>

<!-- Delete Label modal -->
<div class="cfg-modal-overlay" id="cfg-delete-label-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-trash"></i></span>
      <h2 class="cfg-modal-title">Delete Label</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to delete <strong id="cfg-del-label-name-txt"></strong>? It will be removed from all APIs using it. This action can't be undone.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-del-label-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-del-label-confirm">Delete label</button>
    </div>
  </div>
</div>

<!-- Delete Plan modal -->
<div class="cfg-modal-overlay" id="cfg-delete-plan-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-trash"></i></span>
      <h2 class="cfg-modal-title">Delete Plan</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to delete <strong id="cfg-del-plan-name-txt"></strong>? Applications subscribed under it will need a new plan. This action can't be undone.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-del-plan-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-del-plan-confirm">Delete plan</button>
    </div>
  </div>
</div>

<!-- Delete Webhook modal -->
<div class="cfg-modal-overlay" id="cfg-delete-webhook-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-trash"></i></span>
      <h2 class="cfg-modal-title">Delete Webhook</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to delete <strong id="cfg-del-webhook-name-txt"></strong>? This action can't be undone.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-del-webhook-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-del-webhook-confirm">Delete webhook</button>
    </div>
  </div>
</div>

<!-- Delete Key Manager modal -->
<div class="cfg-modal-overlay" id="cfg-delete-km-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-trash"></i></span>
      <h2 class="cfg-modal-title">Delete Key Manager</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to delete <strong id="cfg-del-km-name-txt"></strong>? Applications relying on it will no longer be able to obtain tokens. This action can't be undone.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-del-km-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-del-km-confirm">Delete key manager</button>
    </div>
  </div>
</div>

<!-- Add / Edit Label modal -->
<div class="cfg-modal-overlay" id="cfg-label-modal" style="display:none;">
  <div class="cfg-form-modal">
