      <!-- ══ MCP Servers ══ -->
      <div class="cfg-panel" id="cfg-mcps">
        <div class="cfg-panel-header">
          <div>
            <h2 class="cfg-panel-title">MCP Servers</h2>
            <p class="cfg-panel-desc">Add, edit, and remove the MCP servers exposed in this developer portal.</p>
          </div>
          <div style="display:flex; gap:10px;">
            <button class="cfg-btn-primary" id="cfg-add-mcp-btn" type="button">
              <i class="bi bi-plus"></i> Add MCP Server
            </button>
          </div>
        </div>

        <div class="cfg-bulk-bar" id="cfg-mcps-bulk-bar" style="display:none;" role="region" aria-label="Bulk actions">
          <span class="cfg-bulk-bar-count" id="cfg-mcps-bulk-bar-count"></span>
          <button type="button" class="cfg-btn-danger cfg-btn-sm" id="cfg-mcps-bulk-delete-btn">
            <i class="bi bi-trash"></i> Delete selected
          </button>
        </div>

        <div class="cfg-table-wrap">
          <table class="cfg-table">
            <thead>
              <tr>
                <th class="cfg-th-check"><input type="checkbox" id="cfg-mcps-select-all" aria-label="Select all MCP servers"></th>
                <th>MCP Server</th>
                <th>Version</th>
                <th>Status</th>
                <th style="width:52px;"></th>
              </tr>
            </thead>
            <tbody id="cfg-mcps-tbody">
              {{#orgMCPs}}
              <tr id="cfg-api-row-{{apiId}}">
                <td class="cfg-td-check">
                  <input type="checkbox" class="cfg-row-check"
                    data-id="{{apiId}}" data-name="{{apiName}}"
                    aria-label="Select {{apiName}}">
                </td>
                <td>
                  <div class="cfg-api-cell">
                    <span class="cfg-api-avatar cfg-api-avatar--mcp">{{firstTwoLetters apiName}}</span>
                    <div>
                      <div class="cfg-cell-name">{{apiName}}</div>
                      <div class="cfg-cell-context">/{{apiHandle}}</div>
                    </div>
                  </div>
                </td>
                <td class="cfg-cell-version">{{apiVersion}}</td>
                <td>
                  {{#if (eq apiStatus "PUBLISHED")}}
                  <span class="cfg-status-badge cfg-status-published">
                    <span class="cfg-status-dot"></span>Published
                  </span>
                  {{else if (eq apiStatus "DEPRECATED")}}
                  <span class="cfg-status-badge cfg-status-deprecated">
                    <span class="cfg-status-dot"></span>Deprecated
                  </span>
                  {{else}}
                  <span class="cfg-status-badge cfg-status-draft">
                    <span class="cfg-status-dot"></span>Draft
                  </span>
                  {{/if}}
                </td>
                <td class="cfg-cell-actions">
                  <button class="cfg-action-btn cfg-menu-trigger" type="button" aria-label="MCP server actions">
                    <i class="bi bi-three-dots-vertical"></i>
                  </button>
                  <div class="cfg-dropdown">
                    <button class="cfg-dropdown-item cfg-edit-trigger" type="button" data-id="{{apiId}}">
                      <i class="bi bi-pencil"></i> Edit
                    </button>
                    {{#if (eq apiStatus "PUBLISHED")}}
                    <button class="cfg-dropdown-item cfg-unpublish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                      <i class="bi bi-archive"></i> Deprecate
                    </button>
                    {{else}}
                    <button class="cfg-dropdown-item cfg-publish-trigger" type="button" data-id="{{apiId}}" data-name="{{apiName}}">
                      <i class="bi bi-cloud-upload"></i> Publish
                    </button>
                    {{/if}}
                    <div class="cfg-dropdown-divider"></div>
                    <button class="cfg-dropdown-item cfg-dropdown-item--danger cfg-delete-trigger" type="button"
                      data-id="{{apiId}}" data-name="{{apiName}}">
                      <i class="bi bi-trash"></i> Delete
                    </button>
                  </div>
                </td>
              </tr>
              {{/orgMCPs}}
              {{#unless orgMCPs.length}}
              <tr><td colspan="5" class="cfg-empty-row">No MCP servers found. Click <strong>Add MCP Server</strong> to get started.</td></tr>
              {{/unless}}
            </tbody>
          </table>
        </div>
      </div><!-- /#cfg-mcps -->
