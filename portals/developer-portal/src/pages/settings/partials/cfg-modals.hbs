<!-- Reset Theme modal -->
<div class="cfg-modal-overlay" id="cfg-reset-theme-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-arrow-counterclockwise"></i></span>
      <h2 class="cfg-modal-title">Reset Theme</h2>
    </div>
    <p class="cfg-modal-body">Reset <strong id="cfg-reset-theme-view-txt"></strong> to the built-in default theme? Its custom CSS, layout, partials, and images will be removed. This action can't be undone.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-reset-theme-cancel">Cancel</button>
