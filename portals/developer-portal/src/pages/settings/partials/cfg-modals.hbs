<!-- ══ Modals (position:fixed) ══ -->

<!-- Delete API modal -->
<div class="cfg-modal-overlay" id="cfg-delete-api-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-trash"></i></span>
      <h2 class="cfg-modal-title">Delete API</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to delete <strong id="cfg-del-api-name-txt"></strong>? It will be removed from the developer portal along with its spec and documentation. This action can't be undone.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-del-api-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-del-api-confirm">Delete API</button>
    </div>
  </div>
</div>

<!-- Deprecate API modal -->
<div class="cfg-modal-overlay" id="cfg-deprecate-api-modal" style="display:none;">
  <div class="cfg-modal">
    <div class="cfg-modal-header">
      <span class="cfg-modal-icon"><i class="bi bi-archive"></i></span>
      <h2 class="cfg-modal-title">Deprecate API</h2>
    </div>
    <p class="cfg-modal-body">Are you sure you want to deprecate <strong id="cfg-dep-api-name-txt"></strong>? It will remain visible but marked as deprecated. You can publish it again at any time.</p>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-dep-api-cancel">Cancel</button>
      <button type="button" class="cfg-btn-danger" id="cfg-dep-api-confirm">Deprecate</button>
    </div>
  </div>
</div>

