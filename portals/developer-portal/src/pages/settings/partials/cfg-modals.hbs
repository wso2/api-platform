<!-- Add / Edit Label modal -->
<div class="cfg-modal-overlay" id="cfg-label-modal" style="display:none;">
  <div class="cfg-form-modal">
    <div class="cfg-modal-titlerow">
      <h2 class="cfg-modal-form-title" id="cfg-label-modal-title">Add label</h2>
      <button type="button" class="cfg-modal-close" id="cfg-label-modal-close"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="lbl-display">Display name <span class="required">*</span></label>
      <input type="text" id="lbl-display" class="cfg-form-input" placeholder="e.g. Public" />
    </div>
    <div class="cfg-form-group" style="margin-bottom:24px;">
      <label for="lbl-name">Name <span class="required">*</span></label>
      <input type="text" id="lbl-name" class="cfg-form-input cfg-form-input--mono" placeholder="public" />
      <p class="cfg-field-hint">Lowercase identifier used internally.</p>
    </div>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-label-modal-cancel">Cancel</button>
      <button type="button" class="cfg-btn-primary" id="cfg-label-modal-save">Add label</button>
    </div>
  </div>
</div>

