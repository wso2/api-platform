<!-- Add / Edit View modal -->
<div class="cfg-modal-overlay" id="cfg-view-modal" style="display:none;">
  <div class="cfg-form-modal">
    <div class="cfg-modal-titlerow">
      <h2 class="cfg-modal-form-title" id="cfg-view-modal-title">Add view</h2>
      <button type="button" class="cfg-modal-close" id="cfg-view-modal-close"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="view-handle">Handle <span class="required">*</span></label>
      <input type="text" id="view-handle" class="cfg-form-input cfg-form-input--mono" placeholder="partner-apis" />
      <p class="cfg-field-hint">Lowercase identifier used in URLs. Cannot be changed later.</p>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="view-display">Name</label>
      <input type="text" id="view-display" class="cfg-form-input" placeholder="e.g. Partner APIs" />
    </div>
    <div class="cfg-form-group" style="margin-bottom:24px;">
      <label>Labels</label>
      {{#if orgLabels.length}}
      <div id="view-labels" class="cfg-label-picker" role="group" aria-label="View labels">
        {{#orgLabels}}
        <button type="button" class="cfg-label-toggle" data-value="{{id}}" aria-pressed="false">
          <i class="bi bi-check2"></i><span>{{displayName}}</span>
        </button>
        {{/orgLabels}}
      </div>
      <p class="cfg-field-hint">Click labels to toggle. APIs with these labels appear in this view.</p>
      {{else}}
      <p class="cfg-field-hint">No labels yet — create labels first to attach them to this view.</p>
      {{/if}}
    </div>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-view-modal-cancel">Cancel</button>
      <button type="button" class="cfg-btn-primary" id="cfg-view-modal-save">Add view</button>
    </div>
  </div>
</div>

<!-- Add / Edit Plan modal -->
<div class="cfg-modal-overlay" id="cfg-plan-modal" style="display:none;">
  <div class="cfg-form-modal cfg-form-modal--wide">
    <div class="cfg-modal-titlerow">
      <h2 class="cfg-modal-form-title" id="cfg-plan-modal-title">Add subscription plan</h2>
      <button type="button" class="cfg-modal-close" id="cfg-plan-modal-close"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="cfg-form-grid" style="margin-bottom:16px;">
      <div class="cfg-form-group">
        <label for="pol-display">Display name <span class="required">*</span></label>
        <input type="text" id="pol-display" class="cfg-form-input" placeholder="e.g. Gold" />
      </div>
      <div class="cfg-form-group">
        <label for="pol-name">Name <span class="required">*</span></label>
        <input type="text" id="pol-name" class="cfg-form-input cfg-form-input--mono" placeholder="Gold" />
      </div>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="pol-desc">Description</label>
      <textarea id="pol-desc" class="cfg-form-input" rows="2" placeholder="Describe this tier…"></textarea>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
        <label style="margin:0;">Limits</label>
        <button type="button" class="cfg-btn-secondary cfg-btn-sm" id="pol-add-limit-btn"><i class="bi bi-plus"></i> Add limit</button>
      </div>
      <div id="pol-limits-list"></div>
      <p class="cfg-field-hint">Leave empty for an unlimited plan. Use −1 as the count to mark a limit as unlimited.</p>
    </div>
    <div class="cfg-form-group" style="margin-bottom:24px;">
      <label for="pol-refid">External reference ID <span style="color:#9aa3af;font-weight:400;">(optional)</span></label>
      <input type="text" id="pol-refid" class="cfg-form-input cfg-form-input--mono" placeholder="e.g. 7c9e6679-7425-40de-944b-e07fc1f90ae7" />
      <p class="cfg-field-hint">UUID linking this plan to an external billing or quota system.</p>
    </div>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-plan-modal-cancel">Cancel</button>
      <button type="button" class="cfg-btn-primary" id="cfg-plan-modal-save">Add plan</button>
    </div>
  </div>
</div>

<style>
  .wh-toggle { position: relative; display: inline-block; width: 38px; height: 22px; flex: none; }
  .wh-toggle input { opacity: 0; width: 0; height: 0; }
  .wh-toggle-slider { position: absolute; inset: 0; background-color: #d0d7de; border-radius: 34px; cursor: pointer; transition: .2s; }
  .wh-toggle-slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background-color: var(--white); border-radius: 50%; transition: .2s; }
  .wh-toggle input:checked + .wh-toggle-slider { background-color: #1f6feb; }
  .wh-toggle input:checked + .wh-toggle-slider:before { transform: translateX(16px); }
</style>

<!-- Add / Edit Webhook modal -->
<div class="cfg-modal-overlay" id="cfg-webhook-modal" style="display:none;">
  <div class="cfg-form-modal cfg-form-modal--wide">
    <div class="cfg-modal-titlerow">
      <h2 class="cfg-modal-form-title" id="cfg-webhook-modal-title">Add webhook</h2>
      <button type="button" class="cfg-modal-close" id="cfg-webhook-modal-close"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="wh-display">Display name <span class="required">*</span></label>
      <input type="text" id="wh-display" class="cfg-form-input" placeholder="e.g. Production listener" />
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="wh-handle">Handle <span class="required">*</span></label>
      <input type="text" id="wh-handle" class="cfg-form-input cfg-form-input--mono" placeholder="production-listener" />
      <p class="cfg-field-hint">Lowercase identifier used internally.</p>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="wh-url">Target URL <span class="required">*</span></label>
      <input type="text" id="wh-url" class="cfg-form-input cfg-form-input--mono" placeholder="https://example.com/webhook" />
    </div>
    <div class="cfg-form-grid" style="margin-bottom:16px;">
      <div class="cfg-form-group">
        <label for="wh-secret">Secret <span style="color:#9aa3af;font-weight:400;">(optional)</span></label>
        <input type="password" id="wh-secret" class="cfg-form-input" autocomplete="new-password"
          placeholder="Used to sign payloads (HMAC)" />
        <p class="cfg-field-hint" id="wh-secret-hint" style="display:none;">
          A secret is already set. Leave blank to keep it, or enter a new value to replace it.
        </p>
      </div>
      <div class="cfg-form-group">
        <label for="wh-timeout">Timeout (ms)</label>
        <input type="number" id="wh-timeout" class="cfg-form-input" min="1" value="5000" />
      </div>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label for="wh-publickey">Public key <span style="color:#9aa3af;font-weight:400;">(optional)</span></label>
      <textarea id="wh-publickey" class="cfg-form-input cfg-form-input--mono" rows="3" placeholder="PEM-encoded RSA public key"></textarea>
      <p class="cfg-field-hint">
        Used to encrypt the plaintext API key delivered with apikey.* / subscription.created events, so only you can read it.
      </p>
      <p class="cfg-field-hint" id="wh-publickey-hint" style="display:none;">
        A public key is already set. Leave blank to keep it, or enter a new value to replace it.
      </p>
    </div>
    <div class="cfg-form-group" style="margin-bottom:16px;">
      <label>Events</label>
      <div class="cfg-vis-toggle" style="margin-bottom:12px;">
        <button type="button" class="cfg-vis-btn active" id="wh-events-all-btn">
          <i class="bi bi-broadcast"></i> All events
        </button>
        <button type="button" class="cfg-vis-btn" id="wh-events-select-btn">
          <i class="bi bi-check2-square"></i> Select events
        </button>
      </div>
      <div id="wh-event-list" style="display:none;flex-wrap:wrap;gap:10px 16px;">
        {{#each webhookEventTypes}}
        <label style="display:flex;align-items:center;gap:6px;font-size:.813rem;color:#1a2433;cursor:pointer;">
          <input type="checkbox" class="wh-event-check" value="{{this}}" /> {{this}}
        </label>
        {{/each}}
      </div>
    </div>
    <div class="cfg-form-group" style="margin-bottom:24px;">
      <label style="display:flex;align-items:center;gap:10px;font-size:.844rem;color:#1a2433;font-weight:500;cursor:pointer;">
        <span class="wh-toggle">
          <input type="checkbox" id="wh-enabled" checked />
          <span class="wh-toggle-slider"></span>
        </span>
        Enabled
      </label>
    </div>
    <div class="cfg-modal-actions">
      <button type="button" class="cfg-btn-secondary" id="cfg-webhook-modal-cancel">Cancel</button>
      <button type="button" class="cfg-btn-primary" id="cfg-webhook-modal-save">Add webhook</button>
    </div>
  </div>
</div>

