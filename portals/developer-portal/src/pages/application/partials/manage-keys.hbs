<link rel="stylesheet" href="/technical-styles/manage-keys.css" />
<section id="manage-keys-section" class="section keys-section">
<div class="container-fluid">

    <div class="mk-header">
        <h2 class="mk-title">Manage Keys</h2>
        <p class="mk-subtitle">Generate and govern OAuth2 credentials for <strong>{{applicationMetadata.name}}</strong>. Each key manager issues its own consumer key &amp; secret.</p>
    </div>

    {{!-- Environment selector — card-style tab triggers --}}
    <div class="mk-env-selector" role="tablist">
        <button class="mk-env-card active" id="production-tab" role="tab"
            data-bs-toggle="tab" data-bs-target="#production"
            aria-controls="production" aria-selected="true">
            <span class="mk-env-dot mk-env-dot-prod"></span>
            <div class="mk-env-text">
                <span class="mk-env-name">Production</span>
                <span class="mk-env-desc">Live traffic</span>
            </div>
        </button>
        <button class="mk-env-card" id="sandbox-tab" role="tab"
            data-bs-toggle="tab" data-bs-target="#sandbox"
            aria-controls="sandbox" aria-selected="false">
            <span class="mk-env-dot mk-env-dot-sandbox"></span>
            <div class="mk-env-text">
                <span class="mk-env-name">Sandbox</span>
                <span class="mk-env-desc">Safe to test</span>
            </div>
        </button>
    </div>

    <div class="tab-content mk-tab-content" id="keysTabContent">

        {{!-- ── PRODUCTION ── --}}
        <div class="tab-pane fade show active" id="production" role="tabpanel" aria-labelledby="production-tab">

            <div class="mk-context-banner mk-context-banner-prod">
                <i class="bi bi-circle-fill mk-env-dot-prod-icon"></i>
                <span>You are viewing <strong>Production</strong> credentials. Tokens issued here are valid in the live environment.</span>
            </div>

            {{#if keyManagersMetadata}}

            {{!-- Internal / Resident KMs: always show card --}}
            {{#each keyManagersMetadata}}
            {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
            {{#if enabled}}
            {{#let "keys" productionKeys}}
            {{> manage-keys-km-card
                kmName=../name
                kmId=../id
                kmType=../type
                keyType="PRODUCTION"
                keys=keys
                availableGrantTypes=../availableGrantTypes
                applicationConfiguration=../applicationConfiguration
                tokenEndpoint=../tokenEndpoint
                appId=@root.applicationMetadata.id
                appName=@root.applicationMetadata.name
                orgID=@root.orgID
                subscriptionScopes=@root.subscriptionScopes
                isReadOnlyMode=@root.isReadOnlyMode
            }}
            {{/let}}
            {{/if}}
            {{/in}}
            {{/each}}

            {{!-- External KMs: only show card if keys already exist --}}
            {{#each keyManagersMetadata}}
            {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
            {{!-- skip internal --}}
            {{else}}
            {{#if enabled}}
            {{#let "keys" productionKeys}}
            {{#if keys.consumerKey}}
            {{> manage-keys-km-card
                kmName=../name
                kmId=../id
                kmType=../type
                keyType="PRODUCTION"
                keys=keys
                availableGrantTypes=../availableGrantTypes
                applicationConfiguration=../applicationConfiguration
                tokenEndpoint=../tokenEndpoint
                appId=@root.applicationMetadata.id
                appName=@root.applicationMetadata.name
                orgID=@root.orgID
                subscriptionScopes=@root.subscriptionScopes
                isReadOnlyMode=@root.isReadOnlyMode
            }}
            {{/if}}
            {{/let}}
            {{/if}}
            {{/in}}
            {{/each}}

            {{!-- "Generate with another KM" --}}
            <div class="mk-add-km-section" id="addKmSection-PRODUCTION" style="display:none">
                {{!-- Single-KM direct buttons (JS hides all but one, or hides entire block if >1) --}}
                {{#each keyManagersMetadata}}
                {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
                {{else}}
                {{#if enabled}}
                {{#let "keys" productionKeys}}
                {{#unless keys.consumerKey}}
                <div class="mk-add-km-single-item" data-env="PRODUCTION">
                    <button class="mk-add-km-btn" type="button"
                        data-km-name="{{../name}}"
                        onclick="selectKmAndGenerate('PRODUCTION', '{{@root.applicationMetadata.id}}', '{{@root.applicationMetadata.name}}', '{{@root.orgID}}', this)">
                        <i class="bi bi-plus"></i>
                        <span>Generate keys with <strong>{{../name}}</strong></span>
                        <span class="mk-add-km-spinner" style="display:none">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        </span>
                    </button>
                </div>
                {{/unless}}
                {{/let}}
                {{/if}}
                {{/in}}
                {{/each}}

                {{!-- Multi-KM dropdown (JS shows this instead when >1 available) --}}
                <div class="mk-add-km-dropdown" id="addKmMulti-PRODUCTION" style="display:none">
                    <button class="mk-add-km-btn" type="button"
                        onclick="toggleKmDropdown('PRODUCTION')">
                        <i class="bi bi-plus"></i>
                        <span>Generate keys with another key manager</span>
                        <span class="mk-add-km-spinner" id="addKmSpinner-PRODUCTION" style="display:none">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        </span>
                    </button>
                    <ul class="mk-km-dropdown-menu" id="kmDropdown-PRODUCTION">
                        {{#each keyManagersMetadata}}
                        {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
                        {{else}}
                        {{#if enabled}}
                        {{#let "keys" productionKeys}}
                        {{#unless keys.consumerKey}}
                        <li class="mk-km-dropdown-item"
                            data-km-id="{{../id}}" data-km-name="{{../name}}"
                            onclick="selectKmAndGenerate('PRODUCTION', '{{@root.applicationMetadata.id}}', '{{@root.applicationMetadata.name}}', '{{@root.orgID}}', this)">
                            <i class="bi bi-key"></i>
                            <span>{{../name}}</span>
                        </li>
                        {{/unless}}
                        {{/let}}
                        {{/if}}
                        {{/in}}
                        {{/each}}
                    </ul>
                </div>
            </div>
            <script>
            (function(){
                var sec = document.getElementById('addKmSection-PRODUCTION');
                if (!sec) return;
                var singles = sec.querySelectorAll('.mk-add-km-single-item[data-env="PRODUCTION"]');
                if (singles.length === 0) return;
                sec.style.display = '';
                if (singles.length === 1) {
                    singles[0].style.display = '';
                } else {
                    singles.forEach(function(el) { el.style.display = 'none'; });
                    document.getElementById('addKmMulti-PRODUCTION').style.display = '';
                }
            })();
            </script>

            {{else}}
            <div class="mk-unavailable">
                <i class="bi bi-exclamation-circle"></i>
                <span>Key generation is unavailable. Please contact your organization administrator.</span>
            </div>
            {{/if}}
        </div>

        {{!-- ── SANDBOX ── --}}
        <div class="tab-pane fade" id="sandbox" role="tabpanel" aria-labelledby="sandbox-tab">

            <div class="mk-context-banner mk-context-banner-sandbox">
                <i class="bi bi-circle-fill mk-env-dot-sandbox-icon"></i>
                <span>You are viewing <strong>Sandbox</strong> credentials. These are for testing only and cannot be used in production.</span>
            </div>

            {{#if keyManagersMetadata}}

            {{!-- Internal / Resident KMs: always show card --}}
            {{#each keyManagersMetadata}}
            {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
            {{#if enabled}}
            {{#let "keys" sandboxKeys}}
            {{> manage-keys-km-card
                kmName=../name
                kmId=../id
                kmType=../type
                keyType="SANDBOX"
                keys=keys
                availableGrantTypes=../availableGrantTypes
                applicationConfiguration=../applicationConfiguration
                tokenEndpoint=../tokenEndpoint
                appId=@root.applicationMetadata.id
                appName=@root.applicationMetadata.name
                orgID=@root.orgID
                subscriptionScopes=@root.subscriptionScopes
                isReadOnlyMode=@root.isReadOnlyMode
                isSandbox=true
            }}
            {{/let}}
            {{/if}}
            {{/in}}
            {{/each}}

            {{!-- External KMs: only show card if keys already exist --}}
            {{#each keyManagersMetadata}}
            {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
            {{!-- skip internal --}}
            {{else}}
            {{#if enabled}}
            {{#let "keys" sandboxKeys}}
            {{#if keys.consumerKey}}
            {{> manage-keys-km-card
                kmName=../name
                kmId=../id
                kmType=../type
                keyType="SANDBOX"
                keys=keys
                availableGrantTypes=../availableGrantTypes
                applicationConfiguration=../applicationConfiguration
                tokenEndpoint=../tokenEndpoint
                appId=@root.applicationMetadata.id
                appName=@root.applicationMetadata.name
                orgID=@root.orgID
                subscriptionScopes=@root.subscriptionScopes
                isReadOnlyMode=@root.isReadOnlyMode
                isSandbox=true
            }}
            {{/if}}
            {{/let}}
            {{/if}}
            {{/in}}
            {{/each}}

            {{!-- "Generate with another KM" --}}
            <div class="mk-add-km-section" id="addKmSection-SANDBOX" style="display:none">
                {{!-- Single-KM direct buttons --}}
                {{#each keyManagersMetadata}}
                {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
                {{else}}
                {{#if enabled}}
                {{#let "keys" sandboxKeys}}
                {{#unless keys.consumerKey}}
                <div class="mk-add-km-single-item" data-env="SANDBOX">
                    <button class="mk-add-km-btn" type="button"
                        data-km-name="{{../name}}"
                        onclick="selectKmAndGenerate('SANDBOX', '{{@root.applicationMetadata.id}}', '{{@root.applicationMetadata.name}}', '{{@root.orgID}}', this)">
                        <i class="bi bi-plus"></i>
                        <span>Generate keys with <strong>{{../name}}</strong></span>
                        <span class="mk-add-km-spinner" style="display:none">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        </span>
                    </button>
                </div>
                {{/unless}}
                {{/let}}
                {{/if}}
                {{/in}}
                {{/each}}

                {{!-- Multi-KM dropdown --}}
                <div class="mk-add-km-dropdown" id="addKmMulti-SANDBOX" style="display:none">
                    <button class="mk-add-km-btn" type="button"
                        onclick="toggleKmDropdown('SANDBOX')">
                        <i class="bi bi-plus"></i>
                        <span>Generate keys with another key manager</span>
                        <span class="mk-add-km-spinner" id="addKmSpinner-SANDBOX" style="display:none">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        </span>
                    </button>
                    <ul class="mk-km-dropdown-menu" id="kmDropdown-SANDBOX">
                        {{#each keyManagersMetadata}}
                        {{#in name values="_internal_key_manager_,Resident Key Manager,_appdev_sts_key_manager_"}}
                        {{else}}
                        {{#if enabled}}
                        {{#let "keys" sandboxKeys}}
                        {{#unless keys.consumerKey}}
                        <li class="mk-km-dropdown-item"
                            data-km-id="{{../id}}" data-km-name="{{../name}}"
                            onclick="selectKmAndGenerate('SANDBOX', '{{@root.applicationMetadata.id}}', '{{@root.applicationMetadata.name}}', '{{@root.orgID}}', this)">
                            <i class="bi bi-key"></i>
                            <span>{{../name}}</span>
                        </li>
                        {{/unless}}
                        {{/let}}
                        {{/if}}
                        {{/in}}
                        {{/each}}
                    </ul>
                </div>
            </div>
            <script>
            (function(){
                var sec = document.getElementById('addKmSection-SANDBOX');
                if (!sec) return;
                var singles = sec.querySelectorAll('.mk-add-km-single-item[data-env="SANDBOX"]');
                if (singles.length === 0) return;
                sec.style.display = '';
                if (singles.length === 1) {
                    singles[0].style.display = '';
                } else {
                    singles.forEach(function(el) { el.style.display = 'none'; });
                    document.getElementById('addKmMulti-SANDBOX').style.display = '';
                }
            })();
            </script>

            {{else}}
            <div class="mk-unavailable">
                <i class="bi bi-exclamation-circle"></i>
                <span>Key generation is unavailable. Please contact your organization administrator.</span>
            </div>
            {{/if}}
        </div>

    </div>{{!-- /tab-content --}}

    {{> warning }}
</div>
</section>
