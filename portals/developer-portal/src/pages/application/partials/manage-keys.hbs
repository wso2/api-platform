                                                    <span class="button-normal-state">
                                                        <i class="bi bi-key-fill"></i> Generate
                                                    </span>
                                                    <span class="button-loading-state" style="display: none;">
                                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                        Generating...
