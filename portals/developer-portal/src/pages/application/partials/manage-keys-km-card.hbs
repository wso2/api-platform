<div class="mk-km-card {{#if isSandbox}}mk-km-card-sandbox{{/if}}">

    {{!-- Card header --}}
    <div class="mk-km-header">
        <div class="mk-km-icon {{#if isSandbox}}mk-km-icon-sandbox{{/if}}">
            <i class="bi bi-key-fill"></i>
        </div>
        <div class="mk-km-info">
            <span class="mk-km-name">{{kmName}}</span>
        </div>
        <span class="mk-km-badge {{#if isSandbox}}mk-km-badge-sandbox{{/if}}">
            <span class="mk-km-badge-dot"></span> Active
        </span>
    </div>

    {{!-- Inner tab nav — only visible when credentials exist --}}
    <div class="mk-km-tabnav" id="keyTabNav-{{keyType}}" role="tablist"
        style="{{#unless keys.consumerKey}}display:none{{/unless}}">
        <button class="mk-km-tab active" type="button" role="tab"
            id="tab-btn-creds-{{kmId}}-{{keyType}}"
            data-bs-toggle="tab" data-bs-target="#tab-creds-{{kmId}}-{{keyType}}"
            aria-controls="tab-creds-{{kmId}}-{{keyType}}" aria-selected="true">
            <i class="bi bi-key"></i> Credentials
        </button>
        <button class="mk-km-tab" type="button" role="tab"
            id="tab-btn-token-{{kmId}}-{{keyType}}"
            data-bs-toggle="tab" data-bs-target="#tab-token-{{kmId}}-{{keyType}}"
            aria-controls="tab-token-{{kmId}}-{{keyType}}" aria-selected="false">
            <i class="bi bi-lightning-fill"></i> Generate Token
        </button>
        <button class="mk-km-tab" type="button" role="tab"
            id="tab-btn-curl-{{kmId}}-{{keyType}}"
            data-bs-toggle="tab" data-bs-target="#tab-curl-{{kmId}}-{{keyType}}"
            aria-controls="tab-curl-{{kmId}}-{{keyType}}" aria-selected="false">
            <i class="bi bi-terminal"></i> cURL
        </button>
    </div>

    {{!-- Tab content — only rendered when credentials exist --}}
    <div class="tab-content mk-km-tab-content" id="consumerKeyContainer-{{keyType}}"
        style="{{#unless keys.consumerKey}}display:none{{/unless}}">

        {{!-- ── Credentials tab ── --}}
        <div class="tab-pane fade show active" id="tab-creds-{{kmId}}-{{keyType}}"
            role="tabpanel" aria-labelledby="tab-btn-creds-{{kmId}}-{{keyType}}" tabindex="0">
            <div class="mk-km-body">
                <div class="mk-cred-grid mk-cred-grid-single">
                    <div class="mk-field" id="consumerKey-{{keyType}}-view">
                        <label class="mk-field-label">Consumer Key (Client ID)</label>
                        <div class="mk-input-row">
                            <input type="text" id="consumer-key-{{kmId}}-{{keyType}}-view"
                                class="mk-input" name="consumerKey-{{keyType}}"
                                value="{{keys.consumerKey}}" readonly disabled />
                            <button class="mk-icon-btn copy-btn"
                                onclick="copyConsumerKey('consumer-key-{{kmId}}-{{keyType}}-view')" title="Copy">
                                <span class="copy-btn-icon"><i class="bi bi-copy"></i></span>
                                <span class="copy-btn-check"><i class="bi bi-check"></i> Copied</span>
                            </button>
                        </div>
                        <input type="hidden" id="app-ref-{{kmId}}-{{keyType}}" name="appRefId" value="{{keys.appRefId}}" />
                        <input type="hidden" id="key-map-{{kmId}}-{{keyType}}" name="keyMappingId" value="{{keys.keyMappingId}}" />
                    </div>
                </div>
            </div>
            {{!-- Revoke footer — part of Credentials tab --}}
            <div class="mk-km-footer" id="keyActionsContainer-{{keyType}}">
                <span class="mk-secret-note">
                    <i class="bi bi-info-circle"></i>
                    Revoking removes all credentials. Tokens already issued remain valid until they expire.
                </span>
                <div class="mk-footer-actions">
                    <button class="mk-btn-danger {{#if isReadOnlyMode}}disabled{{/if}}"
                        style="{{#if isReadOnlyMode}}pointer-events:none;opacity:.5{{/if}}"
                        onclick="confirmAndRevokeKeys('{{appId}}', '{{keys.keyMappingId}}', '{{keyType}}')">
                        <i class="bi bi-trash3"></i> Revoke keys
                    </button>
                </div>
            </div>
        </div>

        {{!-- ── Generate Token tab ── --}}
        <div class="tab-pane fade" id="tab-token-{{kmId}}-{{keyType}}"
            role="tabpanel" aria-labelledby="tab-btn-token-{{kmId}}-{{keyType}}" tabindex="0">
            <div class="mk-token-form mk-km-body">
                <div class="mk-field mk-field-wide">
                    <label class="mk-field-label">Request Permissions (Scopes)</label>
                    <div class="input-scopes mk-scope-input"
                        id="scopeContainer-{{appId}}-{{keyType}}"
                        data-scopes="{{json subscriptionScopes}}">
                        <input type="text" class="text-input"
                            id="scope-{{appId}}-{{keyType}}"
                            placeholder="Type scope and press Enter…">
                    </div>
                </div>
                <form id="inlineTokenForm-{{kmId}}-{{keyType}}" style="display:none"></form>
                <div class="mk-token-actions">
                    <button id="tokenKeyBtn-{{keyType}}"
                        class="mk-btn-primary {{#if isReadOnlyMode}}disabled{{/if}}"
                        data-app-id="{{appId}}"
                        data-keymappingid="{{keys.keyMappingId}}"
                        style="{{#if isReadOnlyMode}}pointer-events:none;opacity:.5{{/if}}"
                        onclick="openGenerateTokenModal('inlineTokenForm-{{kmId}}-{{keyType}}', '{{appId}}', '{{keys.keyMappingId}}', '{{kmName}}', '{{appName}}', '{{json subscriptionScopes}}', '{{keyType}}')">
                        <span class="button-normal-state"><i class="bi bi-lightning-fill"></i> Generate access token</span>
                        <span class="button-loading-state" style="display:none">
                            <span class="spinner-border spinner-border-sm" role="status"></span> Generating…
                        </span>
                    </button>
                    <span class="mk-token-note">Uses the consumer key &amp; secret of this key set.</span>
                </div>
            </div>
        </div>

        {{!-- ── cURL tab ── --}}
        <div class="tab-pane fade" id="tab-curl-{{kmId}}-{{keyType}}"
            role="tabpanel" aria-labelledby="tab-btn-curl-{{kmId}}-{{keyType}}" tabindex="0">
            <div class="mk-curl-body mk-km-body">
                <p class="mk-curl-desc">Use the following cURL command to generate an access token with the client credentials grant type.</p>
                <div class="mk-curl-details">
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Token Endpoint</span>
                        <code class="mk-curl-value">{{tokenEndpoint}}</code>
                    </div>
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Authorization</span>
                        <code class="mk-curl-value">Basic Base64(consumer_key:consumer_secret)</code>
                    </div>
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Content-Type</span>
                        <code class="mk-curl-value">application/x-www-form-urlencoded</code>
                    </div>
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Payload</span>
                        <code class="mk-curl-value">grant_type=client_credentials</code>
                    </div>
                </div>
                <div class="mk-code-block">
                    <button class="mk-curl-copy-btn copy-btn"
                        data-endpoint="{{tokenEndpoint}}"
                        aria-label="Copy cURL command"
                        onclick="copyRealCurl(this)">
                        <span class="copy-btn-icon"><i class="bi bi-copy"></i></span>
                        <span class="copy-btn-check"><i class="bi bi-check"></i> Copied</span>
                    </button>
                    <code id="curl_{{kmName}}_{{keyType}}">curl -k -X POST &lt;TOKEN_ENDPOINT_URL&gt; -d "grant_type=client_credentials" -H "Authorization: Basic Base64(&lt;CONSUMER_KEY&gt;:&lt;CONSUMER_SECRET&gt;)"</code>
                </div>
            </div>
        </div>

    </div>{{!-- /tab-content --}}

    <div id="keyGenerationErrorContainer-{{keyType}}" class="mk-error" style="display:none"></div>

    {{!-- Empty state — paste an externally-created client_id --}}
    <div class="mk-km-empty" id="generateKeyContainer-{{keyType}}"
        style="{{#if keys.consumerKey}}display:none{{/if}}">
        <div class="mk-empty-icon-wrap {{#if isSandbox}}mk-empty-icon-sandbox{{/if}}">
            <i class="bi bi-key"></i>
        </div>
        <p class="mk-empty-title">No client ID linked yet</p>
        <p class="mk-empty-desc">
            Create an OAuth application directly in <strong>{{kmName}}</strong>, then paste its client ID below to
            link it to this application.
        </p>
        <div id="addClientIdError-{{kmId}}-{{keyType}}" class="mk-error" style="display:none"></div>
        <div class="mk-add-clientid-row">
            <input type="text" class="mk-input" id="addClientIdInput-{{kmId}}-{{keyType}}"
                placeholder="Paste client ID" {{#if isReadOnlyMode}}disabled{{/if}} />
            <button data-cyid="addClientId-{{keyType}}" id="addClientIdBtn-{{kmId}}-{{keyType}}"
                class="mk-btn-primary {{#if isSandbox}}mk-btn-sandbox{{/if}} {{#if isReadOnlyMode}}disabled{{/if}}"
                style="{{#if isReadOnlyMode}}pointer-events:none;opacity:.5{{/if}}"
                {{#if isReadOnlyMode}}disabled{{/if}}
                onclick="addClientId('{{kmId}}', '{{keyType}}', '{{appId}}', '{{orgId}}', '{{kmName}}')">
                <span class="button-normal-state"><i class="bi bi-plus-lg me-1"></i>Add</span>
                <span class="button-loading-state" style="display:none">
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>Adding…
                </span>
            </button>
        </div>
    </div>
</div>
