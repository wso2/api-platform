<div class="mk-km-card {{#if isSandbox}}mk-km-card-sandbox{{/if}}">

    {{!-- Card header --}}
    <div class="mk-km-header">
        <div class="mk-km-icon {{#if isSandbox}}mk-km-icon-sandbox{{/if}}">
            <i class="bi bi-key-fill"></i>
        </div>
        <div class="mk-km-info">
            <span class="mk-km-name">{{kmName}}</span>
            {{#if kmType}}<span class="mk-km-type">{{kmType}}</span>{{/if}}
        </div>
        <span class="mk-km-badge {{#if isSandbox}}mk-km-badge-sandbox{{/if}}">
            <span class="mk-km-badge-dot"></span> Active
        </span>
    </div>

    {{!-- Inner tab nav — only visible when credentials exist --}}
    <div class="mk-km-tabnav" id="keyTabNav-{{keyType}}" role="tablist"
        style="{{#unless keys.consumerKey}}display:none{{/unless}}">
        <button class="mk-km-tab active" type="button" role="tab"
            id="tab-btn-creds-{{kmId}}-{{keyType}}"
            data-bs-toggle="tab" data-bs-target="#tab-creds-{{kmId}}-{{keyType}}"
            aria-controls="tab-creds-{{kmId}}-{{keyType}}" aria-selected="true">
            <i class="bi bi-key"></i> Credentials
        </button>
        <button class="mk-km-tab" type="button" role="tab"
            id="tab-btn-config-{{kmId}}-{{keyType}}"
            data-bs-toggle="tab" data-bs-target="#tab-config-{{kmId}}-{{keyType}}"
            aria-controls="tab-config-{{kmId}}-{{keyType}}" aria-selected="false">
            <i class="bi bi-gear"></i> Configuration
        </button>
        <button class="mk-km-tab" type="button" role="tab"
            id="tab-btn-token-{{kmId}}-{{keyType}}"
            data-bs-toggle="tab" data-bs-target="#tab-token-{{kmId}}-{{keyType}}"
            aria-controls="tab-token-{{kmId}}-{{keyType}}" aria-selected="false">
            <i class="bi bi-lightning-fill"></i> Generate Token
        </button>
        <button class="mk-km-tab" type="button" role="tab"
            id="tab-btn-curl-{{kmId}}-{{keyType}}"
            data-bs-toggle="tab" data-bs-target="#tab-curl-{{kmId}}-{{keyType}}"
            aria-controls="tab-curl-{{kmId}}-{{keyType}}" aria-selected="false">
            <i class="bi bi-terminal"></i> cURL
        </button>
    </div>

    {{!-- Tab content — only rendered when credentials exist --}}
    <div class="tab-content mk-km-tab-content" id="consumerKeyContainer-{{keyType}}"
        style="{{#unless keys.consumerKey}}display:none{{/unless}}">

        {{!-- ── Credentials tab ── --}}
        <div class="tab-pane fade show active" id="tab-creds-{{kmId}}-{{keyType}}"
            role="tabpanel" aria-labelledby="tab-btn-creds-{{kmId}}-{{keyType}}" tabindex="0">
            <div class="mk-km-body">
                <div class="mk-cred-grid mk-cred-grid-single">
                    <div class="mk-field" id="consumerKey-{{keyType}}-view">
                        <label class="mk-field-label">Consumer Key (Client ID)</label>
                        <div class="mk-input-row">
                            <input type="text" id="consumer-key-{{kmId}}-{{keyType}}-view"
                                class="mk-input" name="consumerKey-{{keyType}}"
                                value="{{keys.consumerKey}}" readonly disabled />
                            <button class="mk-icon-btn"
                                onclick="copyConsumerKey('consumer-key-{{kmId}}-{{keyType}}-view')" title="Copy">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                        <input type="hidden" id="app-ref-{{kmId}}-{{keyType}}" name="appRefId" value="{{keys.appRefId}}" />
                        <input type="hidden" id="key-map-{{kmId}}-{{keyType}}" name="keyMappingId" value="{{keys.keyMappingId}}" />
                    </div>
                </div>
            </div>
            {{!-- Revoke footer — part of Credentials tab --}}
            <div class="mk-km-footer" id="keyActionsContainer-{{keyType}}">
                <span class="mk-secret-note">
                    <i class="bi bi-info-circle"></i>
                    Revoking removes all credentials. Tokens already issued remain valid until they expire.
                </span>
                <div class="mk-footer-actions">
                    <button class="mk-btn-danger {{#if isReadOnlyMode}}disabled{{/if}}"
                        style="{{#if isReadOnlyMode}}pointer-events:none;opacity:.5{{/if}}"
                        onclick="confirmAndRevokeKeys('{{appId}}', '{{keys.keyMappingId}}', '{{keyType}}')">
                        <i class="bi bi-trash3"></i> Revoke keys
                    </button>
                </div>
            </div>
        </div>

        {{!-- ── Configuration tab ── --}}
        <div class="tab-pane fade" id="tab-config-{{kmId}}-{{keyType}}"
            role="tabpanel" aria-labelledby="tab-btn-config-{{kmId}}-{{keyType}}" tabindex="0">

            {{!-- Read-only view --}}
            <div id="configView-{{kmId}}-{{keyType}}">
                <div class="mk-config-body">
                    {{!-- Grant types --}}
                    {{#if keys.supportedGrantTypes}}
                    <div class="mk-config-row">
                        <span class="mk-config-label">Grant types</span>
                        <div class="mk-config-value mk-meta-grants">
                            {{#let "supported" keys.supportedGrantTypes}}
                            {{#each ../availableGrantTypes}}
                            {{#if (contains ../supported name)}}
                            <span class="mk-grant-pill">{{label}}</span>
                            {{/if}}
                            {{/each}}
                            {{/let}}
                        </div>
                    </div>
                    {{/if}}
                    {{!-- Callback URL --}}
                    {{#if keys.callbackUrl}}
                    <div class="mk-config-row">
                        <span class="mk-config-label">Callback URL</span>
                        <code class="mk-config-code">{{keys.callbackUrl}}</code>
                    </div>
                    {{/if}}
                    {{!-- Additional key manager properties (read-only) --}}
                    {{#if applicationConfiguration}}
                    {{#let "additionalProperties" (conditionalIf keys.additionalProperties keys.additionalProperties [])}}
                    {{#each ../applicationConfiguration}}
                    <div class="mk-config-row">
                        <span class="mk-config-label">{{label}}</span>
                        <div class="mk-config-value">
                            {{#if (eq type "checkbox")}}
                                <span class="mk-grant-pill">
                                    {{#if (getValue ../additionalProperties name)}}Enabled{{else}}Disabled{{/if}}
                                </span>
                            {{else}}
                                {{#if (eq type "select")}}
                                    {{#if multiple}}
                                        {{#each (getValue ../additionalProperties name)}}
                                        <span class="mk-grant-pill">{{this}}</span>
                                        {{/each}}
                                    {{else}}
                                        <span class="mk-config-text">{{conditionalIf (getValue ../additionalProperties name) (getValue ../additionalProperties name) default}}</span>
                                    {{/if}}
                                {{else}}
                                    <span class="mk-config-text">{{conditionalIf (getValue ../additionalProperties name) (getValue ../additionalProperties name) default}}</span>
                                {{/if}}
                            {{/if}}
                        </div>
                    </div>
                    {{/each}}
                    {{/let}}
                    {{/if}}
                </div>
                <div class="mk-config-footer">
                    <span class="mk-config-note">Changes to grant types or callback URL take effect on the next token request.</span>
                    {{#unless isReadOnlyMode}}
                    <button class="mk-btn-primary mk-btn-sm"
                        id="editConfigBtn-{{kmId}}-{{keyType}}"
                        onclick="startEditConfiguration('{{kmId}}', '{{keyType}}')">
                        <i class="bi bi-gear"></i> Edit configuration
                    </button>
                    {{/unless}}
                </div>
            </div>

            {{!-- Inline edit form (hidden by default) --}}
            <div id="configEdit-{{kmId}}-{{keyType}}" style="display:none">
                <form id="inlineConfigForm-{{kmId}}-{{keyType}}" class="mk-edit-form">

                    {{!-- Grant types --}}
                    <div class="mk-edit-section">
                        <label class="mk-edit-label">Grant types <span class="text-danger">*</span></label>
                        <div class="mk-grant-grid">
                            {{#let "supportedGrantTypes" keys.supportedGrantTypes}}
                            {{#each ../availableGrantTypes}}
                            <label class="mk-grant-card" for="grant-type-edit-{{name}}-{{../kmId}}-{{../keyType}}">
                                <input type="checkbox"
                                    id="grant-type-edit-{{name}}-{{../kmId}}-{{../keyType}}"
                                    name="grantTypes" value="{{name}}"
                                    {{#if (contains ../supportedGrantTypes name)}} checked {{else}}
                                        {{#unless ../supportedGrantTypes.length}}
                                        {{#if (eq name "client_credentials")}} checked {{/if}}
                                        {{/unless}}
                                    {{/if}} />
                                <span>{{label}}</span>
                            </label>
                            {{/each}}
                            {{/let}}
                        </div>
                    </div>

                    {{!-- Callback URL --}}
                    <div class="mk-edit-section" id="callback-url-row-{{keyType}}">
                        <label class="mk-edit-label">Callback URL</label>
                        <input type="url" name="callbackURL" class="mk-edit-input"
                            placeholder="https://your-app.com/callback"
                            value="{{keys.callbackUrl}}" />
                    </div>

                    {{!-- Additional key manager properties --}}
                    {{#if applicationConfiguration}}
                    {{#let "additionalProperties" (conditionalIf keys.additionalProperties keys.additionalProperties [])}}
                    <div class="mk-edit-props-grid">
                    {{#each ../applicationConfiguration}}
                        {{#if (eq type "checkbox")}}
                        {{!-- Checkboxes span full width --}}
                        <div class="mk-edit-section mk-edit-full-width">
                            <label class="mk-edit-label" for="addprop-{{name}}-{{../../keyType}}">
                                {{label}}
                            </label>
                            <div class="mk-check-item">
                                <input type="checkbox" name="additionalProperties.{{name}}"
                                    id="addprop-{{name}}-{{../../keyType}}"
                                    value="true" {{#if (getValue ../additionalProperties name)}}checked{{/if}} />
                                {{#if tooltip}}<span class="mk-field-hint mk-check-hint">{{tooltip}}</span>{{/if}}
                            </div>
                        </div>
                        {{else}}
                        <div class="mk-edit-section">
                            <label class="mk-edit-label" for="addprop-{{name}}-{{../../keyType}}">
                                {{label}}{{#if required}} <span class="text-danger">*</span>{{/if}}
                            </label>
                            {{#if (eq type "select")}}
                                {{#if multiple}}
                                <select name="additionalProperties.{{name}}"
                                    id="addprop-{{name}}-{{../../keyType}}"
                                    class="mk-edit-input" multiple>
                                    {{#each values}}
                                    <option {{#in this values=(getValue ../../additionalProperties ../name)}}selected{{/in}}>{{this}}</option>
                                    {{/each}}
                                </select>
                                {{else}}
                                <select name="additionalProperties.{{name}}"
                                    id="addprop-{{name}}-{{../../keyType}}"
                                    class="mk-edit-input" {{#if required}}required{{/if}}>
                                    {{#each values}}
                                    <option value="{{this}}" {{#if (eq (getValue ../../additionalProperties ../name) this)}}selected{{/if}}>{{this}}</option>
                                    {{/each}}
                                </select>
                                {{/if}}
                            {{else}}
                            <input type="text" name="additionalProperties.{{{name}}}"
                                id="addprop-{{name}}-{{../../keyType}}"
                                class="mk-edit-input"
                                value="{{conditionalIf (getValue ../additionalProperties name) (getValue ../additionalProperties name) default}}"
                                {{#if required}}required{{/if}} />
                            {{/if}}
                            {{#if tooltip}}<div class="mk-field-hint">{{tooltip}}</div>{{/if}}
                        </div>
                        {{/if}}
                    {{/each}}
                    </div>
                    {{/let}}
                    {{/if}}

                </form>
                <div class="mk-config-footer">
                    <span></span>
                    <div class="mk-footer-actions">
                        <button class="mk-btn-outline mk-btn-sm"
                            onclick="cancelEditConfiguration('{{kmId}}', '{{keyType}}')">
                            Cancel
                        </button>
                        <button class="mk-btn-primary mk-btn-sm"
                            id="saveConfigBtn-{{kmId}}-{{keyType}}"
                            onclick="saveInlineKeyConfig('{{kmId}}', '{{keyType}}', '{{appId}}', '{{kmName}}', '{{keys.keyMappingId}}', '{{keys.clientName}}', '{{keys.consumerKey}}')">
                            <i class="bi bi-check2"></i> Save changes
                        </button>
                    </div>
                </div>
            </div>
            <div id="keyUpdateErrorContainer-{{keyType}}" class="mk-error" style="display:none"></div>
        </div>

        {{!-- ── Generate Token tab ── --}}
        <div class="tab-pane fade" id="tab-token-{{kmId}}-{{keyType}}"
            role="tabpanel" aria-labelledby="tab-btn-token-{{kmId}}-{{keyType}}" tabindex="0">
            <div class="mk-token-form mk-km-body">
                <div class="mk-field mk-field-wide">
                    <label class="mk-field-label">Request Permissions (Scopes)</label>
                    <div class="input-scopes mk-scope-input"
                        id="scopeContainer-{{appId}}-{{keyType}}"
                        data-scopes="{{json subscriptionScopes}}">
                        <input type="text" class="text-input"
                            id="scope-{{appId}}-{{keyType}}"
                            placeholder="Type scope and press Enter…">
                    </div>
                </div>
                <form id="inlineTokenForm-{{kmId}}-{{keyType}}" style="display:none"></form>
                <div class="mk-token-actions">
                    <button id="tokenKeyBtn-{{keyType}}"
                        class="mk-btn-primary {{#if isReadOnlyMode}}disabled{{/if}}"
                        data-app-id="{{appId}}"
                        data-keymappingid="{{keys.keyMappingId}}"
                        style="{{#if isReadOnlyMode}}pointer-events:none;opacity:.5{{/if}}"
                        onclick="openGenerateTokenModal('inlineTokenForm-{{kmId}}-{{keyType}}', '{{appId}}', '{{keys.keyMappingId}}', '{{kmName}}', '{{appName}}', '{{json subscriptionScopes}}', '{{keyType}}')">
                        <span class="button-normal-state"><i class="bi bi-lightning-fill"></i> Generate access token</span>
                        <span class="button-loading-state" style="display:none">
                            <span class="spinner-border spinner-border-sm" role="status"></span> Generating…
                        </span>
                    </button>
                    <span class="mk-token-note">Uses the consumer key &amp; secret of this key set.</span>
                </div>
            </div>
        </div>

        {{!-- ── cURL tab ── --}}
        <div class="tab-pane fade" id="tab-curl-{{kmId}}-{{keyType}}"
            role="tabpanel" aria-labelledby="tab-btn-curl-{{kmId}}-{{keyType}}" tabindex="0">
            <div class="mk-curl-body mk-km-body">
                <p class="mk-curl-desc">Use the following cURL command to generate an access token with the client credentials grant type.</p>
                <div class="mk-curl-details">
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Token Endpoint</span>
                        <code class="mk-curl-value">{{tokenEndpoint}}</code>
                    </div>
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Authorization</span>
                        <code class="mk-curl-value">Basic Base64(consumer_key:consumer_secret)</code>
                    </div>
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Content-Type</span>
                        <code class="mk-curl-value">application/x-www-form-urlencoded</code>
                    </div>
                    <div class="mk-curl-row">
                        <span class="mk-curl-label">Payload</span>
                        <code class="mk-curl-value">grant_type=client_credentials</code>
                    </div>
                </div>
                <div class="mk-code-block">
                    <button class="mk-curl-copy-btn"
                        data-endpoint="{{tokenEndpoint}}"
                        aria-label="Copy cURL command"
                        onclick="copyRealCurl(this)">
                        <i class="bi bi-copy"></i>
                    </button>
                    <code id="curl_{{kmName}}_{{keyType}}">curl -k -X POST &lt;TOKEN_ENDPOINT_URL&gt; -d "grant_type=client_credentials" -H "Authorization: Basic Base64(&lt;CONSUMER_KEY&gt;:&lt;CONSUMER_SECRET&gt;)"</code>
                </div>
            </div>
        </div>

    </div>{{!-- /tab-content --}}

    <div id="keyGenerationErrorContainer-{{keyType}}" class="mk-error" style="display:none"></div>

    {{!-- Empty state --}}
    <div class="mk-km-empty" id="generateKeyContainer-{{keyType}}"
        style="{{#if keys.consumerKey}}display:none{{/if}}">
        <div class="mk-empty-icon-wrap {{#if isSandbox}}mk-empty-icon-sandbox{{/if}}">
            <i class="bi bi-key"></i>
        </div>
        <p class="mk-empty-title">No credentials generated yet</p>
        <p class="mk-empty-desc">
            {{#if isSandbox}}
            Generate sandbox credentials to test your application's authentication before going live.
            {{else}}
            Generate credentials to start authenticating your application with the production environment.
            {{/if}}
        </p>
        <button data-cyid="generateKey-{{keyType}}" id="generateKeyBtn-{{keyType}}"
            class="mk-btn-primary {{#if isSandbox}}mk-btn-sandbox{{/if}} {{#if isReadOnlyMode}}disabled{{/if}}"
            style="{{#if isReadOnlyMode}}pointer-events:none;opacity:.5{{/if}}"
            onclick="generateApplicationKey('keysview-{{kmId}}-{{keyType}}', '{{appId}}', '{{keyType}}', '{{kmName}}', '{{appName}}', '[]', '{{orgID}}', 'consumer-key-{{kmId}}-{{keyType}}', 'consumer-secret-{{kmId}}-{{keyType}}')">
            <span class="button-normal-state"><i class="bi bi-key me-1"></i>Generate Credentials</span>
            <span class="button-loading-state" style="display:none">
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>Generating…
            </span>
        </button>
    </div>
</div>
