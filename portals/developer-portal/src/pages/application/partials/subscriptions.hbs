<div class="row">
    {{#each apis}}
    {{#if isSubAvailable}}
    <div class="dev-card custom-plans-card" onclick="handleCardClick('{{../baseUrl}}/api/{{this.name}}')">
        <div class="card-header">
            <h2 id="apiName" data-id="{{this.id}}"> <a href="{{../baseUrl}}/api/{{this.name}}">{{this.name}}</a></h2>
        </div>
        {{subscribedPlan.length}}
        {{#if subscribedPlan}}
        <h6 class="dev-header h6">Subscribed Plan:
            <ul class="plan-label">
                <li>{{subscribedPlan.plan}}</li>
        </h6>
        <button class="common-btn-outlined mt-2" data-unsubscribe-id="{{subscribedPlan.id}}" data-api-id="{{this.id}}" data-org-id="{{../orgId}}" data-app-id="{{../applicationMetadata.id}}" data-api-ref-id="{{this.id}}">Unsubscribe</button>

        {{else}}
        <select id="subscriptionPlan" class="form-control items-label sub-api-card-item">
            {{#each subscriptionPlans}}
            <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
        <button class="common-btn-primary mt-1" onclick="handleSubscribe(null, '{{this.name}}', '{{this.version}}', '{{this.id}}')">Subscribe</button>
        {{/if}}
    </div>
    {{/if}}
    {{/each}}
</div>