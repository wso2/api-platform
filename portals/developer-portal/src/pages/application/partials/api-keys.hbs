<div id="application-api-keys-config" style="display:none"
    data-org-id="{{orgId}}"
    data-app-id="{{applicationMetadata.id}}"
    data-read-only="{{#if isReadOnlyMode}}true{{else}}false{{/if}}"
    data-available-keys-by-api="{{json availableKeysByApi}}">
</div>

<section class="section mb-6">
  <div class="d-flex justify-content-between align-items-start mb-3">
    <div>
      <h2 class="h5 mb-1">API keys</h2>
      <p class="ak-page-desc" style="margin:0;font-size:0.84375rem;color:#56657a;">
        Keys associated with this app, for usage analytics only — association has no effect on a key's validity.
      </p>
    </div>
    {{#unless isReadOnlyMode}}
    <button type="button" class="dp-btn dp-btn--outline" id="btn-open-associate-key">
      <i class="bi bi-plus"></i> Associate existing key
    </button>
    {{/unless}}
  </div>

  {{#if associatedApiKeys.length}}
  <div class="ak-tablewrap">
    <table class="ak-table" id="application-api-keys-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>API</th>
          <th>Status</th>
          <th class="ak-th-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each associatedApiKeys}}
        <tr>
          <td><span class="ak-key-name">{{this.name}}</span></td>
          <td>{{this.apiName}}</td>
          <td>
            <span class="ak-status {{#if (eq this.status 'active')}}ak-status--active{{else}}ak-status--inactive{{/if}}">
              <span class="ak-status-dot"></span>{{this.status}}
            </span>
          </td>
          <td>
            {{#unless @root.isReadOnlyMode}}
            <div class="ak-actions">
              <button type="button" class="ak-btn-revoke btn-remove-key-association" data-key-id="{{this.keyId}}" data-api-id="{{this.apiId}}" data-key-name="{{this.name}}">
                <i class="bi bi-x-circle"></i> Remove
              </button>
            </div>
            {{/unless}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="dp-empty" id="no-associated-api-keys">
    <span class="dp-empty-icon"><i class="bi bi-key-fill"></i></span>
    <h2 class="dp-empty-title">No API keys associated</h2>
    <p class="dp-empty-desc">Associate an existing API key with this app to attribute its usage in analytics.</p>
  </div>
  {{/if}}
</section>

{{#unless isReadOnlyMode}}
<!-- Associate existing key modal -->
<div class="ak-overlay" id="associate-key-modal">
  <div class="ak-modal">
    <div class="ak-modal-head">
      <h2 class="ak-modal-title">Associate existing key</h2>
      <button type="button" class="ak-modal-close" id="associate-key-close" aria-label="Close"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="ak-modal-body">
      <div class="ak-form-group">
        <label for="associate-key-api-select">API</label>
        <select id="associate-key-api-select" class="ak-form-input">
          <option value="">— Select an API —</option>
        </select>
      </div>
      <div class="ak-form-group">
        <label for="associate-key-select">Key</label>
        <select id="associate-key-select" class="ak-form-input" disabled>
          <option value="">— Select an API first —</option>
        </select>
      </div>
    </div>
    <div class="ak-modal-footer">
      <button type="button" class="dp-btn dp-btn--outline" id="associate-key-cancel">Cancel</button>
      <button type="button" class="dp-btn dp-btn--primary" id="btn-submit-associate-key" disabled>Associate</button>
    </div>
  </div>
</div>
{{/unless}}
