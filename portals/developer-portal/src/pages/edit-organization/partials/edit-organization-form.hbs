<section>
    <form id="editOrg{{name}}" class="editOrg">
        <div class="form-group mb-2">
            <label for="name" class="form-label">Name</label>
            <input type="text" class="form-control orgName" id="name" name="name"
                placeholder="Enter Organization Name" value={{name}}>
        </div>
        <div class="form-group mb-2">
            <label for="business-owner" class="form-label">Business Owner</label>
            <input type="text" class="form-control businessOwner" id="businessOwner" name="businessOwner"
                placeholder="Enter Business Owner Name" value={{businessOwner}}>
        </div>
        <div class="form-group mb-2">
            <label for="business-owner-contact" class="form-label">Business Owner Contact</label>
            <input type="text" class="form-control" id="businessOwnerContact" name="businessOwnerContact"
                placeholder="Enter Business Owner Contact" pattern="\d{10}"
                title="Please enter a valid 10-digit contact number" value={{businessOwnerContact}}>
        </div>
        <div class="form-group mb-2">
            <label for="business-owner-email" class="form-label">Business Owner Email</label>
            <input type="email" class="form-control" id="businessOwnerEmail" name="businessOwnerEmail"
                placeholder="Enter Business Owner Email" title="Please enter a valid email address"
                value={{businessOwnerEmail}}>
        </div>
        <div class="form-group mb-2">
            <label for="id" class="form-label">Org Handle</label>
            <input type="text" class="form-control" id="id" name="id"
                placeholder="Enter organization handle" required value={{id}}>
        </div>
        <div class="form-group mb-2">
            <label for="idpRefId" class="form-label">IDP Reference ID</label>
            <input type="text" class="form-control" id="idpRefId" name="idpRefId"
                placeholder="Enter the org claim value asserted by your Identity Provider" required value={{idpRefId}}>
        </div>
        <div class="form-group mb-4">
            <label for="cpRefId" class="form-label">Control Plane Reference ID</label>
            <input type="text" class="form-control" id="cpRefId" name="cpRefId"
                placeholder="Optional — included in outbound webhook event payloads" value={{cpRefId}}>
        </div>
        <div class="form-group">
            <button type="button" class="btn btn-secondary" id="cancelEditBtn" onclick="hideEditForm('{{id}}')">Cancel</button>
            <button type="button" class="common-btn-outlined" onclick="editOrg('{{id}}', 'editOrg{{name}}')">Save
                Changes</button>
        </div>
    </form>
</section>