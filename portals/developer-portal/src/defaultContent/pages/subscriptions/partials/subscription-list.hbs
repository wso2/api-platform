{{#if subscriptions.length}}
<div class="sub-scroll table-responsive">
  <div class="sub-tablewrap">
    <script>
      window.__tokenMap = window.__tokenMap || {};
      window.__subscriptionOrgID = "{{@root.orgID}}";
    </script>
    <table class="sub-table" id="subscriptions-table">
      <thead>
        <tr>
          <th>API</th>
          <th>Version</th>
          <th>Type</th>
          <th>Plan</th>
          <th>Application</th>
          <th>Status</th>
          <th>Subscription token</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each subscriptions}}
        <tr id="sub-row-{{this.id}}">
          <td>
            <a class="sub-api-link" href="{{../baseUrl}}/api/{{this.apiHandle}}">{{this.apiName}}</a>
          </td>
          <td>{{this.apiVersion}}</td>
          <td>
            <span class="sub-type-pill">{{#if this.type}}{{this.type}}{{else}}Token-based{{/if}}</span>
          </td>
          <td>{{this.planName}}</td>
          <td style="color:#8a98a6;">{{#if this.applicationName}}{{this.applicationName}}{{else}}—{{/if}}</td>
          <td>
            <span class="sub-status-pill {{#if (eq this.status 'ACTIVE')}}sub-status-pill--active{{else}}sub-status-pill--inactive{{/if}}">
              <span class="sub-status-dot"></span>
              {{this.status}}
            </span>
          </td>
          <td>
            <div class="sub-token-wrap">
              <code class="sub-token-code masked-token" id="list-token-{{this.id}}" data-revealed="false">****</code>
              <button class="sub-token-btn" onclick="toggleListTokenVisibility('{{this.id}}')" title="Reveal token">
                <i class="bi bi-eye"></i>
              </button>
              <button class="sub-token-btn" onclick="copySubscriptionToken('{{this.id}}')" title="Copy token">
                <i class="bi bi-copy"></i>
              </button>
            </div>
          </td>
          <td>
            <div class="sub-actions">
              <button class="sub-action-btn sub-action-btn--toggle {{#if @root.isReadOnlyMode}}disabled{{/if}}"
                title="{{#if (eq this.status 'ACTIVE')}}Deactivate{{else}}Activate{{/if}}"
                {{#unless @root.isReadOnlyMode}}onclick="toggleSubscriptionStatus('{{../orgID}}', '{{this.id}}', '{{#if (eq this.status "ACTIVE")}}INACTIVE{{else}}ACTIVE{{/if}}')"{{/unless}}
                {{#if @root.isReadOnlyMode}}disabled{{/if}}>
                {{#if (eq this.status 'ACTIVE')}}<i class="bi bi-pause-circle"></i>{{else}}<i class="bi bi-play-circle"></i>{{/if}}
              </button>
              <button class="sub-action-btn sub-action-btn--delete {{#if @root.isReadOnlyMode}}disabled{{/if}}"
                title="Delete"
                {{#unless @root.isReadOnlyMode}}onclick="prepareDeleteSubscription('{{../orgID}}', '{{this.id}}')"{{/unless}}
                {{#if @root.isReadOnlyMode}}disabled{{/if}}>
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
<div class="sub-empty" id="no-subscriptions" style="display:none;">
  <span class="sub-empty-icon">
    <i class="bi bi-inbox"></i>
  </span>
  <h2 class="sub-empty-title">No subscriptions yet</h2>
  <p class="sub-empty-desc">Subscribe an application to an API or MCP server to start making calls. Your active subscriptions will show up here.</p>
  <button class="sub-empty-btn" disabled title="Backend not wired yet — UI preview only">
    <i class="bi bi-plus"></i> Create subscription
  </button>
</div>
{{else}}
<div class="sub-empty" id="no-subscriptions">
  <span class="sub-empty-icon">
    <i class="bi bi-inbox"></i>
  </span>
  <h2 class="sub-empty-title">No subscriptions yet</h2>
  <p class="sub-empty-desc">Subscribe an application to an API or MCP server to start making calls. Your active subscriptions will show up here.</p>
  <button class="sub-empty-btn" disabled title="Backend not wired yet — UI preview only">
    <i class="bi bi-plus"></i> Create subscription
  </button>
</div>
{{/if}}
