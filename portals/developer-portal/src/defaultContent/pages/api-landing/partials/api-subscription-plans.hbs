<section class="section mt-0 mb-6" id="subscriptionPlans">
    <div class="container-fluid text-center">
        {{#if subscriptionPlans.length}}
            <!-- ===== TOKEN-BASED SUBSCRIPTION UI ===== -->

            <!-- Existing subscriptions for this API -->
            {{#if subscriptions.length}}
            <div class="existing-subscriptions mb-4">
                <div class="container-header mb-4">Subscriptions</div>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Plan</th>
                            <th>Status</th>
                            <th>Subscription Token</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each subscriptions}}
                {{#if @first}}
                <script id="token-map-data" type="application/json">{{{jsonSafeSubscriptions ../subscriptions}}}</script>
                <script>
                    (function() {
                        var data = JSON.parse(document.getElementById('token-map-data').textContent || '[]');
                        window.__tokenMeta = window.__tokenMeta || {};
                        data.forEach(function(sub) {
                            // store only non-sensitive metadata and masked token
                            window.__tokenMeta[sub.subscriptionId] = {
                                maskedToken: sub.maskedToken,
                                customerName: sub.customerName,
                                subscriptionPlanName: sub.subscriptionPlanName,
                                status: sub.status
                            };
                        });
                        // expose orgID for on-demand fetches
                        window.__subscriptionOrgID = "{{@root.orgID}}";
                    })();
                </script>
                {{/if}}
                        <tr>
                            <td>{{this.subscriptionPlanName}}</td>
                            <td>
                                <span class="badge {{#if (eq this.status 'ACTIVE')}}bg-success{{else}}bg-secondary{{/if}}">
                                    {{this.status}}
                                </span>
                            </td>
                            <td>
                                <div class="token-display">
                                    <code class="masked-token" id="token-{{this.subscriptionId}}" data-revealed="false">****</code>
                                    <button class="btn btn-sm btn-outline-secondary" onclick="toggleTokenVisibility('{{this.subscriptionId}}')" title="Reveal token">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" onclick="copySubscriptionToken('{{this.subscriptionId}}')" title="Copy token">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                </div>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-warning {{#if @root.isReadOnlyMode}}disabled{{/if}}" title="{{#if (eq this.status 'ACTIVE')}}Deactivate{{else}}Activate{{/if}}"
                                    {{#unless @root.isReadOnlyMode}}onclick="toggleSubscriptionStatus('{{@root.orgID}}', '{{this.subscriptionId}}', '{{#if (eq this.status "ACTIVE")}}INACTIVE{{else}}ACTIVE{{/if}}')"{{/unless}}
                                    {{#if @root.isReadOnlyMode}}disabled{{/if}}>
                                    {{#if (eq this.status 'ACTIVE')}}<i class="bi bi-pause-circle"></i>{{else}}<i class="bi bi-play-circle"></i>{{/if}}
                                </button>
                                <button class="btn btn-sm btn-outline-danger {{#if @root.isReadOnlyMode}}disabled{{/if}}" title="Delete"
                                    {{#unless @root.isReadOnlyMode}}onclick="confirmDeleteSubscription('{{@root.orgID}}', '{{this.subscriptionId}}')"{{/unless}}
                                    {{#if @root.isReadOnlyMode}}disabled{{/if}}>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{/if}}

            <!-- Subscribe to new plan (token-based, no mandatory app) -->
            {{#if subscriptionPlans.length}}
            <div class="container-header mb-4">Subscription Plans</div>
            {{/if}}
            <div class="row row-gap-4 justify-content-center align-items-start">
                {{#each subscriptionPlans}}
                <div class="col-lg-4 col-md-6 col-12" id="subscriptionCard-{{policyID}}">
                    <div class="card dev-card subscription-card">
                        <div class="card-body align-items-center text-center p-0">
                            <span class="subscription-plans-card-title">{{displayName}}</span>
                            <h1 class="subscription-plans-request-count">{{requestCount}}</h1>
                            <p class="subscription-plans-card-subtitle pt-0">requests per minute</p>
                        </div>
                        <div class="position-relative">
                            {{#if ../isAuthenticated}}
                            {{#if (isCurrentPlan policyName @root.subscriptions)}}
                            <button type="button"
                                class="common-btn-primary subscribe-btn w-100 disabled current-plan-btn"
                                data-org-id="{{@root.orgID}}"
                                data-api-id="{{../apiMetadata.apiID}}"
                                data-policy-name="{{policyName}}"
                                data-display-name="{{displayName}}"
                                disabled>Current Plan</button>
                            {{else}}
                            <button id="subscribe-btn-{{policyID}}" type="button"
                                class="common-btn-primary subscribe-btn w-100 {{#if @root.isReadOnlyMode}}disabled{{/if}}"
                                data-org-id="{{@root.orgID}}"
                                data-api-id="{{../apiMetadata.apiID}}"
                                data-policy-id="{{policyID}}"
                                data-policy-name="{{policyName}}"
                                data-display-name="{{displayName}}"
                                onclick="handlePlanSubscription(this)"
                                >Subscribe</button>
                            {{/if}}
                            {{else}}
                            <a type="button" class="common-btn-primary w-100 subscription-plan-subscribe-btn"
                                href="{{@root.baseUrl}}/login">Subscribe</a>
                            {{/if}}
                            <div class="message-overlay hidden">
                                <div class="message-content">
                                    <i class="bi message-icon"></i>
                                    <p class="message-text"></p>
                                </div>
                                <button type="button" class="close-message" aria-label="Close">&times;</button>
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>

            <script id="existing-subs-data" type="application/json">{{{json subscriptions}}}</script>
            <script>
                (function() {
                    window.__subscriptionOrgID = window.__subscriptionOrgID || "{{@root.orgID}}";
                    var raw = document.getElementById('existing-subs-data').textContent || '[]';
                    try {
                        var parsed = JSON.parse(raw);
                        window.existingSubscriptions = parsed.map(function(sub) {
                            return { subscriptionId: sub.subscriptionId, subscriptionPlanName: sub.subscriptionPlanName, status: sub.status };
                        });
                    } catch (e) {
                        window.existingSubscriptions = [];
                    }
                })();
            </script>
            {{else}}
            {{!-- API without subscription plans: no subscription needed --}}
            {{/if}}
    </div>
</section>
