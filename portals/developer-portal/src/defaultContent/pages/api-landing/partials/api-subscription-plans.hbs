{{#if subscriptionPlans.length}}
<section id="subscriptionPlans" class="aov-plans-wrap" data-org-id="{{@root.orgId}}">

  <h2 class="aov-plans-title">Subscription plans</h2>

  {{#each subscriptionPlans}}
  <div class="aov-plan-card subscription-card{{#if (isCurrentPlan id @root.subscriptions)}} aov-plan-card--subscribed{{/if}}"
    id="subscriptionCard-{{id}}"
    data-policy-name="{{id}}">
    <div class="aov-plan-ribbon" aria-hidden="true">
      <div class="aov-plan-ribbon-label api-ribbon-label">SUBSCRIBED</div>
    </div>
    <div class="aov-plan-card-head">
      <div class="aov-plan-name-row">
        <span class="aov-plan-icon" style="background:#eef1f5;color:#3a4f6a;">
          <i class="bi bi-lightning-charge-fill"></i>
        </span>
        <span class="aov-plan-name">{{#if displayName}}{{displayName}}{{else}}{{id}}{{/if}}</span>
      </div>
      {{#unless (isCurrentPlan id @root.subscriptions)}}
      <span class="aov-recommended-badge" style="display:none;">RECOMMENDED</span>
      {{/unless}}
    </div>
    <div class="aov-plan-limit">
      {{#if limits.length}}{{#each limits}}
      <span class="aov-plan-count">{{#if (eq limitCount -1)}}∞{{else}}{{limitCount}}{{/if}}</span>
      <span class="aov-plan-unit">{{limitTypeLabel limitType}}{{#if timeUnit}} / {{#unless (eq timeAmount 1)}}{{timeAmount}} {{/unless}}{{timeUnitLabel timeUnit}}{{/if}}</span>
      {{/each}}{{else if requestCount}}
      <span class="aov-plan-count">{{requestCount}}</span>
      <span class="aov-plan-unit">requests / min</span>
      {{else}}
      <span class="aov-plan-count">—</span>
      {{/if}}
    </div>
    <div class="position-relative">
      {{#if ../isAuthenticated}}
        {{#if (isCurrentPlan id @root.subscriptions)}}
        <button type="button"
          class="dp-btn dp-btn--outline dp-btn--block mcp-view-sub-btn api-view-sub-btn"
          data-org-id="{{@root.orgId}}"
          data-api-id="{{../apiMetadata.id}}"
          data-policy-name="{{id}}"
          data-display-name="{{displayName}}">
          <i class="bi bi-eye"></i> View subscription
        </button>
        {{else}}
        <button id="subscribe-btn-{{id}}" type="button"
          class="dp-btn dp-btn--outline dp-btn--block subscribe-btn"
          data-org-id="{{@root.orgId}}"
          data-api-id="{{../apiMetadata.id}}"
          data-plan-id="{{id}}"
          data-plan-name="{{id}}"
          data-display-name="{{displayName}}"
          onclick="handlePlanSubscription(this)"
          ><span class="aov-plan-spinner"></span>Subscribe</button>
        {{/if}}
      {{else}}
      <a class="dp-btn dp-btn--outline dp-btn--block" href="{{@root.baseUrl}}/login">Subscribe</a>
      {{/if}}
    </div>
    <div class="aov-plan-error">
      <i class="bi bi-exclamation-circle-fill" style="color:#c62828;font-size:15px;flex:none;margin-top:1px;"></i>
      <div>
        <div class="aov-plan-error-title">Subscription failed</div>
        <div class="aov-plan-error-desc">We couldn't subscribe you to this plan. Please try again.</div>
      </div>
    </div>
  </div>
  {{/each}}

  <script id="existing-subs-data" type="application/json">{{{json subscriptions}}}</script>
  <script src='/technical-scripts/api-subscription-plans.js' defer></script>
</section>

<!-- Subscription created token modal -->
<div id="apiTokenModal" class="mc-overlay" style="display:none;" role="dialog" aria-modal="true">
  <div class="mc-token-modal">
    <button id="apiTokenModalClose" class="mc-modal-close" aria-label="Close">&times;</button>
    <div class="mc-token-modal-header">
      <div class="mc-token-success-icon">
        <i class="bi bi-check-lg"></i>
      </div>
      <h2 class="mc-token-modal-title">Subscription created</h2>
      <p class="mc-token-modal-sub">Your subscription to the <strong id="apiTokenPlanName"></strong> plan is now active.</p>
    </div>
    <div class="mc-token-modal-body">
      <div class="mc-token-label">
        <i class="bi bi-key" style="color:#637282;"></i>
        <span>Subscription token</span>
      </div>
      <div class="mc-token-field mc-token-field--pink">
        <div id="apiTokenValue" class="mc-token-val mc-token-val--pink"></div>
        <button id="apiTokenCopyBtn" class="copy-btn mc-token-copy-btn" title="Copy token">
          <span class="copy-btn-icon"><i class="bi bi-copy"></i></span>
          <span class="copy-btn-check"><i class="bi bi-check"></i> Copied</span>
        </button>
      </div>
      <div class="mc-token-warning">
        <i class="bi bi-exclamation-triangle-fill" style="color:#b8860b;flex:none;margin-top:1px;"></i>
        <span>Use this token as the <code class="mc-inline-code">Subscription-Key</code> header when invoking the API.</span>
      </div>
      <div class="mc-token-modal-footer">
        <button id="apiTokenModalDone" class="dp-btn dp-btn--primary">Done</button>
      </div>
    </div>
  </div>
</div>

<!-- Manage subscription modal -->
<div id="apiManageModal" class="mc-overlay" style="display:none;" role="dialog" aria-modal="true">
  <div class="mc-manage-modal">
    <div class="mc-manage-header">
      <div class="mc-manage-header-info">
        <span class="mc-manage-plan-icon"><i class="bi bi-lightning-charge-fill"></i></span>
        <div>
          <h2 id="apiManagePlanName" class="mc-manage-plan-name"></h2>
          <div class="mc-manage-subtitle">API subscription</div>
        </div>
      </div>
      <button id="apiManageClose" class="mc-modal-close" aria-label="Close">&times;</button>
    </div>
    <div class="mc-manage-body">
      <div class="mc-manage-status-row">
        <span class="mc-manage-status-label">Status</span>
        <span id="apiManageStatusBadge" class="mc-manage-status-badge mc-manage-status-badge--active">Active</span>
      </div>
      <div class="mc-token-label" style="margin-top:1.25rem;">
        <i class="bi bi-key" style="color:#637282;"></i>
        <span>Subscription token</span>
      </div>
      <div class="mc-token-field mc-token-field--manage">
        <div id="apiManageTokenVal" class="mc-token-val mc-token-val--manage"></div>
        <div class="mc-token-field-actions">
          <button id="apiManageRevealBtn" class="mc-token-action-btn" title="Reveal token">
            <i id="apiManageRevealIcon" class="bi bi-eye"></i>
          </button>
          <button id="apiManageCopyBtn" class="copy-btn mc-token-copy-btn" title="Copy token">
            <span class="copy-btn-icon"><i class="bi bi-copy"></i></span>
            <span class="copy-btn-check"><i class="bi bi-check"></i> Copied</span>
          </button>
        </div>
      </div>
      <p class="mc-config-note" style="margin:0.625rem 0 0;">Use this token as the <code class="mc-inline-code">Subscription-Key</code> header when calling this API.</p>
      <hr class="mc-manage-divider">
      <div class="mc-manage-actions">
        <button id="apiManageSuspendBtn" class="dp-btn mc-manage-action-btn mc-manage-action-btn--suspend">
          <i class="bi bi-pause-circle"></i>
          <span class="api-suspend-label">Suspend</span>
        </button>
        <button id="apiManageUnsubBtn" class="dp-btn mc-manage-action-btn mc-manage-action-btn--unsub">
          <i class="bi bi-trash"></i> Unsubscribe
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Unsubscribe / plan-switch dialog -->
<div id="apiUnsubDialog" class="mc-overlay" style="display:none;" role="dialog" aria-modal="true">
  <div class="mc-unsub-dialog">
    <div class="mc-unsub-header">
      <span class="mc-unsub-icon"><i class="bi bi-exclamation-triangle-fill"></i></span>
      <h2 id="apiUnsubTitle" class="mc-unsub-title">Unsubscribe from plan?</h2>
    </div>
    <p id="apiUnsubDesc" class="mc-unsub-desc">Your applications will lose access to this API and any tokens will stop working. You can re-subscribe at any time.</p>
    <div class="mc-unsub-actions">
      <button id="apiUnsubKeepBtn" class="dp-btn dp-btn--outline">Cancel</button>
      <button id="apiUnsubConfirmBtn" class="dp-btn mc-unsub-confirm-btn">Unsubscribe</button>
    </div>
  </div>
</div>
{{/if}}
