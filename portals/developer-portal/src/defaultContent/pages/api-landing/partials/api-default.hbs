{{!-- Endpoints --}}
<div class="aov-section">
  <div class="aov-section-header">
    <h2 class="aov-section-title">Endpoints</h2>
  </div>
  {{#if (eq resources.serverDetails "")}}
  <div class="aov-endpoint-card">
    <span style="font-size:13px;color:#8a93a0;">No endpoints available</span>
  </div>
  {{else}}
  {{#unless (eq resources.serverDetails.productionURL "")}}
  <div class="aov-endpoint-card">
    <div class="aov-endpoint-label-row">
      <span class="aov-endpoint-dot aov-endpoint-dot--prod"></span>
      <span class="aov-endpoint-label">Production</span>
    </div>
    <div class="aov-endpoint-url-row">
      <i class="bi bi-link-45deg" style="color:#8a93a0;flex:none;"></i>
      <pre id="token_api_prod_url" class="aov-endpoint-url token-text">{{resources.serverDetails.productionURL}}</pre>
      <button type="button" class="copy-btn" title="Copy URL" onclick="copyToken(this, 'api_prod_url')">
        <span class="copy-btn-icon"><i class="bi bi-copy"></i></span>
        <span class="copy-btn-check"><i class="bi bi-check"></i> Copied</span>
      </button>
    </div>
  </div>
  {{/unless}}
  {{#unless (eq apiMetadata.type "MCP")}}
  {{#unless (eq resources.serverDetails.sandboxURL "")}}
  <div class="aov-endpoint-card">
    <div class="aov-endpoint-label-row">
      <span class="aov-endpoint-dot aov-endpoint-dot--sandbox"></span>
      <span class="aov-endpoint-label">Sandbox</span>
    </div>
    <div class="aov-endpoint-url-row">
      <i class="bi bi-link-45deg" style="color:#8a93a0;flex:none;"></i>
      <pre id="token_api_dev_url" class="aov-endpoint-url token-text">{{resources.serverDetails.sandboxURL}}</pre>
      <button type="button" class="copy-btn" title="Copy URL" onclick="copyToken(this, 'api_dev_url')">
        <span class="copy-btn-icon"><i class="bi bi-copy"></i></span>
        <span class="copy-btn-check"><i class="bi bi-check"></i> Copied</span>
      </button>
    </div>
  </div>
  {{/unless}}
  {{/unless}}
  {{/if}}
</div>

{{!-- Resources (REST / MCP) --}}
{{#unless (eq apiMetadata.type "WS")}}
{{#unless (eq apiMetadata.type "WEBSUB")}}
{{#unless (eq apiMetadata.type "GRAPHQL")}}
{{#unless (eq apiMetadata.type "MCP")}}
<div class="aov-section">
  <div class="aov-section-header">
    <h2 class="aov-section-title">Resources</h2>
  </div>
  {{#resources.endpoints}}
  {{#methods}}
  <div class="aov-resource-row">
    <span class="aov-method-badge aov-method-badge--{{method}}">{{method}}</span>
    <span class="aov-resource-path">{{../path}}</span>
    <span class="aov-resource-summary">{{summary}}</span>
  </div>
  {{/methods}}
  {{/resources.endpoints}}
</div>
{{/unless}}
{{/unless}}
{{/unless}}
{{/unless}}

{{!-- Channels (WS) --}}
{{#if (eq apiMetadata.type "WS")}}
<div class="aov-section">
  <div class="aov-section-header">
    <h2 class="aov-section-title">Channels</h2>
  </div>
  {{#each resources.channels}}
  <div class="aov-channel-row">
    <span class="aov-channel-badge aov-channel-badge--pub">PUB</span>
    <span class="aov-channel-badge aov-channel-badge--sub">SUB</span>
    <span class="aov-resource-path">{{name}}</span>
  </div>
  {{/each}}
</div>
{{/if}}

{{!-- Channels (WEBSUB) --}}
{{#if (eq apiMetadata.type "WEBSUB")}}
<div class="aov-section">
  <div class="aov-section-header">
    <h2 class="aov-section-title">Channels</h2>
  </div>
  {{#each resources.channels}}
  <div class="aov-channel-row">
    <span class="aov-channel-badge aov-channel-badge--sub">SUB</span>
    <span class="aov-resource-path">{{name}}</span>
  </div>
  {{/each}}
</div>
{{/if}}

{{!-- Scopes --}}
{{#unless (eq apiMetadata.type "WS")}}
{{#unless (eq apiMetadata.type "WEBSUB")}}
{{#unless (eq apiMetadata.type "GRAPHQL")}}
<div class="aov-section">
  <div class="aov-section-header">
    <h2 class="aov-section-title">Scopes</h2>
  </div>
  {{#if scopes.length}}
  <div>
    {{#scopes}}
    <span class="aov-scope-pill"><i class="bi bi-shield-check" style="margin-right:5px;"></i>{{this.key}}</span>
    {{/scopes}}
  </div>
  {{else}}
  <div class="aov-scopes-empty">
    <i class="bi bi-shield-slash" style="font-size:18px;"></i>
    <span>No scopes are defined for this API.</span>
  </div>
  {{/if}}
</div>
{{/unless}}
{{/unless}}
{{/unless}}
