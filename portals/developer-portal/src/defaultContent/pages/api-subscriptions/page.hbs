    <i class="bi bi-chevron-right dp-breadcrumb-sep"></i>
    <span class="dp-breadcrumb-current">Subscriptions</span>
  </nav>
  <div class="page-header">
    <div>
      <h1 class="page-title">Subscriptions</h1>
    </div>
  </div>
  {{> api-subscription-list }}
</div>
{{> warning modalTitle="Confirm" modalMessage="" modalFunction="" }}
{{> alert }}
