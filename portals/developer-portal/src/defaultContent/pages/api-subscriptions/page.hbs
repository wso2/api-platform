{{#pageHead}}
  <link rel='stylesheet' href='/technical-styles/subscriptions.css' />
{{/pageHead}}
{{#pageScripts}}
  <script src='/technical-scripts/subscriptions-page.js' defer></script>
  <script src='/technical-scripts/subscription.js' defer></script>
{{/pageScripts}}
<div class="page-container">
  <nav class="dp-breadcrumb">
    <a class="dp-breadcrumb-item" href="{{baseUrl}}/apis">APIs</a>
    <i class="bi bi-chevron-right dp-breadcrumb-sep"></i>
