<div class="dp-empty" id="no-subscriptions" style="{{#if subscriptions.length}}display:none;{{/if}}">
    <span class="dp-empty-icon"><i class="bi bi-grid-3x3-gap-fill"></i></span>
    <h2 class="dp-empty-title">No subscriptions yet</h2>
    <p class="dp-empty-desc">No subscriptions found for this API.</p>
  </div>

{{#if subscriptions.length}}
<div class="table-responsive">
    <table class="table table-hover" id="subscriptions-table">
        <thead>
            <tr>
                <th>Plan</th>
                <th>Status</th>
                <th>Subscription Token</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <script>
                window.__tokenMap = window.__tokenMap || {};
                window.__subscriptionOrgID = "{{@root.orgID}}";
            </script>
            {{#each subscriptions}}
            <tr id="sub-row-{{this.id}}">
                <td>{{this.planName}}</td>
                <td>
                    <span class="badge {{#if (eq this.status 'ACTIVE')}}bg-success{{else}}bg-secondary{{/if}}">
                        {{this.status}}
                    </span>
                </td>
                <td>
                    <div class="token-display d-flex align-items-center gap-1">
                        <code class="masked-token" id="list-token-{{this.id}}" data-revealed="false">****</code>
                        <button class="btn btn-sm btn-link p-0" onclick="toggleListTokenVisibility('{{this.id}}')" title="Reveal">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-sm btn-link p-0" onclick="copySubscriptionToken('{{this.id}}')" title="Copy">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                </td>
                <td>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-outline-warning {{#if @root.isReadOnlyMode}}disabled{{/if}}" title="{{#if (eq this.status 'ACTIVE')}}Deactivate{{else}}Activate{{/if}}"
                            {{#unless @root.isReadOnlyMode}}onclick="toggleSubscriptionStatus('{{@root.orgID}}', '{{this.id}}', '{{#if (eq this.status "ACTIVE")}}INACTIVE{{else}}ACTIVE{{/if}}')"{{/unless}}
                            {{#if @root.isReadOnlyMode}}disabled{{/if}}>
                            {{#if (eq this.status 'ACTIVE')}}<i class="bi bi-pause-circle"></i>{{else}}<i class="bi bi-play-circle"></i>{{/if}}
                        </button>
                        <button class="btn btn-sm btn-outline-danger {{#if @root.isReadOnlyMode}}disabled{{/if}}" title="Delete"
                            {{#unless @root.isReadOnlyMode}}onclick="prepareDeleteSubscription('{{@root.orgID}}', '{{this.id}}')"{{/unless}}
                            {{#if @root.isReadOnlyMode}}disabled{{/if}}>
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
{{/if}}
