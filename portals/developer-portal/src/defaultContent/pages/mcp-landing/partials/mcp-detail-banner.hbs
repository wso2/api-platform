<div class="aov-hero">
  <div class="aov-hero-top">
    <div class="aov-hero-thumb">
      {{#if apiMetadata.apiInfo.apiImageMetadata.api-icon}}
      <img class="aov-api-img" src="{{apiMetadata.apiInfo.apiImageMetadata.api-icon}}" alt="{{apiMetadata.apiInfo.apiName}}" />
      {{else}}
      <div class="aov-api-avatar">{{firstTwoLetters (or apiMetadata.apiInfo.apiTitle apiMetadata.apiInfo.apiName)}}</div>
      {{/if}}
    </div>
    <div class="aov-hero-title-row">
      <h1 class="aov-hero-name">{{or apiMetadata.apiInfo.apiTitle apiMetadata.apiInfo.apiName}}</h1>
      <div class="aov-hero-badges">
        {{#if apiMetadata.apiInfo.apiVersion}}
        <span class="dp-badge dp-badge--version">{{apiMetadata.apiInfo.apiVersion}}</span>
        {{/if}}
        <span class="dp-badge dp-badge--mcp"><i class="bi bi-cpu"></i> MCP</span>
      </div>
    </div>
  </div>
  <div class="aov-hero-body">
    {{#if apiMetadata.apiInfo.apiDescription}}
    <p class="aov-hero-desc">{{apiMetadata.apiInfo.apiDescription}}</p>
    {{/if}}
    {{#if apiMetadata.apiInfo.tags}}
    <div class="dp-tags">
      {{#apiMetadata.apiInfo.tags}}
      <span class="dp-tag dp-tag--white">{{this}}</span>
      {{/apiMetadata.apiInfo.tags}}
    </div>
    {{/if}}
    <div class="aov-hero-actions">
      {{#if subscriptionPlans.length}}
        {{#unless subscriptions.length}}
      <a class="dp-btn dp-btn--primary" href="#subscriptionPlans">
        <i class="bi bi-bookmark-plus"></i> Subscribe
      </a>
        {{/unless}}
      {{/if}}
      <a class="dp-btn dp-btn--outline" href="{{baseUrl}}/mcp/{{apiMetadata.apiHandle}}/docs/specification">
        <i class="bi bi-book"></i> Documentation
      </a>
      {{#if subscriptionPlans.length}}
      <a class="dp-btn dp-btn--outline" href="{{baseUrl}}/mcp/{{apiMetadata.apiHandle}}/subscriptions">
        <i class="bi bi-layers"></i> Subscriptions
      </a>
      {{/if}}
      {{#if showApiKeysNav}}
      <a class="dp-btn dp-btn--outline" href="{{baseUrl}}/mcp/{{apiMetadata.apiHandle}}/api-keys">
        <i class="bi bi-key"></i> API Keys
      </a>
      {{/if}}
    </div>
  </div>
</div>
