<div class="mc-config-panel">
  <h2 class="aov-section-title" style="margin-bottom:0.875rem;">MCP Server Configuration</h2>
  <div class="mc-config-block">
    <button type="button" class="copy-btn mc-config-copy" onclick="copyMcpConfig(this, '{{apiMetadata.id}}')" title="Copy configuration">
      <span class="copy-btn-icon"><i class="bi bi-copy"></i></span>
      <span class="copy-btn-check"><i class="bi bi-check"></i> Copied</span>
    </button>
    <pre id="mcp-cfg-{{apiMetadata.id}}" class="mc-config-pre"><code class="language-json">{
  "servers": {
    "{{apiMetadata.name}}": {
      "url": "{{resources.serverDetails.productionURL}}",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ${token}"
      }
    }
  }
}</code></pre>
  </div>
  <p class="mc-config-note">Generate a token using a subscribed application and replace the placeholder.</p>

  {{#if subscriptionPlans.length}}
  <div style="margin-top:1.5rem;">
    {{> mcp-subscription-plans}}
  </div>
  {{/if}}
</div>
