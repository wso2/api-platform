{{#pageHead}}
  <link rel="stylesheet" href="/styles/api-keys.css">
{{/pageHead}}
{{#pageScripts}}
  <script src="/technical-scripts/api-keys-page.js" defer></script>
{{/pageScripts}}

<div id="api-keys-config" style="display:none"
    data-org-id="{{orgID}}"
    data-api-id="{{apiMetadata.apiID}}"
    data-read-only="{{#if isReadOnlyMode}}true{{else}}false{{/if}}"
    data-load-error="{{#if apiKeysLoadError}}true{{else}}false{{/if}}"
    data-applications="{{json applications}}"
    data-selected-app-id="{{selectedAppId}}"
    data-csrf-token="{{csrfToken}}">
</div>

<nav class="dp-breadcrumb">
  <a class="dp-breadcrumb-item" href="{{baseUrl}}/apis">APIs</a>
  <i class="bi bi-chevron-right dp-breadcrumb-sep"></i>
  <a class="dp-breadcrumb-item" href="{{baseUrl}}/api/{{apiMetadata.apiHandle}}">{{or apiMetadata.apiInfo.apiTitle apiMetadata.apiInfo.apiName}}</a>
  <i class="bi bi-chevron-right dp-breadcrumb-sep"></i>
  <span class="dp-breadcrumb-current">API Keys</span>
</nav>

<div class="page-header">
  <div>
    <h1 class="page-title">API Keys</h1>
    <p class="page-desc">API keys authenticate requests to the {{or apiMetadata.apiInfo.apiTitle apiMetadata.apiInfo.apiName}}. Generate a key, then use it as a bearer token or <code class="ak-inline-code">apikey</code> header.</p>
  </div>
  {{#if apiKeys.length}}
  {{#unless isReadOnlyMode}}
  {{#unless apiKeysLoadError}}
  <button type="button" class="dp-btn dp-btn--primary" id="btn-open-generate-api-key">
    <i class="bi bi-plus"></i> Generate API key
  </button>
  {{/unless}}
  {{/unless}}
  {{/if}}
</div>

{{> api-key-list }}

{{> alert }}
