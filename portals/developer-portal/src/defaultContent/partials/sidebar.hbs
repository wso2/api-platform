<div class="sidebar" id="sidebar">
  <nav class="nav">
    <a href="{{baseUrl}}/" class="nav-link" id="home">
      <i class="bi bi-house sidebar-icon"></i>
      <span class="nav-text">Home</span>
    </a>
    {{#in devportalMode values="DEFAULT,APIS_ONLY"}}
    <a href="{{baseUrl}}/apis" class="nav-link" id="apis">
      <i class="bi bi-boxes sidebar-icon"></i>
      <span class="nav-text">APIs</span>
      <i class="bi bi-chevron-right sidebar-chevron nav-text"></i>
    </a>
    <div class="submenu api-submenu" id="api-submenu">
      <a href="#" class="nav-link submenu-link fw-light" id="api-overview">
        <i class="bi bi-grid submenu-icon"></i>
        <span class="nav-text">Overview</span>
      </a>
      <a href="#" class="nav-link submenu-link fw-light" id="api-docs">
        <i class="bi bi-file-text submenu-icon"></i>
        <span class="nav-text">Documentation</span>
      </a>
      {{#if showApiKeysNav}}
      <a href="#" class="nav-link submenu-link fw-light" id="api-keys-nav">
        <i class="bi bi-key submenu-icon"></i>
        <span class="nav-text">API Keys</span>
      </a>
      {{/if}}
    </div>
    {{/in}}
    {{#in devportalMode values="DEFAULT,MCP_SERVERS_ONLY"}}
    <a href="{{baseUrl}}/mcps" class="nav-link" id="mcps">
      <img src="/images/mcp-icon.svg" class="sidebar-icon" alt="" />
      <span class="nav-text">MCP Servers</span>
      <i class="bi bi-chevron-right sidebar-chevron nav-text"></i>
    </a>
    <div class="submenu api-submenu" id="mcp-submenu">
      <a href="#" class="nav-link submenu-link fw-light" id="mcp-overview">
        <i class="bi bi-grid submenu-icon"></i>
        <span class="nav-text">Overview</span>
      </a>
      <a href="#" class="nav-link submenu-link fw-light" id="mcp-docs">
        <i class="bi bi-file-text submenu-icon"></i>
        <span class="nav-text">Documentation</span>
      </a>
    </div>
    {{/in}}
    <a href="{{baseUrl}}/api-workflows" class="nav-link" id="api-workflows">
      <i class="bi bi-diagram-3 sidebar-icon"></i>
      <span class="nav-text">API Workflows</span>
    </a>
    <a href="{{baseUrl}}/applications" class="nav-link" id="applications">
      <img src="/images/applications-icon.svg" class="sidebar-icon" alt="" />
      <span class="nav-text">Applications</span>
    </a>
    <a href="{{baseUrl}}/subscriptions" class="nav-link" id="subscriptions">
      <i class="bi bi-receipt sidebar-icon"></i>
      <span class="nav-text">Subscriptions</span>
    </a>
    <a href="{{baseUrl}}/api-keys" class="nav-link" id="api-keys">
      <i class="bi bi-key sidebar-icon"></i>
      <span class="nav-text">API Keys</span>
    </a>
  </nav>

  {{#if profile.isAdmin}}
  {{!-- Settings is org-scoped (no view segment); derive /:orgName/settings from the view-scoped baseUrl --}}
  <a href="{{beforeSeparator baseUrl '/views/'}}/settings" class="nav-link" id="admin-settings">
    <i class="bi bi-gear sidebar-icon"></i>
    <span class="nav-text">Settings</span>
  </a>
  {{/if}}
  <div class="nav-section-divider"></div>
  <button class="collapse-btn" id="collapseBtn">
    <i class="bi bi-chevron-right"></i>
    <span class="collapse-text">Expand</span>
  </button>
</div>
