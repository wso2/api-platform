# --------------------------------------------------------------------
# Secrets for the Developer Portal + Platform API distribution stack.
#
#   cp .env.example .env      # .env is git-ignored — never commit it
#
# Generate each key with:  openssl rand -hex 32
#
# AUTH_JWT_SECRET_KEY and ENCRYPTION_KEY are injected into the Platform API
# container (env_file) and resolved by configs/config-platform-api.toml via
# {{ env "..." }} tokens. AUTH_JWT_SECRET_KEY is ALSO consumed by the
# devportal service (APIP_DP_PLATFORMAPI_JWTSECRET) so it can verify the
# Platform API's login JWTs — both read the same value from this file.
# Never hardcode secret values in docker-compose.yaml or the config TOML.
# For production, prefer mounting a secret file and using {{ file "..." }}.
# --------------------------------------------------------------------

# Signs Platform API login JWTs; the devportal verifies them with the same
# value. Keep stable across restarts. 32-byte key: 64 hex chars or base64.
AUTH_JWT_SECRET_KEY=

# Encrypts secrets / subscription tokens / HMAC secrets at rest. Keep stable
# across restarts and replicas. 32-byte key: 64 hex chars or base64.
ENCRYPTION_KEY=
