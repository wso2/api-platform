# Developer Portal Configuration
#
# Copy this file to config.yaml and adjust the values for your setup.
# Every setting here can also be overridden via a DP_* environment variable:
#
#   Convention: DP_<LEVEL1>_<LEVEL2>_...
#   - Each underscore-separated token maps to one config level (case-insensitive)
#   - Double underscores (__) represent a literal underscore within a key name
#
#   Examples:
#     DP_DB_HOST=myhost                    → db.host
#     DP_DB_PASSWORD=pass                  → db.password
#     DP_IDENTITYPROVIDER_CLIENTID=abc     → identityProvider.clientId
#     DP_ADVANCED_APIKEY_KEYVALUE=secret   → advanced.apiKey.keyValue
#     DP_TELEMETRY_CONNECTIONSTRING=...    → telemetry.connectionString
#
# You can place env var overrides in a .env file at the project root.

# ─── Server ────────────────────────────────────────────────────────────────────

baseUrl: "http://localhost:3000"
defaultPort: 3000
readOnlyMode: false
mode: "production"        # "production" or "development" (dev mode uses pathToContent)
disableTLS: true
pathToContent: "./resources/default-layout/"
pathToDBCert: "./resources/security/ca.pem"

# ─── Logging ───────────────────────────────────────────────────────────────────

logging:
  consoleOnly: false      # Set to true (or DP_LOGGING_CONSOLEONLY=true) for Docker/cloud

# ─── Database ──────────────────────────────────────────────────────────────────
# Supported dialects: sqlite (default), postgres
# SQLite: only 'storage' is required (path to the .db file)
# PostgreSQL: set host, port, database, username, password and dialect: postgres

db:
  dialect: "sqlite"
  storage: "./devportal.db"       # SQLite only: path to the database file
  # host: "localhost"               # PostgreSQL only
  # port: 5432                      # PostgreSQL only
  # database: "devportal"           # PostgreSQL only
  # username: "postgres"            # PostgreSQL only
  # password: ""                    # PostgreSQL only — set via DP_DB_PASSWORD in production

# ─── Advanced ──────────────────────────────────────────────────────────────────

advanced:
  http: true              # Use plain HTTP (no TLS). Set to false to require serverCerts below
  dbSslDialectOption: false
  disabledRoleValidation: true
  disableOrgCallback: true

  disableSilentSSO: false
  encryptionKey: ""  # 64-char hex key for AES-256-GCM encryption of sensitive data at rest
  apiKey:
    enabled: true
    keyType: "x-wso2-api-key"
    keyValue: ""              # Secret key value — set via DP_ADVANCED_APIKEY_KEYVALUE in production
  # OpenAPI-spec-driven /devportal router: request validation + fine-grained OAuth2
  # scope enforcement, dispatching by operationId to src/openapi/handlers.
  openApiValidator:
    # Response validation strategy. Off by default in production.
    #   off      — disabled
    #   strict     — strict; responses that don't match the spec become 500s
    #   'log-only' — log drift via warn-level logs but send the response anyway
    # When unset, enabled only if mode == "development".
    validateResponses: off 

# ─── TLS Certificates (only needed when advanced.http is false) ────────────────

serverCerts:
  pathToCert: "./resources/security/client-truststore.pem"
  pathToPK: "./resources/security/private-key.pem"
  pathToCA: "./resources/security/client-truststore.pem"

# ─── Identity Provider (OAuth2 / OIDC) ────────────────────────────────────────
# Leave clientId empty to use local auth (Platform API sidecar) instead of OIDC.
# For IDP-specific setup guides (Asgardeo, Keycloak) see docs/administer/authentication.md

identityProvider:
  name: "IS"                 # IDP name used in logs — env: DP_IDENTITYPROVIDER_NAME
  issuer: "https://localhost:9443/oauth2/token"
  authorizationURL: "https://localhost:9443/oauth2/authorize"
  tokenURL: "https://localhost:9443/oauth2/token"
  userInfoURL: "https://localhost:9443/oauth2/userinfo"
  clientId: ""               # Set to enable OIDC — env: DP_IDENTITYPROVIDER_CLIENTID
  clientSecret: ""           # Confidential client secret (Traditional Web App / Keycloak)
                             # Leave empty for PKCE public client — env: DP_IDENTITYPROVIDER_CLIENTSECRET
  audience: ""               # JWT aud claim to verify (usually the clientId); leave empty to skip
                             # env: DP_IDENTITYPROVIDER_AUDIENCE
  callbackURL: "http://localhost:3000/default/callback"
  scope: "openid profile email"  # Space-separated OIDC scopes to request
                                  # env: DP_IDENTITYPROVIDER_SCOPE
  signUpURL: ""
  logoutURL: "https://localhost:9443/oidc/logout"
  logoutRedirectURI: "http://localhost:3000/default"
  certificate: ""
  jwksURL: "https://localhost:9443/oauth2/jwks"
  tokenRefreshTimeoutMs: 10000

  # ── Claim name mappings — adjust to match what your IDP puts in the JWT ──────
  # Dot-notation is supported for nested claims (e.g. "realm_access.roles" for Keycloak)
  roleClaim: "roles"                # env: DP_IDENTITYPROVIDER_ROLECLAIM
  orgIDClaim: "organization.uuid"   # Asgardeo B2B uses "org_id" — env: DP_IDENTITYPROVIDER_ORGIDCLAIM
  groupsClaim: "groups"             # env: DP_IDENTITYPROVIDER_GROUPSCLAIM
  adminRole: "admin"                # env: DP_IDENTITYPROVIDER_ADMINROLE
  subscriberRole: "Internal/subscriber"  # env: DP_IDENTITYPROVIDER_SUBSCRIBERROLE
  superAdminRole: "superAdmin"      # env: DP_IDENTITYPROVIDER_SUPERADMINROLE

  # ── Federated IdP hints — maps ?fidp=<key> query param to IDP identifier ─────
  fidp:
    google: "google"
    github: "github"
    microsoft: "microsoft"
    enterprise: "EnterpriseIDP"
    email: "LOCAL"

# ─── Platform API ─────────────────────────────────────────────────────────────
# Used for two purposes:
#
# 1. Local auth — when identityProvider.clientId is empty, the built-in login
#    form authenticates against Platform API and receives a signed JWT.
#    Users and their scopes are defined in configs/config-platform-api.toml.
#
# 2. Direct gateway integration — when an API has GATEWAY_TYPE = "wso2/api-platform"
#    and baseUrl is set, subscription and API key operations are forwarded to the
#    Platform API instead of publishing webhook events. The Platform API is then
#    responsible for propagating state to the gateway.
#    If baseUrl is unset, the webhook path is used as a fallback for all gateway types.
#
# Leave baseUrl empty (or unset) to disable both features.

platformApi:
  baseUrl: ""           # e.g. https://platform-api:9243  — env: DP_PLATFORMAPI_BASEURL
  jwtSecret: ""         # Same value as AUTH_JWT_SECRET_KEY in the Platform API; enables
                        # local HS256 verification of Bearer tokens with no network call.
                        # env: DP_PLATFORMAPI_JWTSECRET
  insecure: false       # Accept self-signed Platform API certs (dev only).
                        # env: DP_PLATFORMAPI_INSECURE

# ─── Page Access Rules ─────────────────────────────────────────────────────────

authenticatedPages:
  - "/portal/*/edit"
  - "/portal"
  - "/*/configure"
  - "**/applications"
  - "**/applications/**"
  - "**/myapis"
  - "**/myapis/**"
  - "**/myapis?**"

authorizedPages:
  - "**/applications"
  - "**/applications/**"
  - "/*/configure"
  - "/portal/*/edit"
  - "/portal"
  - "**/myapis"
  - "**/myapis/**"
  - "**/myapis?**"

# ─── Portal UI Config ──────────────────────────────────────────────────────────

portalConfigs:
  showMaintenanceBanner: false
  maintenanceBannerText: ""

# ─── Telemetry ─────────────────────────────────────────────────────────────────

telemetry:
  enabled: false
  azureInsightsConnectionString: ""   # Azure Application Insights — set via DP_TELEMETRY_AZUREINSIGHTSCONNECTIONSTRING

# ─── Default Organization Seeding ─────────────────────────────────────────────
# When set, an organization with this name is created automatically on startup
# (idempotent — safe to leave enabled permanently). Uses the role/claim settings
# from the sections below (roleClaim, adminRole, subscriberRole, etc.).
# Set to "" or remove the key to disable auto-seeding.
# Env var override: DP_DEFAULTORGNAME

defaultOrgName: "default"

# ─── Subscription Policies ─────────────────────────────────────────────────────
# When true, Bronze/Silver/Gold/Unlimited/AsyncUnlimited plans are auto-created
# for every new organization.

generateDefaultSubPolicies: true

# ─────────────────────────────────────────────────────────
# Outbound webhooks (gateway event delivery)
# ─────────────────────────────────────────────────────────
# When a user generates an API key, subscribes, etc., the devportal fires signed
# HTTP POST events to every matching subscriber below.  Gateways implement their
# own handler and never need a reverse connection into the devportal.
#
# Per-subscriber secrets / public keys can also be supplied via env vars:
#   DP_WEBHOOK_SECRET_<ID_UPPERCASED>   — HMAC signing secret
#   DP_WEBHOOK_PUBKEY_<ID_UPPERCASED>   — RSA public key (PEM) for key encryption
# where the ID is the subscriber `id` with non-alphanumeric chars replaced by _.
#
webhooks:
  subscribers: []
  # Example subscriber:
  #
  # subscribers:
  #   - id: my-gateway                         # stable identifier, used in DB + logs
  #     gatewayType: "my-gateway-type"          # matches API.GATEWAY_TYPE; use "*" for all
  #     url: "https://gateway.example.com/devportal/events"
  #     secret: "change-me-32-chars-minimum"   # env: DP_WEBHOOK_SECRET_MY_GATEWAY
  #     publicKeyPath: "/run/secrets/gateway-pubkey.pem"  # RSA-2048+ PEM file; env: DP_WEBHOOK_PUBLIC_KEY_PATH_MY_GATEWAY
  #     events:                                 # allowlist — omit to receive all event types
  #       - apikey.*
  #       - subscription.*
  #     timeoutMs: 5000

  delivery:
    maxAttempts: 8
    # Retry delays in seconds: 1 min, 5 min, 15 min, 30 min, 1 h, 2 h, 4 h, 8 h
    backoff: [60, 300, 900, 1800, 3600, 7200, 14400, 28800]
    pollIntervalMs: 2000
    batchSize: 50
    signatureToleranceSec: 300
