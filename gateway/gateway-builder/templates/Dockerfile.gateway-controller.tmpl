FROM {{ .BaseImage }}

# Copy policy definitions
RUN rm -rf /app/policies
COPY policies /app/policies

# Copy build manifest file for custom policy detection
COPY build-manifest.yaml /app/build-manifest.yaml

# Point the controller at the baked policy directory. The mounted config.toml reads this
# value through its controller.policies.definitions_path interpolation token, which references
# the env var APIP_GW_CONTROLLER_POLICIES_DEFINITIONS_PATH
ENV APIP_GW_CONTROLLER_POLICIES_DEFINITIONS_PATH=/app/policies

# Metadata labels
LABEL org.opencontainers.image.title="API Platform Gateway Controller"
LABEL org.opencontainers.image.description="API Platform Gateway Controller with custom policy definitions"
LABEL org.opencontainers.image.vendor="WSO2"
LABEL build.timestamp="{{ .BuildTimestamp }}"
LABEL build.builder-version="{{ .BuilderVersion }}"
LABEL build.base-image="{{ .BaseImage }}"
{{- range $key, $value := .Labels }}
LABEL {{ $key }}="{{ $value }}"
{{- end }}
